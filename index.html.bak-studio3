};

function renderPage(id){
  // Hide loading, show main area
  const loading=$('loadingMsg');
  if(loading)loading.style.display='none';
  const main=$('appMain');
  if(!main)return;
  main.style.display='block';
  if(pages[id])main.innerHTML=pages[id];
  activePage=id;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  main.querySelectorAll('.page').forEach(p=>p.id===id&&p.classList.add('active'));
  navButtons();
  // Render specific page
  if(id==='home')renderHomeStats();
  if(id==='todo')renderTodos();
  if(id==='board')renderBoard();
  if(id==='projects')renderProjects();
  if(id==='calendar'){renderTimetableConfig();generateTimetableForDate(selectedDate||todayKey())}
  if(id==='calendar')renderCalendar();
  if(id==='chat')renderChat();
  if(id==='content'){switchContentTab('board');renderContentBoard();}
  if(id==='skills')renderSkills();
  if(id==='docs')renderDocs();
  if(id==='inbox')renderInbox();
  if(id==='gallery')renderGallery();
  if(id==='vault'){renderVault();renderVaultGraph();}
}

function navTo(id){
  if(id==='project-detail'){
    const main=$('appMain');if(main)main.innerHTML=pages.projectDetail;
    activePage='project-detail';
    navButtons();
    renderProjectDetail();
    return;
  }
  renderPage(id);
  // Switch to this page's thread if it exists
  const tid=pageThreads[id];
  if(tid){ activeThread=tid; renderChatHist(); }
  // Load OpenCode iframe when navigating to workspace
  if(id==='workspace'){
    const frame=$('ocFrame');
    if(frame&&frame.src==='about:blank'){
      frame.src='http://100.111.98.27:1704/';
      setTimeout(()=>{const ld=$('ocLoading');if(ld)ld.style.display='none';},2000);
    }
    checkOpenCodeStatus();
  }
}

