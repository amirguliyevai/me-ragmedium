// ─── OpenCode Workspace Status ─────────────────────
async function checkOpenCodeStatus(){
  try{
    const res=await fetch('/api/opencode/status').then(r=>r.json());
    const dot=$('ocDot'),label=$('ocLabel');
    if(dot&&label){
      dot.style.background=res.running?'var(--green)':'var(--red)';
      label.textContent=res.running?'Live':'Offline';
    }
  }catch(e){
    const dot=$('ocDot'),label=$('ocLabel');
    if(dot&&label){dot.style.background='var(--red)';label.textContent='Offline'}
  }
}
// ─── Legal AI messaging ─────────────────────────────
const LEGAL_THREAD_ID = 'legal-ai-assistant';
const LEGAL_SYSTEM_PROMPT = `You are a specialized Legal AI assistant embedded in the Kaneki productivity dashboard. Your role is to provide informative legal guidance and analysis to a tech entrepreneur running multiple businesses across SaaS, real estate, software development, and B2B services.

IMPORTANT DISCLAIMER: Always clarify you are providing informational guidance only, NOT formal legal advice. Recommend consulting a qualified attorney for specific legal matters.

Your capabilities:
- Analyze and explain legal concepts in plain language
- Review contract clauses and identify potential issues
- Explain regulatory frameworks (GDPR, CCPA, EU AI Act, etc.)
- Compare business entity structures (LLC, GmbH, UG, Ltd, etc.)
- Identify IP protection strategies
- Flag compliance risks in business operations
- Explain employment law basics across jurisdictions
- Help draft clauses and templates for common agreements

Context about the user:
- Based in Germany (Europe/Berlin timezone)
- Runs multiple businesses: SaaS platforms, white-label software, real estate, B2B services
- Works across EU, UK, and potentially US markets
- Businesses include: syneticX (health/biotech AI), LamaTrader/LamaBroker (white-label trading platforms), RAGmedium (B2B lead generation), Waterspring, Rema Exteriors
- Needs practical, actionable legal information relevant to tech startups and SMEs

Style: Be thorough but practical. Cite relevant laws and regulations (GDPR, BGB, HGB, etc.) where applicable. Flag jurisdiction-specific concerns. When comparing options, show pros/cons clearly.`;

async function sendLegalMsg(text){
  const input = $('legalInput');
  const msg = text || (input ? input.value.trim() : '');
  if(!msg) return;
  if(input){ input.value = ''; input.style.height = 'auto'; }
  
  const list = $('legalMsgList');
  if(!list) return;
  
  // Show user message
  const userDiv = document.createElement('div');
  userDiv.style.cssText = 'margin-bottom:12px;display:flex;justify-content:flex-end';
  userDiv.innerHTML = `<div style="max-width:85%;background:var(--accent);color:#fff;border-radius:16px 16px 4px 16px;padding:10px 14px;font-size:13px;line-height:1.5">${escapeHtml(msg)}</div>`;
  list.appendChild(userDiv);
  
  // Show thinking indicator
  const thinkDiv = document.createElement('div');
  thinkDiv.style.cssText = 'margin-bottom:12px;display:flex;justify-content:flex-start';
  thinkDiv.innerHTML = `<div style="max-width:85%;background:var(--panel2);color:var(--dim);border-radius:16px 16px 16px 4px;padding:10px 14px;font-size:13px">⚖️ Thinking…</div>`;
  list.appendChild(thinkDiv);
  list.scrollTop = list.scrollHeight;
  
  try {
    // Ensure legal thread exists
    await ensureLegalThread();
    
    // Build message with legal context prefix
    const fullMsg = `[Legal AI Mode — provide informational legal guidance with disclaimer]\n\nUser query: ${msg}`;
    
    const res = await fetch('/api/commands', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ text: fullMsg, threadId: LEGAL_THREAD_ID, send: true })
    }).then(r=>r.json());
    
    // Remove thinking indicator
    thinkDiv.remove();
    
    // Show AI response
    if(res && res.reply){
      const aiDiv = document.createElement('div');
      aiDiv.style.cssText = 'margin-bottom:12px;display:flex;justify-content:flex-start';
      aiDiv.innerHTML = `<div style="max-width:85%;background:var(--panel2);color:var(--fg);border-radius:16px 16px 16px 4px;padding:10px 14px;font-size:13px;line-height:1.5;white-space:pre-wrap">${escapeHtml(res.reply)}</div>`;
      list.appendChild(aiDiv);
    } else {
      const errDiv = document.createElement('div');
      errDiv.style.cssText = 'margin-bottom:12px;display:flex;justify-content:flex-start';
      errDiv.innerHTML = `<div style="max-width:85%;background:var(--panel2);color:var(--red);border-radius:16px 16px 16px 4px;padding:10px 14px;font-size:13px">⚠️ No response received. Try again.</div>`;
      list.appendChild(errDiv);
    }
  } catch(e) {
    thinkDiv.remove();
    const errDiv = document.createElement('div');
    errDiv.style.cssText = 'margin-bottom:12px;display:flex;justify-content:flex-start';
    errDiv.innerHTML = `<div style="max-width:85%;background:var(--panel2);color:var(--red);border-radius:16px 16px 16px 4px;padding:10px 14px;font-size:13px">⚠️ Error: ${escapeHtml(e.message)}</div>`;
    list.appendChild(errDiv);
  }
  list.scrollTop = list.scrollHeight;
}

async function ensureLegalThread(){
  const res = await api('/api/brain');
  if(!res || !res.brain) return;
  const threads = res.brain.threads || [];
  const existing = threads.find(t => t.id === LEGAL_THREAD_ID);
  if(!existing){
    // Create thread via state
    const s = await api('/api/state');
    s.brain = s.brain || {}; s.brain.threads = s.brain.threads || [];
    s.brain.threads.unshift({
      id: LEGAL_THREAD_ID,
      title: 'Legal AI Assistant',
      icon: '⚖️',
      scope: 'Legal AI — informational legal guidance for tech entrepreneurs.',
      tags: ['legal', 'compliance', 'advisor'],
      context: { businessIds: [] },
      sessionKey: 'agent:main:dashboard-legal-ai',
      messages: []
    });
    // Register on server via threads API (not full-state overwrite)
    fetch('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({
      id: LEGAL_THREAD_ID, title: 'Legal AI Assistant', icon: '⚖️',
      scope: 'Legal AI — informational legal guidance for tech entrepreneurs.',
      tags: ['legal', 'compliance', 'advisor'], context: { businessIds: [] },
      sessionKey: 'agent:main:dashboard-legal-ai'
    })}).catch(()=>{});
  }
}

function escapeHtml(s){
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

function reloadOC(){
  const frame=$('ocFrame');
  if(frame){frame.src='about:blank';setTimeout(()=>{frame.src='http://100.111.98.27:1704/';},100);}
  const ld=$('ocLoading');if(ld)ld.style.display='flex';
  setTimeout(()=>{const ld2=$('ocLoading');if(ld2)ld2.style.display='none';},2000);
}

// ─── GALLERY ────────────────────────────────────────
async function renderGallery(){
  var grid=$('galleryGrid'), count=$('galleryCount');
  if(!grid)return;
  grid.innerHTML='<div style="text-align:center;padding:20px;color:var(--dim);font-size:12px;grid-column:1/-1">Loading...</div>';
  try{
    var res=await fetch('/api/gallery');
    var data=await res.json();
    if(data.images&&data.images.length){
      var vids=data.images.filter(function(i){return i.type==='video';}).length;
      if(count)count.textContent=data.images.length+' files'+(vids?' + '+vids+' videos':'');
      grid.innerHTML=data.images.map(function(img){
        var f=img.file||'';
        var isVideo=img.type==='video'||['mp4','webm','mov','mkv'].indexOf(img.ext)>=0;
        if(isVideo){
          return '<div style="border-radius:6px;overflow:hidden;border:1px solid var(--line);background:var(--card);cursor:pointer;position:relative" onclick="openGalleryMedia(\''+f+'\',\'video\')"><div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:1;pointer-events:none"><div style="width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px">\u25b6</div></div><video src="/media/'+f+'" style="width:100%;height:120px;object-fit:cover;display:block" preload="metadata"></video><div style="padding:2px 6px;font-size:9px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">\u25b6 '+f+'</div></div>';
        }
        return '<div style="border-radius:6px;overflow:hidden;border:1px solid var(--line);background:var(--card);cursor:pointer" onclick="openGalleryMedia(\''+f+'\',\'image\')"><img src="/media/'+f+'" style="width:100%;height:120px;object-fit:cover;display:block" loading="lazy" onerror="this.parentElement.innerHTML=\'<div style=\"padding:30px;text-align:center;color:var(--dim)\">Broken</div>\'"><div style="padding:2px 6px;font-size:9px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+f+'</div></div>';
      }).join('');
    } else {
      grid.innerHTML='<div style="text-align:center;padding:40px;color:var(--dim);font-size:13px;grid-column:1/-1">No files yet.</div>';
    }
  }catch(e){
    grid.innerHTML='<div style="text-align:center;padding:40px;color:var(--dim);font-size:13px;grid-column:1/-1">Could not load gallery.</div>';
  }
}

// ─── CONTENT BOARD ───────────────────────────────────
let ctTab = 'board';
let ctEditId = null;

function switchContentTab(tab){
  ctTab = tab;
  const boardBtn = document.getElementById('ctBoardTab');
  const ideasBtn = document.getElementById('ctIdeasTab');
  const empireBtn = document.getElementById('ctEmpireTab');
  const boardView = document.getElementById('ctBoardView');
  const ideasView = document.getElementById('ctIdeasView');
  const empireView = document.getElementById('ctEmpireView');
  [boardBtn,ideasBtn,empireBtn].forEach(b=>{if(b){b.style.background='var(--card)';b.style.color='var(--text)';}});
  if(tab==='board'&&boardBtn){boardBtn.style.background='var(--blue)';boardBtn.style.color='#fff';}
  if(tab==='ideas'&&ideasBtn){ideasBtn.style.background='var(--blue)';ideasBtn.style.color='#fff';}
  if(tab==='empire'&&empireBtn){empireBtn.style.background='var(--blue)';empireBtn.style.color='#fff';}
  if(boardView)boardView.style.display=tab==='board'?'block':'none';
  if(ideasView)ideasView.style.display=tab==='ideas'?'block':'none';
  if(empireView)empireView.style.display=tab==='empire'?'block':'none';
  if(tab==='board')renderContentBoard();
  if(tab==='ideas')renderContentIdeas();
}

function renderContentBoard(){
  var el=document.getElementById('contentBoard');
  if(!el)return;
  var posts=state.brain?.content?.posts||[];
  var platforms=[
    {id:'linkedin-amir',label:'\ud83d\udd17 LinkedIn',icon:'\ud83d\udd17',accountId:'pb-linkedin'},
    {id:'x-amir',label:'\ud83d\udc26 X / BlueSky',icon:'\ud83d\udc26',accountId:'pb-x'},
    {id:'insta-personal',label:'\ud83d\udcf7 Personal Insta',icon:'\ud83d\udcf7',accountId:'pb-instagram'},
    {id:'insta-students',label:'\ud83c\udf93 Students Insta',icon:'\ud83c\udf93',accountId:'pb-instagram-students'},
    {id:'insta-business',label:'\ud83d\udcbc Business Insta',icon:'\ud83d\udcbc',accountId:'pb-instagram-business'},
    {id:'tiktok-amir',label:'\ud83c\udfb5 TikTok',icon:'\ud83c\udfb5',accountId:'pb-tiktok'},
    {id:'youtube-amir',label:'\u25b6\ufe0f YouTube',icon:'\u25b6\ufe0f',accountId:'pb-youtube'}
  ];
  var stages=['\ud83d\udca1 Idea','\u270f\ufe0f Drafting','\ud83c\udfa5 Editing','\u2705 Posted'];
  var stageKeys=['idea','drafted','editing','posted'];
  
  el.innerHTML=platforms.map(function(pl){
    var pfPosts=posts.filter(function(p){return (p.platform||'')===pl.label.replace(/[^a-zA-Z\/ ]/g,'').trim()||(p.accountId||'')===pl.accountId||(!p.platform&&!p.accountId);});
    // More flexible matching
    pfPosts=posts.filter(function(p){
      var plat=(p.platform||'').toLowerCase();
      var label=pl.label.toLowerCase();
      if(plat==='linkedin'&&label.includes('linkedin'))return true;
      if(plat.includes('x')&&label.includes('x / bluesky'))return true;
      if(plat.includes('tiktok')&&label.includes('tiktok'))return true;
      if(plat.includes('instagram')&&label.includes('personal insta'))return true;
      if(plat.includes('youtube')&&label.includes('youtube'))return true;
      if((p.accountId||'')===pl.accountId)return true;
      return false;
    });
    return '<div class="boardCol" style="min-width:180px;flex:1;background:var(--card);border-radius:8px;padding:8px;display:flex;flex-direction:column"><div style="font-size:11px;font-weight:700;color:var(--fg);margin-bottom:6px;padding:4px 8px;border-bottom:2px solid var(--blue)">'+pl.label+'</div>'+stages.map(function(st,i){
      var cards=pfPosts.filter(function(p){return (p.status||'idea')===stageKeys[i];});
      return '<div style="margin-bottom:6px"><div style="font-size:10px;color:var(--dim);margin-bottom:3px;padding:0 4px">'+st+' <span style="opacity:.5">'+cards.length+'</span></div><div style="min-height:30px;display:flex;flex-direction:column;gap:3px" ondragover="event.preventDefault()" ondrop="moveContentCardTo(event,\''+stageKeys[i]+'\')">'+cards.map(function(p){
        return '<div class="boardCard" draggable="true" onclick="openContentPostForm(\''+p.id+'\')" ondragstart="event.dataTransfer.setData(\'text/plain\',\''+p.id+'\')" style="padding:6px 8px;background:var(--soft);border-radius:4px;cursor:pointer;font-size:11px;border-left:2px solid var(--blue)"><div style="font-weight:500">'+esc(p.title||'Untitled')+'</div><div style="font-size:9px;color:var(--dim);margin-top:1px">'+(p.type||'')+'</div></div>';
      }).join('')+'</div></div>';
    }).join('')+'</div>';
  }).join('');
  
  document.querySelectorAll('.boardCard').forEach(function(card){
    card.addEventListener('dragstart',function(e){e.dataTransfer.setData('text/plain',this.getAttribute('ondragstart').match(/\\'([^\\']+)\\'/)?.[1]||'');});
  });
}

function moveContentCardTo(e,newStatus){
  var cid=e.dataTransfer?.getData('text/plain');
  if(!cid)return;
  api('/api/content/posts/'+cid,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify({status:newStatus})}).then(function(){load();});
}

function renderContentIdeas(){
  const el = document.getElementById('contentIdeasList');
  if(!el)return;
  const posts = (state.brain?.content?.posts||[]);
  if(!posts.length){el.innerHTML='<div style="text-align:center;padding:40px;color:var(--dim);font-size:13px">No content ideas yet. Start by clicking + New Post.</div>';return;}
  el.innerHTML = posts.map(p=>{
    const statusColors={idea:'var(--muted)',drafted:'var(--amber)',scheduled:'var(--blue)',posted:'var(--green)'};
    return '<div class="card" style="padding:10px 14px;cursor:pointer;display:flex;gap:10px;align-items:center" onclick="openContentPostForm(\''+p.id+'\')"><div style="width:8px;height:8px;border-radius:50%;background:'+(statusColors[p.status]||'var(--muted)')+';flex-shrink:0"></div><div style="flex:1;min-width:0"><div style="font-size:13px;font-weight:500">'+esc(p.title||'Untitled')+'</div><div style="font-size:10px;color:var(--dim);margin-top:2px">'+esc(p.platform||'')+' · '+(p.type||'')+' · '+(p.personaId||'')+'</div></div><div style="font-size:10px;color:var(--dim);flex-shrink:0">'+(p.status||'idea')+'</div></div>';
  }).join('');
}

function openContentPostForm(postId){
  ctEditId = postId||null;
  const modal = document.getElementById('ctPostModal');
  const title = document.getElementById('ctModalTitle');
  if(!modal)return;
  if(postId){
    const posts = state.brain?.content?.posts||[];
    const p = posts.find(x=>x.id===postId);
    if(p){
      if(title)title.textContent='Edit Post';
      const tEl=document.getElementById('ctPostTitle');if(tEl)tEl.value=p.title||'';
      const plEl=document.getElementById('ctPostPlatform');if(plEl)plEl.value=p.platform||'LinkedIn';
      const tyEl=document.getElementById('ctPostType');if(tyEl)tyEl.value=p.type||'insight';
      const peEl=document.getElementById('ctPostPersona');if(peEl)peEl.value=p.personaId||'';
      const stEl=document.getElementById('ctPostStatus');if(stEl)stEl.value=p.status||'idea';
      const boEl=document.getElementById('ctPostBody');if(boEl)boEl.value=p.body||'';
      const hoEl=document.getElementById('ctPostHook');if(hoEl)hoEl.value=p.hook||'';
    }
  } else {
    if(title)title.textContent='New Post';
    ['ctPostTitle','ctPostBody','ctPostHook'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
    const stEl=document.getElementById('ctPostStatus');if(stEl)stEl.value='idea';
    ctEditId = null;
  }
  modal.style.display='flex';
}

function closeContentPostForm(e){
  if(e&&e.target!==e.currentTarget)return;
  const modal = document.getElementById('ctPostModal');
  if(modal)modal.style.display='none';
}

async function saveContentPost(){
  const data = {
    title: document.getElementById('ctPostTitle')?.value||'Untitled',
    platform: document.getElementById('ctPostPlatform')?.value||'LinkedIn',
    type: document.getElementById('ctPostType')?.value||'insight',
    personaId: document.getElementById('ctPostPersona')?.value||'',
    status: document.getElementById('ctPostStatus')?.value||'idea',
    body: document.getElementById('ctPostBody')?.value||'',
    hook: document.getElementById('ctPostHook')?.value||'',
    businessId: 'personal-brand'
  };
  if(ctEditId){
    await api('/api/content/posts/'+ctEditId,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify(data)});
  } else {
    await api('/api/content/posts',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(data)});
  }
  closeContentPostForm();
  load();
}

// ─── GALLERY MODAL ──────────────────────────────────
function openGalleryMedia(file, type){
  const modal = document.getElementById('galleryModal');
  const content = document.getElementById('galleryModalContent');
  const info = document.getElementById('galleryModalInfo');
  if(!modal||!content)return;
  const url = '/media/'+file;
  if(type==='video'){
    content.innerHTML = '<video src="'+url+'" controls autoplay style="max-width:90vw;max-height:80vh;border-radius:8px"></video>';
  } else {
    content.innerHTML = '<img src="'+url+'" style="max-width:90vw;max-height:80vh;border-radius:8px;object-fit:contain">';
  }
  if(info) info.textContent = file;
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeGalleryModal(){
  const modal = document.getElementById('galleryModal');
  if(!modal)return;
  modal.style.display = 'none';
  const content = document.getElementById('galleryModalContent');
  if(content) content.innerHTML = '';
  document.body.style.overflow = '';
}
// ─── VAULT 3D KNOWLEDGE GRAPH ─────────────────────
let vaultNodes=[],vaultEdges=[],vaultAnim=null;

function renderVaultGraph(){
  const canvas=$('vaultCanvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.parentElement.clientWidth;
  const H=canvas.parentElement.clientHeight;
  canvas.width=W*2;canvas.height=H*2;
  canvas.style.width=W+'px';canvas.style.height=H+'px';
  ctx.scale(2,2);
  
  // Build nodes from brain threads
  const threads=state.brain?.threads||[];
  vaultNodes=threads.filter(t=>t.title&&t.title!=='General Brain'&&t.title!=='Chat chat 9').map(t=>({
    id:t.id,label:t.title,radius:8+Math.min((t.messages||[]).length,20)*1.5,
    x:40+Math.random()*(W-80),y:40+Math.random()*(H-80),
    vx:0,vy:0,color:'#9cdef2',thread:t
  }));
  // Add businesses as hub nodes
  const biz=state.businesses||[];
  biz.forEach(b=>{
    vaultNodes.push({id:'biz_'+b.id,label:b.name,radius:16,x:Math.random()*W,y:Math.random()*H,vx:0,vy:0,color:'#e06c75',biz:true,thread:null});
  });
  // Fallback demo nodes when no data
  if(vaultNodes.length<3){
    const demos=[
      {id:'demo_projects',label:'Projects Hub',radius:18,color:'#e06c75',biz:true,thread:null},
      {id:'demo_tasks',label:'Active Tasks',radius:10,color:'#98c379',biz:false,thread:null},
      {id:'demo_docs',label:'Documents',radius:10,color:'#61afef',biz:false,thread:null},
      {id:'demo_revenue',label:'Revenue',radius:12,color:'#d19a66',biz:false,thread:null},
      {id:'demo_content',label:'Content',radius:9,color:'#c678dd',biz:false,thread:null},
    ];
    demos.forEach((d,i)=>{
      const angle=(i/demos.length)*Math.PI*2-1.5;
      const distance=Math.min(W,H)*0.25;
      d.x=W/2+Math.cos(angle)*distance;
      d.y=H/2+Math.sin(angle)*distance;
      d.vx=0;d.vy=0;
      vaultNodes.push(d);
    });
  }
  // Create edges between related nodes
  vaultEdges=[];
  for(let i=0;i<vaultNodes.length;i++){
    for(let j=i+1;j<vaultNodes.length;j++){
      if(Math.random()<0.3) vaultEdges.push({source:i,target:j});
    }
  }
  
  let hoverNode=null;
  let mx=0,my=0;
  
  function simulate(){
    // Simple force simulation
    for(let i=0;i<vaultNodes.length;i++){
      const n=vaultNodes[i];
      // Repulsion
      for(let j=0;j<vaultNodes.length;j++){
        if(i===j)continue;
        const o=vaultNodes[j];
        const dx=n.x-o.x,dy=n.y-o.y;
        const dist=Math.max(dx*dx+dy*dy,1);
        const force=500/dist;
        n.vx+=dx/dist*force;
        n.vy+=dy/dist*force;
      }
      // Attraction to center
      n.vx+=(W/2-n.x)*0.001;
      n.vy+=(H/2-n.y)*0.001;
      // Damping
      n.vx*=0.85;n.vy*=0.85;
      n.x+=n.vx;n.y+=n.vy;
      // Bounds
      n.x=Math.max(20,Math.min(W-20,n.x));
      n.y=Math.max(20,Math.min(H-20,n.y));
    }
    draw();
    vaultAnim=requestAnimationFrame(simulate);
  }
  
  function draw(){
    ctx.clearRect(0,0,W,H);
    // Draw edges
    ctx.strokeStyle='rgba(156,222,242,0.08)';
    ctx.lineWidth=1;
    vaultEdges.forEach(e=>{
      const s=vaultNodes[e.source],t=vaultNodes[e.target];
      if(!s||!t)return;
      ctx.beginPath();
      ctx.moveTo(s.x,s.y);
      ctx.lineTo(t.x,t.y);
      ctx.stroke();
    });
    // Draw nodes
    vaultNodes.forEach(n=>{
      const isHover=n===hoverNode;
      const r=isHover?n.radius+4:n.radius;
      ctx.beginPath();
      ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fillStyle=n.color||(n.biz?'#e06c75':'#9cdef2');
      ctx.globalAlpha=n.biz?0.8:0.6;
      ctx.fill();
      ctx.globalAlpha=1;
      if(isHover){
        ctx.strokeStyle='#fff';
        ctx.lineWidth=2;
        ctx.stroke();
      }
      // Label
      ctx.fillStyle=n.biz?'#e06c75':'#9cdef2';
      ctx.font='9px system-ui,sans-serif';
      ctx.textAlign='center';
      ctx.fillText(n.label.substring(0,15),n.x,n.y+r+10);
    });
    // Node info
    const info=$('vaultNodeInfo');
    if(info&&hoverNode){
      info.style.display='block';
      info.textContent=hoverNode.label+(hoverNode.thread?(' — '+(hoverNode.thread.messages||[]).length+' messages'):' (project hub)');
    }else if(info)info.style.display='none';
  }
  
  // Mouse interaction
  canvas.onmousemove=function(e){
    const rect=canvas.getBoundingClientRect();
    mx=e.clientX-rect.left;my=e.clientY-rect.top;
    hoverNode=null;
    for(let i=vaultNodes.length-1;i>=0;i--){
      const n=vaultNodes[i];
      const dx=mx-n.x,dy=my-n.y;
      if(dx*dx+dy*dy<(n.radius+8)*(n.radius+8)){hoverNode=n;break;}
    }
    canvas.style.cursor=hoverNode?'pointer':'grab';
  };
  canvas.onmouseleave=function(){hoverNode=null;const info=$('vaultNodeInfo');if(info)info.style.display='none';};
  canvas.onclick=function(){
    if(hoverNode&&hoverNode.thread)navTo('chat');
  };
  
  const stats=$('vaultStats');
  if(stats)stats.textContent=vaultNodes.length+' nodes';
  
  if(vaultAnim)cancelAnimationFrame(vaultAnim);
  simulate();
}

async function load(){
  try{
    state=await api('/api/state');
    // Restore last active thread — pick the one with most recent messages
    if(state.brain?.activeThread && state.brain.threads?.find(t=>t.id===state.brain.activeThread)){
      activeThread = state.brain.activeThread;
    } else {
      // Fallback: use the thread with the most recent non-system message
      const threads = (state.brain?.threads||[]).filter(t=>(t.messages||[]).some(m=>m.role!=='system'));
      if(threads.length){
        threads.sort((a,b)=>{
          const aLast = (a.messages||[]).filter(m=>m.role!=='system').slice(-1)[0];
          const bLast = (b.messages||[]).filter(m=>m.role!=='system').slice(-1)[0];
          return (bLast?.at||'').localeCompare(aLast?.at||'');
        });
        activeThread = threads[0].id;
      }
    }
  }catch(e){
    document.title='Dashboard offline';
    return;
  }
  navButtons();
  loadNotif();
  if(activePage==='home')renderHomeStats();
  else if(activePage==='todo')renderTodos();
  else if(activePage==='projects')renderProjects();
  else if(activePage==='project-detail')renderProjectDetail();
  else if(activePage==='calendar')renderCalendar();
  else if(activePage==='chat')renderChat();
  else if(activePage==='board')renderBoard();
  else if(activePage==='vault'){renderVault();renderVaultGraph();}
  else if(activePage==='gallery'){renderGallery();}
  else if(activePage==='inbox'){renderInbox();}
  else if(activePage==='content'){switchContentTab('board');renderContentBoard();}
  else if(activePage==='skills'){renderSkills();}
  else if(activePage==='docs'){renderDocs();}
}

// ─── INIT ─────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  try {
  navButtons();
  renderPage('chat');
  load();
  checkOpenCodeStatus();
  setupChatPaste();
  // Periodically check OpenCode status
  setInterval(checkOpenCodeStatus, 15000);
  } catch(e) {
    const lm = document.getElementById('loadingMsg');
    if(lm) {
      lm.innerHTML = '<div style="color:var(--red);font-weight:700">⚠️ Init Error</div><div style="font-size:12px;margin-top:8px">'+e.message+'</div><div style="font-size:10px;color:var(--dim);margin-top:4px">'+e.stack+'</div><button onclick="location.reload()" style="margin-top:12px;padding:6px 16px;border-radius:6px;border:1px solid var(--border);background:var(--card);color:var(--text);cursor:pointer">Reload</button>';
      lm.style.display = 'block';
    }
    console.error('Init error:', e);
  }
});

// Auto-resize chat textarea
document.addEventListener('input',function(e){
  if(e.target&&(e.target.id==='chatInput'||e.target.id==='barChatInput')){
    autoResizeChatInput(e.target);
  }
});

// Expose checkOpenCodeStatus globally
window.checkOpenCodeStatus = checkOpenCodeStatus;

// Enter key sends message (Shift+Enter for new line)
document.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&!e.shiftKey&&document.activeElement){
    if(document.activeElement.id==='chatInput'){
      e.preventDefault();
      sendChatMessage();
    } else if(document.activeElement.id==='barChatInput'){
      e.preventDefault();
      sendBarMessage();
    }
  }
  if(e.key==='Enter'&&!e.shiftKey&&document.activeElement===$('legalInput')){
    e.preventDefault();
    sendLegalMsg();
  }
});

// ─── NEW FEATURES: Research / Compare / Email ─────
async function startResearch(){
  const q=$('brainQuery');
  const r=$('brainResults');
  if(!q||!r||!q.value.trim())return;
  r.innerHTML='<div style="text-align:center;padding:20px;color:var(--muted)">🔍 Researching: '+esc(q.value)+'...</div>';
  // Send to Kaneki via Gateway
  sendChatMessage('Deep Research: '+q.value+' — Search the web, gather data from multiple sources, analyze findings, and produce a comprehensive research report with insights and sources.');
  r.innerHTML='<div style="text-align:center;padding:20px;color:var(--muted)">✅ Research submitted. Check Chat tab for results.</div>';
}

async function startCompare(){
  const p=$('comparePrompt');
  const ma=$('compareModelA');
  const mb=$('compareModelB');
  const ra=$('compareResultA');
  const rb=$('compareResultB');
  if(!p||!p.value.trim())return;
  ra.textContent='⏳ Running '+ma.value+'...';
  rb.textContent='⏳ Running '+mb.value+'...';
  ra.textContent='✅ Compare submitted. Check Chat tab for full results.';
  rb.textContent='Run this: Ask Kaneki to compare "'+esc(p.value)+'" using models '+ma.value+' vs '+mb.value;
  sendChatMessage('Compare models: Run prompt "'+p.value+'" on model '+ma.value+' and model '+mb.value+'. Compare and contrast the responses.');
}

async function checkGmail(){
  const el=$('emailList');
  if(!el)return;
  el.innerHTML='<div style="text-align:center;padding:20px;color:var(--muted)">⏳ Checking Gmail...</div>';
  try{
    const res=await fetch('/api/email/check',{method:'POST'}).then(r=>r.json());
    if(res.messages&&res.messages.length){
      el.innerHTML=res.messages.map(m=>'<div style="border-bottom:1px solid var(--line);padding:8px 0"><b>'+esc(m.from||'')+'</b> — '+esc(m.subject||'')+'</div>').join('');
    } else {
      el.innerHTML='<div style="text-align:center;padding:20px;color:var(--dim)">📭 No new messages.</div>';
    }
  }catch(e){
    el.innerHTML='<div style="text-align:center;padding:20px;color:var(--red)">Error: '+esc(e.message)+'</div>';
  }
}

// Bootstrap compare model selects
setTimeout(()=>{
  const ma=$('compareModelA'),mb=$('compareModelB');
  if(ma&&mb){
    ma.innerHTML=models.map(m=>'<option value="'+m.id+'"'+(m.id===models[0].id?' selected':'')+'>'+m.name+'</option>').join('');
    mb.innerHTML=models.map(m=>'<option value="'+m.id+'"'+(m.id===(models[1]||models[0]).id?' selected':'')+'>'+m.name+'</option>').join('');
  }
},1000);

// ─── MODEL PICKER ────────────────────────────────
const models=[
  {id:'opencode-go/deepseek-v4-flash',name:'DeepSeek Flash',short:'⚡'},
  {id:'deepseek/deepseek-v4-pro',name:'DeepSeek Pro',short:'🔷'},
  {id:'opencode-go/minimax-m2-5',name:'MiniMax M2.5',short:'🎯'},
  {id:'opencode-go/qwen-3.5-plus',name:'Qwen 3.5+',short:'🧠'},
];
let activeModel=models[1].id;
function toggleModelPicker(){
  const pop=$('modelPop');
  if(!pop)return;
  pop.classList.toggle('open');
  pop.innerHTML=models.map(m=>
    `<button onclick="setModel('${m.id}');toggleModelPicker()" style="${m.id===activeModel?'color:var(--blue);font-weight:700':''}">${m.short} ${m.name}</button>`
  ).join('');
  const btn=$('modelBtn');
  if(btn)btn.textContent=models.find(m=>m.id===activeModel)?.short||'⚡';
}
function setModel(id){
  activeModel=id;
  // Update both model buttons
  const chatBtn=$('modelBtn');
  if(chatBtn)chatBtn.textContent=models.find(m=>m.id===activeModel)?.short||'⚡';
  const codeBtn=$('codeModelBtn');
  if(codeBtn)codeBtn.textContent=models.find(m=>m.id===activeModel)?.short||'⚡';
}
let sidebarHidden=false;
function toggleSidebar(){
  const sb=$('sidebar');
  const btn=$('sidebarToggle');
  if(!sb)return;
  sidebarHidden=!sidebarHidden;
  sb.classList.toggle('hidden');
  if(btn){
    if(sidebarHidden){
      btn.innerHTML='☰';
      btn.title='Open menu';
    } else {
      btn.innerHTML='☰ <span>Menu</span>';
      btn.title='Close menu';
    }
  }
  if(activePage==='vault')renderVaultGraph();
}
function toggleCodeModelPicker(){
  const pop=$('codeModelPop');
  if(!pop)return;
  pop.classList.toggle('open');
  pop.innerHTML=models.map(m=>
    `<button onclick="setModel('${m.id}');toggleCodeModelPicker()" style="${m.id===activeModel?'color:var(--blue);font-weight:700':''}">${m.short} ${m.name}</button>`
  ).join('');
  const btn=$('codeModelBtn');
  if(btn)btn.textContent=models.find(m=>m.id===activeModel)?.short||'⚡';
}

// ─── CHAT RESIZE ────────────────────────────────────
let chatResizeActive=false,chatResizeStartY=0,chatResizeStartH=0;
function startChatResize(e){
  chatResizeActive=true;
  chatResizeStartY=e.touches?e.touches[0].clientY:e.clientY;
  const p=$('chatPanel');
  chatResizeStartH=p?p.offsetHeight:300;
  e.preventDefault();
}
document.addEventListener('mousemove',e=>{
  if(!chatResizeActive)return;
  const p=$('chatPanel');if(!p)return;
  const dy=chatResizeStartY-e.clientY;
  const nh=Math.min(Math.max(chatResizeStartH+dy,120),window.innerHeight*0.9);
  p.style.height=nh+'px';p.style.maxHeight='none';
});
document.addEventListener('touchmove',e=>{
  if(!chatResizeActive)return;
  const p=$('chatPanel');if(!p)return;
  const dy=chatResizeStartY-(e.touches[0]?.clientY||0);
  const nh=Math.min(Math.max(chatResizeStartH+dy,120),window.innerHeight*0.9);
  p.style.height=nh+'px';p.style.maxHeight='none';
},{passive:false});
document.addEventListener('mouseup',()=>{chatResizeActive=false;});
document.addEventListener('touchend',()=>{chatResizeActive=false;});

// ─── CHAT OVERLAY ────────────────────────────────────
function renderChatOverlayMsgs(){
  const ml=$('overlayMsgList');
  if(!ml)return;
  const c=currentThread();
  const msgs=c.messages||[];
  ml.innerHTML=msgs.filter(m=>m.role!=='system').map(m=>{
    let body=esc(m.text||'');
    let mediaHtml='';
    if(m.media && Array.isArray(m.media)){
      for(const med of m.media){
        if(med.type && med.type.startsWith('image/')){
          mediaHtml += `<div style="margin-top:4px"><img src="${esc(med.url)}" style="max-width:200px;max-height:140px;border-radius:6px;cursor:pointer" onclick="window.open('${esc(med.url)}','_blank')" loading="lazy"></div>`;
        } else {
          mediaHtml += `<div style="margin-top:2px"><a href="${esc(med.url)}" target="_blank" style="font-size:11px;color:var(--blue)">📄 ${esc(med.name||'File')}</a></div>`;
        }
      }
    }
    return '<div class="msg '+(m.role==='user'?'user':'')+'"><div class="bubble">'+body.replace(/\n/g,'<br>').substring(0,500)+mediaHtml+'</div></div>';
  }).join('')||'<div style="padding:20px;text-align:center;color:var(--dim);font-size:12px">No messages yet</div>';
  ml.scrollTop=ml.scrollHeight;
}
function openChatOverlay(){
  const ov=$('chatOverlay');
  if(!ov)return;
  ov.classList.add('open');
  renderChatOverlayMsgs();
}
function closeChatOverlay(e){if(e&&e.target!==e.currentTarget)return;const ov=$('chatOverlay');if(ov)ov.classList.remove('open')}

// ─── PAYMENT EDITING ────────────────────────────────
function editPayment(id){
  const pays=state.payments||[];
  const p=pays.find(x=>x.id===id);
  if(!p)return;
  const amount=prompt('Amount (£)?',p.amount)||p.amount;
  const status=prompt('Status (paid/upcoming/pipeline)?',p.status)||p.status;
  const desc=prompt('Description?',p.description)||p.description;
  api('/api/payments/'+id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify({amount:parseFloat(amount),status,description:desc})}).then(()=>load());
}
function deletePayment(id){
  if(!confirm('Delete this payment?'))return;
  api('/api/payments/'+id,{method:'DELETE'}).then(()=>load());
}
function showProjectPayments(id){
  const el=$('projectPaymentsList');
  if(!el)return;
  const pays=(state.payments||[]).filter(p=>p.projectId===id);
  el.style.display=el.style.display==='none'?'':'none';
  if(el.style.display==='none')return;
  el.innerHTML=pays.length?pays.map(p=>`
    <div style="background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:10px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:8px">
      <div><span style="font-weight:700">\u00a3${p.amount.toLocaleString()}</span><span style="font-size:11px;color:var(--muted);margin-left:6px">${p.status}${p.type==='recurring'?' \u00b7 MRR':''}</span><div style="font-size:11px;color:var(--dim)">${esc(p.description||'')}</div></div>
      <div style="display:flex;gap:4px;flex-shrink:0">
        <button class="btn ghost" onclick="editPayment(\''+p.id+'\')" style="padding:2px 6px;font-size:10px">\u270e</button>
        <button class="btn ghost" onclick="deletePayment(\''+p.id+'\')" style="padding:2px 6px;font-size:10px;color:var(--red)">\u2716</button>
      </div>
    </div>`).join(''):'<div style="color:var(--dim);padding:10px;font-size:12px">No payments for this project.</div>';
}

// ─── THREAD MANAGEMENT ───────────────────────────────
// Track last message time - new thread if >5min since last
let lastMsgTime=0;
function createNewChat(){
  // Immediately create a fresh empty thread and switch to it
  state.brain=state.brain||{};state.brain.threads=state.brain.threads||[];
  delete pageThreads[activePage];
  const tid='thread_'+Date.now();
  const pageLabel=tabs.find(t=>t[0]===activePage)?.[2]||activePage;
  state.brain.threads.unshift({id:tid,title:pageLabel+' chat '+(state.brain.threads.length+1),messages:[],context:{businessIds:[],page:activePage}});
  activeThread=tid;
  pageThreads[activePage]=tid;
  // Server persists via /api/commands when messages are sent
  renderChatHist();renderChat();
}
// Page-aware thread map — each page gets its own thread
const pageThreads={};
async function deleteThread(id){
  if(!confirm('Delete this conversation?')) return;
  state.brain=state.brain||{};state.brain.threads=state.brain.threads||[];
  state.brain.threads=state.brain.threads.filter(t=>t.id!==id);
  if(activeThread===id) activeThread=(state.brain.threads[0]||{}).id||'';
  // Delete on server via proper endpoint (not full-state overwrite)
  fetch('/api/threads/'+id,{method:'DELETE'}).catch(()=>{});
  renderChatHist();renderChat();
  if(activePage==='code'){codeThreads=state.brain?.threads||[];switchCodeProject($('codeProject')?.value||'__all',false);}
}
function ensureFreshThread(){
  state.brain=state.brain||{};state.brain.threads=state.brain.threads||[];
  // Check if this page already has a thread
  const existingId=pageThreads[activePage];
  if(existingId){
    const t=state.brain.threads.find(x=>x.id===existingId);
    if(t){ activeThread=existingId; return t; }
  }
  // Create fresh thread for this page
  const tid='thread_'+Date.now();
  const pageLabel=tabs.find(t=>t[0]===activePage)?.[2]||activePage;
  state.brain.threads.unshift({id:tid,title:pageLabel+' chat '+(state.brain.threads.length+1),messages:[],context:{businessIds:[],page:activePage}});
  activeThread=tid;
  pageThreads[activePage]=tid;
  // Server persists threads via /api/commands — no need to save full state
  return state.brain.threads[0];
}

let vaultData=[];
async function renderVault(){
  try{
    const r=await fetch('/api/vault');
    const d=await r.json();
    vaultData=d.files||[];
    const s=$('vaultStats');
    if(s)s.innerHTML=`${d.fileCount||0} files · ${((d.totalSize||0)/1024).toFixed(1)} KB · indexed ${d.generated?.slice(0,10)||'today'}`;
    renderVaultFiles(vaultData);
  }catch(e){
    const f=$('vaultFiles'); if(f)f.innerHTML='<p style="color:var(--danger)">Vault index not available</p>';
  }
}
function renderVaultFiles(files){
  const el=$('vaultFiles'); if(!el)return;
  el.innerHTML=files.map(f=>`
    <div class="vaultFile" style="padding:8px;border-bottom:1px solid var(--border);cursor:pointer" onclick="toggleVaultFile(this,'${f.path}')">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <strong style="font-size:13px">📄 ${f.title}</strong>
        <span style="font-size:10px;color:var(--muted)">${f.path}</span>
      </div>
      <div style="font-size:11px;color:var(--muted);margin-top:4px">${f.sections.length} sections · ${f.size}B · ${f.fullKeywords?.length||0} keywords</div>
      <div class="vaultDetail" style="display:none;margin-top:8px;padding:8px;background:var(--bg);border-radius:6px">
        ${f.sections.map(s=>`
          <div style="margin-bottom:6px">
            <strong style="font-size:12px">${s.heading||'·'}</strong>
            <p style="font-size:11px;color:var(--muted);margin:2px 0">${s.content?.slice(0,200)||''}</p>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');
}
function toggleVaultFile(el,path){
  const detail=el.querySelector('.vaultDetail');
  if(detail) detail.style.display=detail.style.display==='none'?'block':'none';
}
function filterVault(q){
  if(!q) return renderVaultFiles(vaultData);
  const lower=q.toLowerCase();
  const filtered=vaultData.filter(f=>
    f.title.toLowerCase().includes(lower)||
    f.path.toLowerCase().includes(lower)||
    f.sections.some(s=>s.content.toLowerCase().includes(lower))
  );
  renderVaultFiles(filtered);
}

