<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><title>Amir Command</title><meta name="theme-color" content="#0d1117"><link rel="manifest" href="/manifest.webmanifest"><link rel="icon" href="/icons/icon-192.png"><style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d1117;--card:#161b22;--soft:#1c2129;--text:#e6edf3;--muted:#8b949e;--dim:#5c6570;--line:#30363d;--ink:#f0f6fc;--green:#2ea043;--amber:#d29922;--red:#f85149;--blue:#58a6ff;--radius:10px;--radius-lg:14px;--radius-xl:18px;--font:-apple-system,BlinkMacSystemFont,"Inter","Segoe UI",sans-serif;--mono:ui-monospace,"SF Mono",Menlo,monospace;--shadow:0 1px 3px rgba(0,0,0,.3)}
html,body{height:100%;overflow:hidden}body{margin:0;background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px;-webkit-font-smoothing:antialiased}
a{color:var(--blue)}

/* Odysseus-inspired Dark Theme */
:root{--sidebar-w:220px;--bg:#282c34;--bg2:#1e2228;--panel:#111;--panel2:#1e2228;--fg:#9cdef2;--heading:#9cdef2;--muted:#6b8a94;--text:#abb2bf;--dim:#4b5a64;--border:#355a66;--accent:#e06c75;--green:#98c379;--amber:#d19a66;--red:#e06c75;--blue:#61afef;--purple:#c678dd;--radius:8px;--radius-lg:12px;--radius-xl:16px;--font:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;--mono:ui-monospace,'SF Mono','Fira Code',monospace;--shadow:0 2px 8px rgba(0,0,0,.4);--transition:all .12s ease}
html,body{height:100%;overflow:hidden;background:var(--bg)}body{margin:0;color:var(--text);font-family:var(--font);font-size:14px;-webkit-font-smoothing:antialiased;display:flex}
a{color:var(--blue);text-decoration:none}

/* Lucide icons inline (lightweight SVG) */
.lucide{width:16px;height:16px;display:inline-block;vertical-align:middle;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.lucide-sm{width:14px;height:14px}
.lucide-lg{width:20px;height:20px}

/* Sidebar */
#sidebar{position:fixed;left:0;top:0;bottom:0;width:var(--sidebar-w);background:var(--panel);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;overflow:hidden}
#sidebar .brand{padding:16px 16px 12px;font-size:13px;font-weight:700;letter-spacing:-0.3px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);flex-shrink:0;color:var(--heading)}
#sidebar .brand .logo{width:24px;height:24px;border-radius:6px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff}
#sidebar .nav-scroll{flex:1;overflow-y:auto;padding:6px 8px}
#sidebar .nav-scroll::-webkit-scrollbar{width:4px}
#sidebar .nav-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
#sidebar .nav-group{font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.8px;padding:14px 12px 6px}
#sidebar .nav-item{display:flex;align-items:center;gap:10px;padding:6px 12px;border-radius:var(--radius);cursor:pointer;color:var(--text);font-size:13px;font-weight:400;transition:var(--transition);border:0;background:none;width:100%;text-align:left}
#sidebar .nav-item:hover{background:var(--bg2);color:var(--fg)}
#sidebar .nav-item.active{background:var(--bg2);color:var(--fg);font-weight:500}
#sidebar .nav-item .nav-icon{width:18px;height:18px;flex-shrink:0;color:var(--muted);display:flex;align-items:center;justify-content:center}
#sidebar .nav-item.active .nav-icon{color:var(--fg)}
#sidebar .nav-item .nav-badge{margin-left:auto;font-size:9px;padding:1px 6px;border-radius:10px;background:var(--accent);color:#fff;font-weight:600}
#sidebar .nav-divider{height:1px;background:var(--border);margin:4px 12px;opacity:.3}
#sidebar .bottom{flex-shrink:0;padding:8px;border-top:1px solid var(--border)}

/* Sidebar collapse - full hide with bookmark tab */
#sidebar.hidden{display:none}
#sidebar.hidden~#appWrap{margin-left:0;width:100%}
#sidebar.hidden~.chatBar{left:0;width:100%}
#sidebar.hidden+#appWrap #historyPane{left:0}

/* Sidebar toggle - always fixed top-left as a tab-like button */
#sidebarToggle{position:fixed;top:8px;left:8px;z-index:200;width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:var(--panel);color:var(--muted);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;transition:all .15s;padding:0;line-height:1}
#sidebarToggle:hover{background:var(--accent);color:#fff;border-color:var(--accent)}

/* When sidebar is hidden - bookmark tab style */
#sidebar.hidden~#sidebarToggle{left:0;top:0;width:36px;height:36px;border:0;border-radius:0 0 10px 0;background:var(--panel);font-size:14px;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
#sidebar.hidden~#sidebarToggle:hover{background:var(--bg2);color:var(--fg)}

/* When sidebar is visible - push the toggle inside the sidebar header */
#sidebar:not(.hidden)~#sidebarToggle{left:calc(var(--sidebar-w) - 32px);top:8px;width:24px;height:24px;font-size:10px;border-radius:6px}

/* Model Selector */
.model-select{display:flex;align-items:center;gap:6px;padding:5px 10px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg2);cursor:pointer;font-size:11px;color:var(--muted);transition:var(--transition)}
.model-select:hover{border-color:var(--fg);color:var(--fg)}
.model-select .ms-dot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0}

/* Main content area */
#appWrap{margin-left:var(--sidebar-w);width:calc(100% - var(--sidebar-w));height:100dvh;display:flex;flex-direction:column}
#appMain{flex:1;overflow-y:auto;padding:12px 16px 8px;min-height:0}
.page{display:none}.page.active{display:block;height:100%;overflow-y:auto}

/* Cards */
.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);padding:16px;margin-bottom:12px}

/* Kanban Board */
.boardWrap{height:100%;display:flex;flex-direction:column;overflow:hidden}
.boardCols{display:flex;gap:12px;overflow-x:auto;flex:1;padding-bottom:8px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}
.boardCol{min-width:280px;max-width:320px;flex-shrink:0;background:var(--soft);border:1px solid var(--line);border-radius:var(--radius-xl);display:flex;flex-direction:column;max-height:100%;scroll-snap-align:start}
.boardColHead{padding:12px 14px 8px;font-size:13px;font-weight:700;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line);flex-shrink:0}
.boardColHead .count{font-size:11px;color:var(--muted);font-weight:400}
.boardColBody{overflow-y:auto;padding:8px;flex:1;min-height:60px}
.boardCard{background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);padding:10px 12px;margin-bottom:8px;cursor:pointer;transition:border-color .12s,transform .1s}
.boardCard:hover{border-color:var(--blue);transform:translateY(-1px)}
.boardCard .bcTitle{font-size:12px;font-weight:600;line-height:1.4}
.boardCard .bcMeta{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}
.boardCard .bcTag{font:500 9px var(--mono);padding:2px 6px;border-radius:999px;border:1px solid var(--line);color:var(--muted)}
.boardCard .bcTag.high{border-color:var(--red);color:var(--red)}
.boardCard .bcTag.medium{border-color:var(--amber);color:var(--amber)}
.boardCard .bcTag.low{border-color:var(--dim);color:var(--dim)}
.boardCard .bcDone{text-decoration:line-through;opacity:0.5}
.boardCard .bcDate{font-size:9px;color:var(--dim);margin-top:4px}
.boardCard{position:relative}
.boardCard .bcActions{position:absolute;top:6px;right:6px;display:flex;gap:2px;opacity:0;transition:opacity .12s}
.boardCard:hover .bcActions{opacity:1}
.boardCard .bcActions button{width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--muted);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center;transition:all .1s}
.boardCard .bcActions button:hover{background:var(--soft);color:var(--text);border-color:var(--blue);transform:scale(1.1)}
.boardCard .bcActions .bcDoneBtn:hover{border-color:var(--green);color:var(--green)}
.boardCard .bcActions .bcChatBtn:hover{border-color:var(--blue);color:var(--blue)}
.boardCard .bcActions .bcCodeBtn:hover{border-color:var(--amber);color:var(--amber)}

/* Task Description */
.tpDesc{background:var(--soft);border:1px solid var(--line);border-radius:var(--radius);padding:10px 12px;margin-bottom:12px;font-size:12px;color:var(--muted);line-height:1.5;min-height:50px;white-space:pre-wrap}
.tpDesc.empty{color:var(--dim);font-style:italic;font-size:11px}
.tpDescEdit{width:100%;min-height:60px;padding:10px 12px;border-radius:var(--radius);border:1px solid var(--blue);background:var(--bg);color:var(--text);font:inherit;font-size:12px;line-height:1.5;resize:vertical;outline:none;margin-bottom:8px;display:none}
.tpDescEdit.open{display:block}
.tpDescHeader{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.tpDescHeader label{font-size:11px;font-weight:600;color:var(--muted)}
.tpDescHeader button{font-size:10px;padding:2px 8px;border-radius:6px}

.boardEmpty{color:var(--dim);font-size:11px;text-align:center;padding:20px}

/* Task Action Popup */
.taskOverlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:999;display:none;align-items:center;justify-content:center}
.taskOverlay.open{display:flex}
.taskPopup{background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);padding:20px;max-width:380px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,.5)}
.taskPopup h3{font-size:14px;margin:0 0 4px;line-height:1.4}
.taskPopup .tpMeta{font-size:11px;color:var(--muted);margin-bottom:14px}
.taskPopup .tpActions{display:flex;flex-direction:column;gap:8px}
.taskPopup .tpBtn{display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:var(--radius-lg);background:var(--soft);border:1px solid var(--line);cursor:pointer;transition:all .12s;font-size:13px;font-weight:600;text-align:left;color:var(--text)}
.taskPopup .tpBtn:hover{border-color:var(--blue);background:var(--card)}
.taskPopup .tpBtn .tpIcon{font-size:20px;width:28px;text-align:center;flex-shrink:0}
.taskPopup .tpBtn .tpSub{font-size:11px;color:var(--muted);font-weight:400}
.taskPopup .tpClose{display:block;margin-top:10px;text-align:center;padding:8px;border:0;background:transparent;color:var(--dim);font-size:12px;cursor:pointer;width:100%;border-radius:var(--radius)}
.taskPopup .tpClose:hover{background:var(--soft);color:var(--muted)}

.boardFilter{display:flex;gap:8px;padding:0 0 10px;flex-wrap:wrap;flex-shrink:0}
.boardFilter select,.boardFilter input{padding:6px 12px;border-radius:8px;border:1px solid var(--line);background:var(--card);color:var(--text);font-size:12px}

/* Menu Grid - 2x2 */
.menuGrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
.menuTile{background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);padding:28px 16px;cursor:pointer;text-align:center;transition:border-color .15s,background .15s}
.menuTile:hover{border-color:var(--blue);background:var(--soft)}
.menuTile .icon{font-size:28px;margin-bottom:6px}
.menuTile .name{font-size:14px;font-weight:700}
.menuTile .desc{font-size:11px;color:var(--muted);margin-top:4px}

/* Inputs */
.input{border:1px solid var(--line);background:var(--card);color:var(--text);border-radius:var(--radius);padding:10px 14px;font:inherit;font-size:14px;width:100%;outline:none}
.input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(88,166,255,.12)}

/* Buttons */
.btn{border:0;background:var(--ink);color:var(--bg);border-radius:var(--radius);padding:8px 18px;font-weight:600;font-size:13px;cursor:pointer;display:inline-flex;align-items:center;gap:6px}
.btn:hover{opacity:.85}.btn.alt{background:var(--card);color:var(--text);border:1px solid var(--line)}.btn.ghost{background:transparent;color:var(--muted)}.btn.ghost:hover{background:var(--soft);color:var(--text)}

/* Todo list */
.todoList{display:grid;gap:8px}
.todo{display:grid;grid-template-columns:32px 1fr auto;gap:8px;align-items:center;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);padding:10px 12px;min-height:72px;transition:border-color .12s}
.todo:hover{border-color:color-mix(in srgb,var(--blue)30%,var(--line))}
.todo .rank{font:700 12px var(--mono);color:var(--dim);text-align:center}
.todo.done .text{text-decoration:line-through;color:var(--dim)}
.todo .text{font-size:13px;font-weight:600;line-height:1.4;min-width:0}
.todo .meta{display:flex;gap:4px;flex-wrap:wrap;margin-top:3px}

/* Tags */
.tag{font:600 10px var(--mono);border:1px solid var(--line);background:var(--soft);color:var(--muted);padding:2px 8px;border-radius:999px;white-space:nowrap}
.tag.high{color:var(--red)}
.tag.medium{color:var(--amber)}

/* Project cards */
.projects{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px}
.project{background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);padding:16px;cursor:pointer;transition:border-color .12s}
.project:hover{border-color:var(--blue)}
.project h3{font-size:15px;margin-bottom:4px}
.project .lane{font-size:11px;color:var(--muted);margin-bottom:6px}
.project .desc{font-size:12px;color:var(--muted);display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}

/* Stats grid */
.statGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px}
.statCard{background:var(--soft);border:1px solid var(--line);border-radius:var(--radius-lg);padding:14px;text-align:center}
.statCard b{font-size:20px;font-weight:700;display:block}
.statCard span{font-size:11px;color:var(--muted)}

/* Daily Check-in */
.checkinCard{background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);padding:16px;margin-bottom:12px}
.checkinHeader{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.checkinHeader b{font-size:14px}
.checkinHeader small{font-size:11px;color:var(--dim)}
.moodRow{display:flex;gap:8px;margin:8px 0;flex-wrap:wrap}
.moodBtn{width:44px;height:44px;border-radius:50%;border:2px solid var(--line);background:transparent;font-size:22px;cursor:pointer;display:grid;place-items:center;transition:all .15s}
.moodBtn:hover,.moodBtn.sel{border-color:var(--blue);background:var(--soft);transform:scale(1.1)}
.scoreRow{display:flex;align-items:center;gap:10px;margin:8px 0}
.scoreRow input[type=range]{flex:1}
.scoreRow span{font-size:18px;font-weight:700;min-width:24px;text-align:center}
.hoursRow{display:flex;align-items:center;gap:8px;margin:8px 0}
.hoursRow input[type=number]{width:70px;padding:6px 8px;background:var(--bg);border:1px solid var(--line);color:var(--text);border-radius:var(--radius-lg);font-size:14px;text-align:center}
.hoursRow label{font-size:13px;color:var(--muted)}
.miniChart{display:flex;gap:4px;align-items:flex-end;height:60px;margin-top:8px}
.miniBar{flex:1;background:var(--blue);border-radius:3px 3px 0 0;min-width:8px;transition:height .3s;position:relative}
.miniBar span{position:absolute;bottom:-18px;left:0;right:0;text-align:center;font-size:9px;color:var(--dim);white-space:nowrap}
.miniBar.mood{background:var(--amber)}
.miniBar.prod{background:var(--green)}
.chartRow{display:flex;gap:10px;margin-top:10px}
.chartCol{flex:1}
.chartCol .label{font-size:10px;color:var(--muted);margin-bottom:4px;text-align:center}

/* Revenue */
.revPanel{margin-top:12px}
.revRow{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.revStat{background:var(--soft);border:1px solid var(--line);border-radius:var(--radius);padding:12px;text-align:center}
.revStat b{font-size:18px;display:block}
.revStat span{font-size:10px;color:var(--muted)}
.barChart{display:flex;align-items:flex-end;gap:12px;height:100px;padding:8px 0}
.barWrap{flex:1;display:flex;flex-direction:column;align-items:center;height:100%;justify-content:flex-end}
.bar{width:100%;max-width:50px;background:var(--blue);border-radius:4px 4px 0 0;min-height:4px;transition:height .3s}
.barLabel{font-size:10px;color:var(--muted);margin-top:4px}

/* Calendar - Two Column Layout */
.calPage{display:flex;gap:12px;height:100%;overflow:hidden}
.calLeft{flex:1;overflow-y:auto;padding-right:6px;min-width:0;max-width:none}
.calRight{flex:0 0 auto;width:40%;min-width:260px;overflow-y:auto}
@media(max-width:768px){.calPage{flex-direction:column;height:auto}.calLeft{width:100%}.calRight{width:100%;min-width:0}}

.calGrid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.calDay{display:flex;flex-direction:column;border-radius:var(--radius);cursor:pointer;position:relative;padding:3px 2px;min-height:72px;border:1px solid transparent;transition:all .1s}
.calDay:hover{background:var(--soft)}
.calDay.today{background:color-mix(in srgb,var(--blue)15%,var(--soft));border-color:var(--blue)}
.calDay.today .calNum{background:var(--blue);color:var(--bg)}
.calDay.selected{border:2px solid var(--blue);background:var(--soft)}
.calDay.other{opacity:0.3}
.calDay .calNum{font-size:10px;font-weight:700;color:var(--muted);margin-bottom:1px;width:18px;height:18px;display:flex;align-items:center;justify-content:center;border-radius:50%}
.calDay.today .calNum{background:var(--blue);color:var(--bg)}
.calDay .calPreview{font-size:9px;line-height:1.3;color:var(--dim);overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;word-break:break-word;margin-top:1px}
.calDay .calPreview .cpItem{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;padding:0 1px}
.calDay .calPreview .cpUrgent{color:var(--red);font-weight:600}
.calDay .calPreview .cpDeadline{color:var(--amber)}
.calDay .calPreview .cpEvent{color:var(--blue)}
.calDay .calPreview .cpDone{color:var(--green)}

/* Day View (Right Side) */
.dayView{padding:0 4px}
.dayViewHead{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--line)}
.dayViewHead h2{font-size:16px;margin:0}
.dayViewHead .dvLabel{font-size:11px;color:var(--muted)}
.dayViewHead .dvNav{display:flex;gap:4px}
.dayViewHead .dvNav button{padding:4px 10px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--text);cursor:pointer;font-size:12px}
.dayViewHead .dvNav button:hover{background:var(--soft)}

.daySection{margin-bottom:16px}
.daySection h4{font-size:12px;font-weight:600;margin:0 0 8px;color:var(--muted);display:flex;align-items:center;gap:6px}
.daySection h4 .dsCount{font-size:10px;color:var(--dim);font-weight:400}
.eventRow{padding:8px 10px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);margin-bottom:6px}
.eventRow:hover{border-color:var(--blue)}
.eventRow .edl{display:flex;align-items:center;gap:8px;flex:1;min-width:0}
.eventRow .edl .eText{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.eventRow .edl .eProj{font:500 9px var(--mono);padding:2px 6px;border-radius:999px;border:1px solid var(--line);color:var(--muted);flex-shrink:0}
.eventRow .edl .eTag{font:500 9px var(--mono);padding:1px 5px;border-radius:999px;border:1px solid var(--line);color:var(--muted);flex-shrink:0}
.eventRow .edl .eTag.high{border-color:var(--red);color:var(--red)}
.eventRow .edl .eTag.medium{border-color:var(--amber);color:var(--amber)}
.eventRow .edl .eTime{font-size:10px;color:var(--dim);flex-shrink:0}
.eventRow .edl .eDesc{font-size:11px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.deadlineUrgent{color:var(--red)!important}
.deadlineSoon{color:var(--amber)!important}

.calSync{font-size:10px;color:var(--dim);text-align:center;padding:4px 0;display:flex;justify-content:center;gap:12px}

/* Notification Bell */
.notifBell{position:relative;display:flex;align-items:center;justify-content:center}
.notifBell .badge{position:absolute;top:-2px;right:-4px;background:var(--red);color:var(--bg);font-size:8px;font-weight:700;min-width:14px;height:14px;border-radius:14px;display:flex;align-items:center;justify-content:center;padding:0 3px;line-height:1}
.notifPop{position:fixed;top:52px;left:8px;z-index:200;width:320px;max-height:70vh;overflow-y:auto;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);box-shadow:0 8px 32px rgba(0,0,0,.5);display:none;padding:8px}
.notifPop.open{display:block}
.notifItem{display:flex;gap:10px;padding:10px 8px;border-bottom:1px solid var(--line);align-items:flex-start;cursor:pointer}
.notifItem:last-child{border-bottom:0}
.notifItem:hover{background:var(--soft);border-radius:var(--radius)}
.notifItem .niIcon{font-size:18px;flex-shrink:0;margin-top:1px}
.notifItem .niBody{flex:1;min-width:0}
.notifItem .niTitle{font-size:12px;font-weight:600}
.notifItem .niTime{font-size:9px;color:var(--dim);margin-top:2px}
.notifEmpty{padding:30px;text-align:center;color:var(--dim);font-size:12px}
.calSync span{cursor:default}
.calSync .syncing{color:var(--amber)}
.calSync .synced{color:var(--green)}
.calSync .syncErr{color:var(--red)}

/* Timetable */
.timelineWrap{height:400px;overflow-y:auto;position:relative}
.timeline{position:relative}
.timelineHour{position:absolute;left:0;font-size:10px;color:var(--dim)}
.timelineLine{position:absolute;left:40px;right:0;border-top:1px solid var(--line)}
.timetableBlock{position:absolute;left:44px;right:8px;border-radius:6px;padding:4px 8px;overflow:hidden;font-size:11px}
.timetableBlock.meeting{background:color-mix(in srgb,var(--blue)15%,var(--card));border:1px solid color-mix(in srgb,var(--blue)30%,var(--line))}
.timetableBlock.task{background:color-mix(in srgb,var(--green)10%,var(--card));border:1px solid color-mix(in srgb,var(--green)20%,var(--line))}
.tbTitle{font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tbTime{font-size:10px;color:var(--muted)}

/* Chat page */
.chatWrap{display:flex;flex-direction:column;height:100%;position:relative}
.chatWrap .msgList{flex:1;overflow-y:auto;padding:8px 0 120px}
.chatWrap.has-messages .chatInputWrap{position:relative;bottom:auto;left:auto;transform:none;width:100%}
.chatWrap:not(.has-messages) .chatInputWrap{position:absolute;top:35%;left:50%;transform:translate(-50%,-50%);width:min(90%,600px)}
.chatInputWrap{padding:12px 16px;flex-shrink:0}
.msg{display:flex;flex-direction:column;margin-bottom:10px}
.msg.user{align-items:flex-end}
.msg .bubble{max-width:85%;padding:10px 14px;border-radius:var(--radius-lg);font-size:13px;line-height:1.5}
.msg .bubble{background:var(--soft);border:1px solid var(--line)}
.msg.user .bubble{background:var(--blue);color:var(--bg)}
.msg.system{align-items:center}
.msg.system .bubble{background:transparent;font-size:11px;color:var(--dim);text-align:center;max-width:100%}

/* Persistent Chat Bar */
.chatBar{position:fixed;bottom:0;left:var(--sidebar-w);right:0;z-index:100;background:var(--panel);border-top:1px solid var(--border);padding:8px 12px env(safe-area-inset-bottom);transition:left .2s ease,width .2s ease}
.chatBar textarea{flex:1;border:1px solid var(--border);background:var(--bg2);color:var(--fg);border-radius:16px;padding:10px 16px;font:inherit;font-size:14px;outline:none;min-height:40px;resize:none;overflow-y:auto;line-height:1.5;transition:border-color .15s}
.chatBar textarea:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(224,108,117,.15)}
.chatBar .sendBtn{border:0;background:var(--accent);color:#fff;border-radius:12px;width:40px;height:40px;cursor:pointer;font-size:16px;display:grid;place-items:center;flex-shrink:0;transition:all .15s}
.chatBar .sendBtn:hover{opacity:.85;transform:scale(1.05)}
.chatBar .settingsBtn{border:0;background:transparent;color:var(--muted);cursor:pointer;padding:6px;border-radius:8px;font-size:18px;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.chatBar .settingsBtn:hover{background:var(--soft);color:var(--fg)}
.chatBar .collapseBtn{border:0;background:transparent;color:var(--muted);cursor:pointer;padding:6px 4px;border-radius:8px;font-size:11px;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.chatBar .collapseBtn:hover{background:var(--soft);color:var(--fg)}
.settingsPop .modeBtn{border:0;background:var(--panel2);color:var(--muted);padding:5px 12px;border-radius:8px;cursor:pointer;font-size:11px;font-weight:600;transition:all .15s}
.settingsPop .modeBtn:hover,.settingsPop .modeBtn.active{background:var(--accent);color:#fff}
.settingsPop .checkItem{display:flex;align-items:center;gap:8px;padding:5px 12px;border-radius:6px;cursor:pointer;font-size:12px;color:var(--text);transition:background .1s}
.settingsPop .checkItem:hover{background:var(--soft)}
.settingsPop .checkItem input[type=checkbox]{accent-color:var(--accent);width:14px;height:14px;cursor:pointer}

/* History sidebar toggle for chat */
.historyToggle{position:fixed;left:var(--sidebar-w);top:8px;z-index:105;border:0;background:var(--panel);color:var(--muted);padding:6px 10px;border-radius:0 var(--radius) var(--radius) 0;cursor:pointer;font-size:14px;border-left:1px solid var(--border);border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.historyPane{position:fixed;left:var(--sidebar-w);top:0;bottom:0;z-index:101;width:260px;background:var(--panel);border-right:1px solid var(--border);overflow-y:auto;padding:48px 10px 10px;transform:translateX(-100%);transition:transform .2s}
.historyPane.open{transform:translateX(0)}
/* Desktop: history sidebar toggleable, shifts msg list + input */
@media(min-width:768px){
  .historyPane{left:var(--sidebar-w)}
  .historyPane.open{transform:translateX(0)}
  .historyPane.open ~ #msgList,
  .historyPane.open ~ .chatInputWrap{margin-left:260px}
  .historyToggle{display:none}
  .chatBar{left:var(--sidebar-w)!important;width:calc(100% - var(--sidebar-w))!important}
  #sidebar.hidden~.chatBar{left:0!important;width:100%!important}
  #sidebar.hidden ~ #appWrap .historyPane{left:0}
}
@media(max-width:767px){
  .historyPane{left:0;width:80%;max-width:300px}
  #msgList{margin-left:0!important}
  .chatBar{left:0!important;width:100%!important}
}
.histWrap{position:relative;display:block;margin-bottom:2px}
.histDel{position:absolute;top:2px;right:4px;width:18px;height:18px;border-radius:18px;border:0;background:var(--red);color:#fff;font-size:10px;line-height:18px;text-align:center;cursor:pointer;display:none;z-index:5;padding:0}
.histWrap:hover .histDel{display:flex;align-items:center;justify-content:center}
.histDel:hover{background:#e33}
.threadCard{position:relative}
.threadCard .thrDel{position:absolute;top:4px;right:4px;width:20px;height:20px;border-radius:20px;border:0;background:var(--red);color:#fff;font-size:11px;line-height:20px;text-align:center;cursor:pointer;display:none;z-index:5;padding:0}
.threadCard:hover .thrDel{display:flex;align-items:center;justify-content:center}
.threadCard .thrDel:hover{background:#e33}
.hist{display:block;width:100%;text-align:left;border:0;background:transparent;color:var(--text);padding:10px;border-radius:var(--radius);cursor:pointer;border-bottom:1px solid var(--line)}
.hist:hover{background:var(--soft)}
.hist.active{background:var(--soft);border-left:2px solid var(--blue)}
.hist b{display:block;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hist small{display:block;font-size:10px;color:var(--dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* Settings popup */
.settingsPop{display:none;position:fixed;bottom:56px;right:12px;z-index:90;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl);padding:14px;min-width:180px;box-shadow:var(--shadow)}
.settingsPop.open{display:grid;gap:4px}
.settingsPop button{border:0;background:transparent;color:var(--text);padding:8px 12px;border-radius:var(--radius);cursor:pointer;text-align:left;font-size:13px}
.settingsPop button:hover{background:var(--soft)}

/* Chat Overlay */
.chatOverlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:95;background:rgba(0,0,0,.5)}
.chatOverlay.open{display:block}
.chatPanel{position:fixed;bottom:56px;left:8px;right:8px;max-height:60dvh;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-xl) var(--radius-xl) var(--radius-lg) var(--radius-lg);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow)}
.chatPanelHead{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--line);flex-shrink:0}
.chatDragHandle{height:8px;cursor:ns-resize;background:var(--line);border-radius:0 0 4px 4px;margin:0 40%;flex-shrink:0;transition:background .15s}
.chatDragHandle:hover,.chatDragHandle:active{background:var(--blue)}
.chatPanel .msgList{flex:1;overflow-y:auto;padding:8px 12px;min-height:100px}

/* Model Picker */
.modelBtn{border:1px solid var(--line);border-radius:8px;padding:6px 10px;font-size:11px;font-weight:600;cursor:pointer;color:var(--muted);flex-shrink:0}

/* Content */
.contentTabs{display:flex;gap:4px;margin-bottom:12px}
.contentTabs button{border:0;background:var(--soft);color:var(--muted);padding:6px 14px;border-radius:var(--radius-lg);cursor:pointer;font-size:12px;font-weight:600}
.contentTabs button.active{background:var(--ink);color:var(--bg)}
.contentPanel{display:none}.contentPanel.active{display:block}

/* Charts */
.chart canvas{width:100%!important;height:200px!important}

/* Project detail */
.badge{padding:2px 8px;border-radius:12px;font-size:10px;font-weight:600;display:inline-block}

/* Responsive */
@media(max-width:480px){.menuGrid{gap:10px}.menuTile{padding:20px 12px}.projects{grid-template-columns:1fr}}
@media(max-width:767px){
  .chatBar textarea{padding:8px 12px;font-size:13px}
  .chatBar .sendBtn{width:36px;height:36px;font-size:14px}
  .settingsPop{min-width:220px!important;right:8px!important}
  .chatWrap .msgList:empty~.chatInputWrap{top:30%;width:95%}
  #appMain{padding-bottom:80px}
}
@media(min-width:768px){
  #appMain{padding-bottom:80px}
}
</style></head><body>

<!-- Sidebar -->
<aside id="sidebar">
  <div class="brand">
    <div class="logo">K</div>
    <span>Kaneki</span>
  </div>
  <div class="nav-scroll" id="sideNav"></div>
  <div class="bottom">
    <div class="model-select" id="modelSelect" onclick="toggleModelPicker()">
      <span class="ms-dot"></span>
      <span id="modelLabel">DeepSeek V4</span>
      <span style="margin-left:auto;font-size:9px;opacity:.5">▼</span>
    </div>
  </div>
</aside>
<button id="sidebarToggle" onclick="toggleSidebar()">☰ <span>Menu</span></button>

<!-- Main Area -->
<div id="appWrap">
  <div id="loadingMsg" style="padding:40px;text-align:center;color:var(--muted);font-size:13px">Loading dashboard…</div>
  <div id="appMain" style="display:none"></div>
  <!-- Global media lightbox (shared by gallery, docs, etc.) -->
  <div id="galleryModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;flex-direction:column" onclick="closeGalleryModal()">
    <button onclick="closeGalleryModal()" style="position:absolute;top:16px;right:16px;border:0;background:rgba(255,255,255,.1);color:#fff;font-size:24px;width:44px;height:44px;border-radius:50%;cursor:pointer;z-index:1">✕</button>
    <div id="galleryModalContent" style="max-width:90vw;max-height:85vh;display:flex;align-items:center;justify-content:center" onclick="event.stopPropagation()"></div>
    <div id="galleryModalInfo" style="color:#fff;font-size:12px;margin-top:8px;opacity:.7;text-align:center;max-width:80vw"></div>
  </div>
</div>

<!-- Persistent Chat Bar -->
<div class="chatBar" id="chatBar">
  <!-- Chat preview area (shows after first message) - ABOVE input -->
  <div id="barChatPreview" style="display:none;max-height:200px;overflow-y:auto;padding:0 0 8px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
      <span id="barPreviewTitle" style="font-size:11px;color:var(--muted);font-weight:600">Chat</span>
      <div style="display:flex;gap:4px">
        <button onclick="navTo('chat')" style="border:0;background:var(--accent);color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:10px;font-weight:600">Expand</button>
        <button onclick="closeBarPreview()" style="border:0;background:var(--soft);color:var(--muted);padding:3px 8px;border-radius:6px;cursor:pointer;font-size:10px">×</button>
      </div>
    </div>
    <div id="barPreviewMsgs"></div>
  </div>
  <!-- Collapsed state: just a thin bar -->
  <div id="barCollapsed" style="display:none;padding:4px 0">
    <button onclick="toggleBarCollapse()" style="border:0;background:var(--soft);color:var(--muted);cursor:pointer;padding:6px 12px;border-radius:8px;font-size:12px;width:100%;text-align:left">💬 Open chat...</button>
  </div>
  <!-- Input row -->
  <div id="barInputRow" style="display:flex;align-items:flex-end;gap:8px">
    <button class="collapseBtn" onclick="toggleBarCollapse()" title="Collapse">▼</button>
    <button onclick="newBarChat()" title="New chat" style="border:0;background:var(--soft);color:var(--muted);cursor:pointer;padding:6px 8px;border-radius:8px;font-size:16px;flex-shrink:0;transition:all .15s" onmouseenter="this.style.background='var(--blue)';this.style.color='#fff'" onmouseleave="this.style.background='var(--soft)';this.style.color='var(--muted)'">+</button>
    <textarea id="barChatInput" placeholder="Ask Kaneki to do anything…" autocomplete="off" rows="1"></textarea>
    <input type="file" id="barFileInput" multiple accept="image/*,.pdf,.doc,.docx,.txt,.zip" style="display:none" onchange="handleBarFileUpload(this.files)">
    <button onclick="document.getElementById('barFileInput').click()" title="Attach files or images" style="border:0;background:transparent;color:var(--muted);cursor:pointer;padding:4px;font-size:16px;flex-shrink:0">📎</button>
    <button class="sendBtn" id="sendBtn" onclick="sendBarMessage()">➤</button>
    <button class="settingsBtn" onclick="toggleBarSettings()" title="Settings">☰</button>
  </div>
</div>

<!-- Bar Settings Popup -->
<div class="settingsPop" id="barSettingsPop" style="bottom:70px;right:12px;min-width:260px;max-height:70dvh;overflow-y:auto">
  <div style="font-size:11px;font-weight:700;padding:8px 12px 6px;color:var(--muted)">Modes</div>
  <div style="display:flex;gap:4px;padding:0 8px 8px;flex-wrap:wrap">
    <button class="modeBtn" onclick="toggleBarMode('code')" id="barCodeModeBtn" style="border:0;background:var(--panel2);color:var(--muted);padding:5px 12px;border-radius:8px;cursor:pointer;font-size:11px;font-weight:600">⌘ Code</button>
    <button class="modeBtn" onclick="toggleBarMode('research')" id="barResearchModeBtn" style="border:0;background:var(--panel2);color:var(--muted);padding:5px 12px;border-radius:8px;cursor:pointer;font-size:11px;font-weight:600">🧠 Research</button>
    <button class="modeBtn" onclick="toggleBarDeepReasoning()" id="barDeepReasonBtn" style="border:0;background:var(--panel2);color:var(--muted);padding:5px 12px;border-radius:8px;cursor:pointer;font-size:11px;font-weight:600">🧠 Deep</button>
    <button class="modeBtn" onclick="toggleBarLawyerMode()" id="barLawyerBtn" style="border:0;background:var(--panel2);color:var(--muted);padding:5px 12px;border-radius:8px;cursor:pointer;font-size:11px;font-weight:600">⚖️ Legal</button>
  </div>
  <div style="height:1px;background:var(--line);margin:4px 0"></div>
  <div style="font-size:11px;font-weight:700;padding:8px 12px 6px;color:var(--muted)">Project</div>
  <div id="barProjectList" style="padding:0 8px 8px;max-height:120px;overflow-y:auto"></div>
  <div style="padding:0 8px 8px">
    <button onclick="createNewProject()" style="border:1px dashed var(--border);background:transparent;color:var(--muted);padding:6px 12px;border-radius:8px;cursor:pointer;font-size:11px;width:100%;text-align:left">＋ New Project</button>
  </div>
  <div style="height:1px;background:var(--line);margin:4px 0"></div>
  <div style="font-size:11px;font-weight:700;padding:8px 12px 6px;color:var(--muted)">Skills</div>
  <div id="barSkillsList" style="padding:0 8px 8px;max-height:120px;overflow-y:auto"></div>
  <div style="padding:0 8px 8px">
    <button onclick="createNewSkill()" style="border:1px dashed var(--border);background:transparent;color:var(--muted);padding:6px 12px;border-radius:8px;cursor:pointer;font-size:11px;width:100%;text-align:left">＋ New Skill</button>
  </div>
  <div style="height:1px;background:var(--line);margin:4px 0"></div>
  <div style="padding:4px 8px">
    <button onclick="toggleModelPicker()" style="border:0;background:transparent;color:var(--text);padding:8px 12px;border-radius:8px;cursor:pointer;font-size:12px;width:100%;text-align:left">⚡ Change Model</button>
    <button onclick="navTo('skills')" style="border:0;background:transparent;color:var(--text);padding:8px 12px;border-radius:8px;cursor:pointer;font-size:12px;width:100%;text-align:left">📋 All Skills</button>
  </div>
  <div id="barModeIndicator" style="font-size:9px;color:var(--dim);text-align:center;padding:6px 0;border-top:1px solid var(--line)">DeepSeek Pro</div>
</div>

<!-- Model Picker Popup -->
<div class="settingsPop" id="modelPop" style="bottom:60px;right:60px;min-width:140px"></div>

<!-- Chat Slide-up Overlay -->
<div id="chatOverlay" class="chatOverlay" onclick="closeChatOverlay(event)">
  <div class="chatPanel" id="chatPanel" onclick="event.stopPropagation()" style="height:45vh;min-height:120px;max-height:90vh">
    <div class="chatDragHandle" id="chatDragHandle" onmousedown="startChatResize(event)" ontouchstart="startChatResize(event)" title="Drag to resize"></div>
    <div class="chatPanelHead">
      <b id="chatOverlayTitle">Chat</b>
      <button class="btn ghost" onclick="createNewChat();openChatOverlay()" title="New chat" style="padding:4px 8px;font-size:14px">＋</button>
      <button class="btn ghost" onclick="closeChatOverlay()" style="padding:4px 8px;font-size:14px">×</button>
    </div>
    <div class="msgList" id="overlayMsgList"></div>
    <button class="btn alt" onclick="closeChatOverlay();navTo('chat')" style="margin:8px;font-size:11px">Open full chat →</button>
  </div>
</div>

<!-- Settings Popup -->
<div class="settingsPop" id="settingsPop"></div>

<!-- Notification Popup -->
<div class="notifPop" id="notifPop">
  <div style="font-size:12px;font-weight:700;padding:6px 8px 10px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between">
    <span>🔔 Notifications</span>
    <button class="btn ghost" onclick="markAllNotifRead()" style="font-size:10px;padding:2px 8px">Mark all read</button>
  </div>
  <div id="notifList"></div>
</div>

<script>
// ─── STATE ────────────────────────────────────────────
let state={},activePage='todo',activeThread='general',calCursor=new Date(),selectedDate='',todoView='list';
const $=id=>document.getElementById(id);

// Global error trap — shows errors on screen
window.onerror = function(msg, url, line, col, err) {
  const lm = $('loadingMsg');
  if(lm) {
    lm.innerHTML = `<div style="color:var(--red);font-weight:700">⚠️ JS Error</div><div style="font-size:12px;margin-top:8px">${msg}</div><div style="font-size:10px;color:var(--dim);margin-top:4px">Line ${line}:${col}</div><button class="btn" onclick="location.reload()" style="margin-top:12px;padding:6px 16px;border-radius:6px;border:1px solid var(--border);background:var(--card);color:var(--text);cursor:pointer">↻ Reload</button>`;
    lm.style.display = 'block';
  }
  console.error('Fatal:', msg, 'at', line+':'+col);
  return true;
};
const esc=s=>{const d=document.createElement('div');d.textContent=String(s);return d.innerHTML};
const clip=(s,n=140)=>{s=String(s||'').replace(/\s+/g,' ').trim();return s.length>n?s.slice(0,n-1)+'…':s};
function todayKey(d){d=d||new Date();if(d.getHours()<6)d.setDate(d.getDate()-1);return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')}

// Close popups on outside click
document.addEventListener('click',function(e){
  const barPop=$('barSettingsPop');
  if(barPop&&barPop.classList.contains('open')&&!barPop.contains(e.target)&&!e.target.closest('.settingsBtn')){
    barPop.classList.remove('open');
  }
  const modelPop=$('modelPop');
  if(modelPop&&modelPop.classList.contains('open')&&!modelPop.contains(e.target)&&!e.target.closest('.modelBtn')&&!e.target.closest('.model-select')){
    modelPop.classList.remove('open');
  }
});

// ─── NOTIFICATIONS ──────────────────────────────
let notifications=[];
let notifUnread=0;
function loadNotif(){
  const notes=[];
  // 1. Server activity log (task completions, project updates, uploads, etc.)
  const activity = (state.ops?.activity||[]).slice(-30).reverse();
  for(const a of activity){
    let icon='📌';
    const t = (a.text||'').toLowerCase();
    if(t.includes('task')||t.includes('todo')) icon='✅';
    else if(t.includes('completed')||t.includes('done')) icon='🎉';
    else if(t.includes('payment')) icon='💰';
    else if(t.includes('upload')) icon='📤';
    else if(t.includes('project')) icon='📁';
    else if(t.includes('business')) icon='🏢';
    else if(t.includes('command')||t.includes('thread')) icon='💬';
    else if(t.includes('calendar')||t.includes('event')) icon='📅';
    notes.push({id:'act_'+a.id,icon,title:clip(a.text,80),desc:'',at:a.at});
  }
  // 2. Recent thread replies
  for(const t of (state.brain?.threads||[])){
    const msgs=t.messages||[];
    const last=msgs[msgs.length-1];
    if(last&&last.role==='assistant'&&!last.pending&&last.at&&Date.now()-new Date(last.at).getTime()<7200000){
      notes.push({id:'thread_'+t.id,icon:'💬',title:'Reply in: '+(t.title||'Chat'),desc:clip(last.text,80),at:last.at});
    }
  }
  // 3. Today's tasks
  const allTodos=Object.values(state.todos||{}).flat();
  for(const t of allTodos.filter(t=>t.createdAt&&Date.now()-new Date(t.createdAt).getTime()<86400000).slice(-5)){
    notes.push({id:'todo_'+t.id,icon:t.done?'🎉':'✅',title:t.done?'Completed: '+clip(t.text,60):'Task added: '+clip(t.text,60),desc:'',at:t.done?t.doneAt:t.createdAt});
  }
  // 4. Today's calendar
  const today=todayKey();
  for(const e of (state.brain?.calendar||[]).filter(e=>e.start&&e.start.startsWith(today))){
    notes.push({id:'cal_'+e.id,icon:'📅',title:'Today: '+clip(e.title,40),desc:'',at:e.start});
  }
  notes.sort((a,b)=>new Date(b.at||0).getTime()-new Date(a.at||0).getTime());
  notifications=notes.slice(0,50);
  notifUnread=notifications.filter(n=>!n.read).length;
  updateNotifBadge();
}
function updateNotifBadge(){
  const tab=document.querySelector('.topNav button:first-child');
  if(!tab)return;
  if(notifUnread>0){
    const existing=tab.querySelector('.badge');
    if(existing)existing.textContent=notifUnread;
    else{const b=document.createElement('span');b.className='badge';b.textContent=notifUnread;tab.appendChild(b);tab.style.position='relative'}
  }else{
    const b=tab.querySelector('.badge');
    if(b)b.remove();
  }
}
function toggleNotifPop(){
  const pop=$('notifPop');
  if(!pop)return;
  pop.classList.toggle('open');
  if(pop.classList.contains('open')) renderNotifList();
}
function renderNotifList(){
  const el=$('notifList');
  if(!el)return;
  loadNotif();
  if(!notifications.length){
    el.innerHTML='<div class="notifEmpty">No recent notifications</div>';
    return;
  }
  el.innerHTML=notifications.map(n=>{
    const ts=n.at?new Date(n.at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
    return '<div class="notifItem" onclick="notifClick(\''+n.id+'\', this)">'+
      '<span class="niIcon">'+n.icon+'</span>'+
      '<div class="niBody">'+
        '<div class="niTitle">'+esc(n.title)+'</div>'+
        (n.desc?'<div style="font-size:10px;color:var(--muted);margin-top:2px">'+esc(n.desc)+'</div>':'')+
        '<div class="niTime">'+ts+'</div>'+
      '</div></div>';
  }).join('');
}
function markAllNotifRead(){
  notifications.forEach(n=>n.read=true);
  notifUnread=0;
  updateNotifBadge();
  renderNotifList();
}
function notifPopClose(){
  const pop=$('notifPop');
  if(pop)pop.classList.remove('open');
}
function notifClick(id,el){
  // Mark this one as read
  const n=notifications.find(x=>x.id===id);
  if(n){n.read=true;notifUnread=Math.max(0,notifUnread-1);updateNotifBadge();}
  if(el)el.style.opacity='0.5';
  notifPopClose();
  
  const type=id.split('_')[0];
  const actualId=id.substring(id.indexOf('_')+1);
  
  if(type==='thread'){
    // Navigate to chat page with this thread
    activeThread=actualId;
    navTo('chat');
  } else if(type==='todo'){
    // Navigate to todo and open task
    navTo('todo');
    if(todoView!=='list'){todoView='list';renderTodos();}
    setTimeout(()=>{
      const task=findTask(actualId);
      if(task) openTaskMenu(actualId);
    },100);
  } else if(type==='cal'){
    // Navigate to calendar
    navTo('calendar');
  }
}

function renderInbox(){
  loadNotif();
  const el=$('inboxList');
  const count=$('inboxCount');
  if(!el)return;
  if(count)count.textContent=notifications.length+' items · '+notifUnread+' unread';
  if(!notifications.length){
    el.innerHTML='<div style="text-align:center;padding:40px;color:var(--dim);font-size:13px">🔔 No notifications yet. Activity will appear here.</div>';
    return;
  }
  el.innerHTML=notifications.map(n=>{
    const ts=n.at?new Date(n.at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
    const day=n.at?new Date(n.at).toLocaleDateString([],{month:'short',day:'numeric'}):'';
    return '<div class="notifItem" onclick="notifClick(\''+n.id+'\', this)" style="padding:10px 12px;border-bottom:1px solid var(--line);cursor:pointer;display:flex;gap:10px;align-items:flex-start;transition:background .1s" onmouseenter="this.style.background=\'var(--soft)\'" onmouseleave="this.style.background=\'transparent\'">'+'<span style="font-size:18px;flex-shrink:0">'+n.icon+'</span>'+'<div style="flex:1;min-width:0">'+'<div style="font-size:13px;font-weight:500;color:var(--text)">'+esc(n.title)+'</div>'+ (n.desc?'<div style="font-size:11px;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+esc(n.desc)+'</div>':'') +'<div style="font-size:10px;color:var(--dim);margin-top:3px">'+day+' · '+ts+'</div>'+'</div></div>';
  }).join('');
}

function api(u,o){return fetch(u,o).then(r=>r.json().catch(()=>({}))).then(j=>{if(j.error)throw Error(j.error);return j})}

