/* Navigation groups for sidebar */
const navGroups=[
  {label:'Workspace',items:[
    ['home','◈','Home',0],
    ['workspace','⌘','Workspace',0],
    ['desktop','🖥️','Desktop',0],
    ['chat','💬','Chat',0],
  ]},
  {label:'Productivity',items:[
    ['todo','✓','Todo',0],
    ['board','📋','Board',0],
    ['calendar','◷','Calendar',0],
    ['projects','□','Projects',0],
  ]},
  {label:'Business',items:[
    ['crm','📞','RAGX',0],
    ['legal','⚖️','Legal AI',0],
    ['content','📣','Content',0],
    ['leads','📊','Leads',0],
  ]},
  {label:'Tools',items:[
    ['brain','🧠','Deep Research',0],
    ['inbox','🔔','Inbox',0],
    ['docs','📄','Docs',0],
    ['gallery','🖼️','Gallery',0],
  ]},
  {label:'System',items:[
    ['skills','⚙️','Skills',0],
    ['mindmap','🗺️','Mindmap',0],
    ['scrape','🕷️','Scraper',0],
    ['vault','🧠','Vault',0],
  ]},
];

// Flat tabs list for backward compat
const tabs=[].concat(...navGroups.map(g=>g.items));

function navButtons(){
  const nav=$('sideNav');
  if(!nav)return;
  // SVG icon paths (Lucide-compatible)
  const I={home:'<svg class="lucide" viewBox="0 0 24 24"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',desktop:'<svg class="lucide" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',chat:'<svg class="lucide" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',todo:'<svg class="lucide" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>',board:'<svg class="lucide" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>',calendar:'<svg class="lucide" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',workspace:'<svg class="lucide" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',projects:'<svg class="lucide" viewBox="0 0 24 24"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>',crm:'<svg class="lucide" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4c0 2-2 3-4 5-2-2-4-3-4-5a4 4 0 0 1 4-4z"/><path d="M12 2v20"/><path d="M8 10a6 6 0 0 0 8 0"/></svg>',content:'<svg class="lucide" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',leads:'<svg class="lucide" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',brain:'<svg class="lucide" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4c0 2-2 3-4 5-2-2-4-3-4-5a4 4 0 0 1 4-4z"/><path d="M12 2v20"/><path d="M8 10a6 6 0 0 0 8 0"/></svg>',inbox:'<svg class="lucide" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>',docs:'<svg class="lucide" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',skills:'<svg class="lucide" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',mindmap:'<svg class="lucide" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',scrape:'<svg class="lucide" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',vault:'<svg class="lucide" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',notif:'<svg class="lucide" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>',gallery:'<svg class="lucide" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>',studio:'<svg class="lucide" viewBox="0 0 24 24"><path d="M15.5 2H8.5C6 2 5 3 5 5.5V22c0 .55.45 1 1 1h12c.55 0 1-.45 1-1V5.5C19 3 18 2 15.5 2zM12 16c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm6-7H6V6h12v3z"/></svg>',legal:'<svg class="lucide" viewBox="0 0 24 24"><path d="M12 2L4 7v4c0 6.55 3.84 12.74 8 15 4.16-2.26 8-8.45 8-15V7l-8-5z"/><line x1="12" y1="12" x2="12" y2="20"/></svg>'}
  const groups=[{l:'Workspace',g:[['home','Home'],['workspace','Workspace'],['desktop','Desktop'],['chat','Chat']]},{l:'Productivity',g:[['todo','Todo'],['board','Board'],['calendar','Calendar'],['projects','Projects']]},{l:'Business',g:[['crm','RAGX'],['legal','Legal AI'],['content','Content'],['leads','Leads']]},{l:'Tools',g:[['brain','Deep Research'],['inbox','Inbox'],['docs','Docs'],['gallery','Gallery'],['studio','Studio']]},{l:'System',g:[['skills','Skills'],['mindmap','Mindmap'],['scrape','Scraper'],['vault','Vault']]}];
  nav.innerHTML=groups.map(g=>'<div class="nav-group">'+g.l+'</div>'+g.g.map(t=>{
    const a=activePage===t[0]?' active':'';
    return '<button class="nav-item'+a+'" onclick="navTo(\''+t[0]+'\')"><span class="nav-icon">'+(I[t[0]]||'')+'</span>'+t[1]+'</button>';
  }).join('')).join('');
  const ml=$('modelLabel');
  if(ml)ml.textContent=(models.find(m=>m.id===activeModel)||{}).name||'DeepSeek V4';
  updateNotifBadge();
}

// ─── HOME STATS ───────────────────────────────────────
function renderHomeStats(){
  const el=$('homeStats');
  if(!el)return;
  const pays=state.payments||[];
  const mrr=pays.filter(p=>p.type==='recurring'&&p.status==='paid').reduce((a,p)=>a+Number(p.amount||0),0);
  const upcoming=pays.filter(p=>p.status==='upcoming').reduce((a,p)=>a+Number(p.amount||0),0);
  const pipeline=pays.filter(p=>p.status==='pipeline').reduce((a,p)=>a+Number(p.amount||0),0);
  const todos=(state.todos||{})[todayKey()]||[];
  el.innerHTML=`
    <div class="statCard"><b>£${mrr.toLocaleString()}</b><span>MRR</span></div>
    <div class="statCard"><b>£${upcoming.toLocaleString()}</b><span>Upcoming</span></div>
    <div class="statCard"><b>£${pipeline.toLocaleString()}</b><span>Pipeline</span></div>
    <div class="statCard"><b>${(state.businesses||[]).length}</b><span>Projects</span></div>`;
  renderCheckin();
}

// ─── DAILY CHECK-IN ──────────────────────────────────
const moods=[{v:1,e:'😫',l:'Awful'},{v:2,e:'😕',l:'Meh'},{v:3,e:'😐',l:'Okay'},{v:4,e:'🙂',l:'Good'},{v:5,e:'😄',l:'Great'}];
function renderCheckin(){
  const el=$('checkinCard');if(!el)return;
  const checkins=state.metrics||{};checkins.dailyCheckin||={};
  const today=checkins.dailyCheckin[todayKey()]||{};
  const days=getLast7Days();
  // Mini mood chart
  const moodBars=days.map(d=>{const v=((checkins.dailyCheckin||{})[d]||{}).mood||0;return `<div class="miniBar mood" style="height:${v*12}px" title="${d}: ${v}/5"><span>${d.slice(5)}</span></div>`;}).join('');
  const prodBars=days.map(d=>{const v=((checkins.dailyCheckin||{})[d]||{}).productivity||0;return `<div class="miniBar prod" style="height:${v*6}px" title="${d}: ${v}/10"><span>${d.slice(5)}</span></div>`;}).join('');
  el.innerHTML=`
    <div class="checkinHeader"><b>📊 Daily Check-in</b><small>${new Date().toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short'})}</small></div>
    <div style="font-size:11px;color:var(--muted);margin-bottom:6px">Mood</div>
    <div class="moodRow">${moods.map(m=>`<button class="moodBtn ${today.mood===m.v?'sel':''}" onclick="setCheckin('mood',${m.v})" title="${m.l}">${m.e}</button>`).join('')}</div>
    <div class="scoreRow"><label style="font-size:12px;color:var(--muted)">Productivity</label>
      <input type="range" min="1" max="10" value="${today.productivity||5}" onchange="setCheckin('productivity',this.value)" oninput="$('prodScoreVal').textContent=this.value">
      <span id="prodScoreVal">${today.productivity||5}</span></div>
    <div class="hoursRow"><label>Hours worked</label>
      <input type="number" min="0" max="24" step="0.5" value="${today.hours||''}" placeholder="-" onchange="setCheckin('hours',this.value)"></div>
    <div class="chartRow">
      <div class="chartCol"><div class="label">Mood (7d)</div><div class="miniChart">${moodBars||'<span style="font-size:10px;color:var(--dim)">no data</span>'}</div></div>
      <div class="chartCol"><div class="label">Productivity (7d)</div><div class="miniChart">${prodBars||'<span style="font-size:10px;color:var(--dim)">no data</span>'}</div></div>
    </div>`;
}
function getLast7Days(){
  const days=[];const d=new Date();
  for(let i=6;i>=0;i--){const n=new Date(d);n.setDate(d.getDate()-i);if(n.getHours()<6)n.setDate(n.getDate()-1);days.push(n.getFullYear()+'-'+String(n.getMonth()+1).padStart(2,'0')+'-'+String(n.getDate()).padStart(2,'0'));}
  return days;
}
async function setCheckin(field,value){
  const s=state;const sm=s.metrics||{};sm.dailyCheckin||={};sm.dailyCheckin[todayKey()]||={};
  sm.dailyCheckin[todayKey()][field]=field==='mood'?Number(value):field==='hours'?parseFloat(value)||0:Number(value);
  await api('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field,value:sm.dailyCheckin[todayKey()][field]})});
  await load();
}

// ─── TODOS ────────────────────────────────────────────
function renderTodos(){
  const el=$('todoList');
  const bc=$('boardContainer');
  if(!el)return;
  
  // Toggle active button
  document.querySelectorAll('#tvList,#tvBoard').forEach(b=>b.classList.remove('active'));
  const btn=$(todoView==='list'?'tvList':'tvBoard');
  if(btn)btn.classList.add('active');
  
  if(todoView==='board'){
    // Show board, hide list
    el.style.display='none';
    if(bc){bc.style.display='block';renderBoardInline()}
    return;
  }
  
  // List view
  el.style.display='block';
  if(bc)bc.style.display='none';
  
  const allTodos=Object.values(state.todos||{}).flat().filter(t=>!t.done);
  allTodos.sort((a,b)=>((a.priority==='high'?-1:1)-(b.priority==='high'?-1:1)));
  el.innerHTML=allTodos.length?allTodos.map((t,i)=>`
    <div style="background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);padding:10px 12px;margin-bottom:6px;cursor:pointer;position:relative;transition:border-color .12s" onclick="openTaskMenu('${t.id}')" onmouseenter="this.querySelector('.tlActions').style.opacity='1'" onmouseleave="this.querySelector('.tlActions').style.opacity='0'">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font:700 12px var(--mono);color:var(--dim);width:24px;text-align:center">${i+1}</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:600;line-height:1.4">${esc(t.text)}</div>
          ${t.project||t.priority?`<div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:3px">${t.project?`<span class="tag">${esc(t.project)}</span>`:''}${t.priority?`<span class="tag ${t.priority}">${t.priority}</span>`:''}${t.deadline?`<span style="font:500 9px var(--mono);padding:1px 5px;border-radius:999px;border:1px solid var(--line);color:var(--muted)">📅 ${t.deadline}</span>`:''}</div>`:''}
        </div>
      </div>
      <div class="tlActions" style="position:absolute;top:8px;right:8px;display:flex;gap:2px;opacity:0;transition:opacity .12s">
        <button style="width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--green);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center" onclick="event.stopPropagation();taskDoneDirect('${t.id}')" title="Done">✅</button>
        <button style="width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--blue);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center" onclick="event.stopPropagation();taskChatDirect('${t.id}')" title="Discuss">💬</button>
        <button style="width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--amber);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center" onclick="event.stopPropagation();taskCodeDirect('${t.id}')" title="Code">⌘</button>
      </div>
    </div>`).join(''):'<div style="color:var(--dim);padding:30px 0;text-align:center;font-size:13px">No tasks. Ask the AI below to add some.</div>';
}

function renderBoardInline(){
  // Same as renderBoard but populates inline containers (already on todo page)
  renderBoard();
}
async function toggleTodo(id){
  // Search across all dates
  for(const date of Object.keys(state.todos||{})){
    const t=(state.todos[date]||[]).find(x=>x.id===id);
    if(t){
      await api('/api/todos/'+id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify({done:!t.done})});
      await load();
      return;
    }
  }
}

// ─── KANBAN BOARD ─────────────────────────────────────
function renderBoard(){
  const cols=$('boardCols');
  if(!cols)return;
  
  // Populate project filter
  const projFilter=$('boardProjectFilter');
  if(projFilter&&projFilter.options.length===1){
    (state.businesses||[]).forEach(b=>{
      const opt=document.createElement('option');
      opt.value=b.id;opt.textContent=b.name;
      projFilter.appendChild(opt);
    });
  }
  
  const projFilterVal=projFilter?projFilter.value:'__all';
  const prioFilter=$('boardPriorityFilter');
  const prioFilterVal=prioFilter?prioFilter.value:'__all';
  
  // Get all undone tasks
  let allTodos=Object.values(state.todos||{}).flat().filter(t=>!t.done);
  
  // Filter by project
  if(projFilterVal!=='__all'){
    const projName=(state.businesses||[]).find(b=>b.id===projFilterVal)?.name||'';
    allTodos=allTodos.filter(t=>t.businessId===projFilterVal||t.project===projName||t.project===projFilterVal);
  }
  
  // Filter by priority
  if(prioFilterVal!=='__all'){
    allTodos=allTodos.filter(t=>t.priority===prioFilterVal);
  }
  
  // Group by project
  const grouped={};
  const projectNames={};
  (state.businesses||[]).forEach(b=>{projectNames[b.id]=b.name});
  
  // 'Unassigned' bucket
  grouped['__unassigned']=[];
  // 'Other' bucket
  grouped['__other']=[];
  
  allTodos.forEach(t=>{
    const bizId=t.businessId||'';
    const proj=t.project||'';
    if(bizId&&grouped[bizId]===undefined) grouped[bizId]=[];
    if(!bizId&&proj) {
      // Match project by name
      const matched=Object.entries(projectNames).find(([,n])=>n===proj);
      if(matched){if(grouped[matched[0]]===undefined)grouped[matched[0]]=[];grouped[matched[0]].push(t);}
      else grouped['__other'].push(t);
    } else if(bizId) {
      grouped[bizId].push(t);
    } else {
      grouped['__unassigned'].push(t);
    }
  });
  
  // Sort within each group by priority
  Object.values(grouped).forEach(arr=>arr.sort((a,b)=>(a.priority==='high'?-1:0)-(b.priority==='high'?-1:0)));
  
  // Build board columns sorted by business order
  const bizOrder=(state.businesses||[]).map(b=>b.id);
  const colOrder=['__unassigned',...bizOrder,'__other'].filter(k=>grouped[k]&&grouped[k].length>0);
  
  const projectIcons={syneticx:'🧬',waterspring:'🌊',unitas:'🤝','imam-connect':'🕌',concordia:'🏛️',rema:'🏠','rema-exteriors':'🏠',ragx:'📧',lamatrader:'📈','ragmedium-b2b':'🎯','content-empire':'📣'};
  
  cols.innerHTML=colOrder.map(colId=>{
    const tasks=grouped[colId]||[];
    let colTitle, colIcon='📋';
    if(colId==='__unassigned'){colTitle='Unassigned';colIcon='📥'}
    else if(colId==='__other'){colTitle='Other';colIcon='📦'}
    else{colTitle=projectNames[colId]||colId;colIcon=projectIcons[colId]||'📋'}
    
    return '<div class="boardCol">'+
      '<div class="boardColHead">'+colIcon+'&nbsp;'+esc(colTitle)+' <span class="count">'+tasks.length+'</span></div>'+
      '<div class="boardColBody">'+
      tasks.map(t=>{
        const prio=t.priority||'medium';
        const src=t.source||'';
        const dateStr=t.createdAt?t.createdAt.slice(0,10):'';
        const tid=t.id;
        return '<div class="boardCard" onclick="openTaskMenu(\''+tid+'\')">'+
          '<div class="bcTitle">'+esc(t.text)+'</div>'+
          '<div class="bcMeta">'+
            '<span class="bcTag '+prio+'">● '+prio+'</span>'+
            (t.minutes?'<span class="bcTag">⏱ '+t.minutes+'m</span>':'')+
            (dateStr?'<span class="bcTag">📅 '+dateStr+'</span>':'')+
          '</div>'+
          '<div class="bcActions">'+
            '<button class="bcDoneBtn" onclick="event.stopPropagation();taskDoneDirect(\''+tid+'\')" title="Done">✅</button>'+
            '<button class="bcChatBtn" onclick="event.stopPropagation();taskChatDirect(\''+tid+'\')" title="Discuss">💬</button>'+
            '<button class="bcCodeBtn" onclick="event.stopPropagation();taskCodeDirect(\''+tid+'\')" title="Code">⌘</button>'+
          '</div>'+
        '</div>';
      }).join('')+
      (!tasks.length?'<div class="boardEmpty">No tasks</div>':'')+
      '</div></div>';
  }).join('');
  
  // Hide empty columns
  if(!colOrder.length) cols.innerHTML='<div style="color:var(--dim);padding:40px;text-align:center;width:100%;font-size:14px">✨ No undone tasks to show. Ask the AI below to add some.</div>';
}

// ─── TASK ACTION MENU ────────────────────────────────
let _activeTaskId=null;
function findTask(id){
  for(const date of Object.keys(state.todos||{})){
    const t=(state.todos[date]||[]).find(x=>x.id===id);
    if(t) return t;
  }
  return null;
}
function openTaskMenu(id){
  _activeTaskId=id;
  _editOpen=false;
  const t=findTask(id);
  if(!t)return;
  const overlay=$('taskOverlay');
  const title=$('tpTitle');
  const meta=$('tpMeta');
  const desc=$('tpDesc');
  const descEdit=$('tpDescEdit');
  const editBtn=$('tpEditBtn');
  const saveBtn=$('tpSaveDesc');
  if(!overlay||!title||!meta||!desc)return;
  title.textContent=t.text;
  const proj=t.project||t.businessId||'Unassigned';
  const prio=t.priority||'medium';
  const mins=t.minutes?' · ⏱ '+t.minutes+'m':'';
  const date=t.createdAt?t.createdAt.slice(0,10):'';
  meta.textContent=proj+' · '+prio+mins+(date?' · 📅 '+date:'');
  
  // Show description
  const hasDesc=t.description&&t.description.trim();
  desc.textContent=hasDesc?t.description:'No description yet. Click Edit to add notes, context, or steps.';
  desc.className='tpDesc'+(hasDesc?'':' empty');
  desc.style.display='block';
  if(descEdit){descEdit.value=t.description||'';descEdit.classList.remove('open')}
  if(editBtn)editBtn.textContent='✏️ Edit';
  if(saveBtn)saveBtn.style.display='none';
  
  overlay.classList.add('open');
}
let _editOpen=false;
function toggleDescEdit(){
  _editOpen=!_editOpen;
  const desc=$('tpDesc');
  const edit=$('tpDescEdit');
  const btn=$('tpEditBtn');
  const save=$('tpSaveDesc');
  if(!desc||!edit||!btn)return;
  desc.style.display=_editOpen?'none':'block';
  edit.classList.toggle('open',_editOpen);
  btn.textContent=_editOpen?'🔍 Preview':'✏️ Edit';
  if(save)save.style.display=_editOpen?'block':'none';
}
async function saveTaskDesc(){
  const id=_activeTaskId;
  const edit=$('tpDescEdit');
  if(!id||!edit)return;
  const desc=edit.value.trim();
  await api('/api/todos/'+id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify({description:desc})});
  await load();
  toggleDescEdit();
  const t=findTask(id);
  const descEl=$('tpDesc');
  if(t&&descEl){
    descEl.textContent=desc||'No description yet. Click Edit to add notes, context, or steps.';
    descEl.className='tpDesc'+(desc?'':' empty');
  }
}
function closeTaskMenu(e){
  if(e&&e.target!==e.currentTarget)return;
  const overlay=$('taskOverlay');
  if(overlay)overlay.classList.remove('open');
  _activeTaskId=null;
  _editOpen=false;
}
async function taskDone(){
  const id=_activeTaskId;
  closeTaskMenu();
  if(!id)return;
  await toggleTodo(id);
  await load();
}
function buildTaskPrompt(t){
  let parts=[t.text];
  if(t.description) parts.push('\n\nDescription: '+t.description);
  if(t.project) parts.push('\nProject: '+t.project);
  if(t.priority) parts.push('\nPriority: '+t.priority);
  if(t.deadline) parts.push('\nDeadline: '+t.deadline);
  if(t.minutes) parts.push('\nEst. time: '+t.minutes+' min');
  return parts.join('');
}

async function taskChat(){
  const id=_activeTaskId;
  closeTaskMenu();
  const t=findTask(id);
  if(!t)return;
  const input=$('chatInput');
  if(input){input.value=buildTaskPrompt(t);input.focus();input.dispatchEvent(new Event('input'));input.setSelectionRange(0,t.text.length)}
  navTo('chat');
}
async function taskCode(){
  const id=_activeTaskId;
  closeTaskMenu();
  const t=findTask(id);
  if(!t)return;
  const prompt=buildTaskPrompt(t);
  navTo('workspace');
  // The OpenCode iframe loads separately; user can type prompt there
}

// Direct hover button actions
async function taskDoneDirect(id){
  await toggleTodo(id);
  await load();
}
async function taskChatDirect(id){
  const t=findTask(id);
  if(!t)return;
  const input=$('chatInput');
  if(input){input.value=buildTaskPrompt(t);input.focus();input.dispatchEvent(new Event('input'));input.setSelectionRange(0,t.text.length)}
  navTo('chat');
}
async function taskCodeDirect(id){
  const t=findTask(id);
  if(!t)return;
  const prompt=buildTaskPrompt(t);
  navTo('workspace');
}

// ─── PROJECTS ─────────────────────────────────────────
var projView='list';

function renderProjects(){
  const wrap=$('projectsWrap');
  if(!wrap)return;
  const biz=state.businesses||[];
  if(!biz.length){wrap.innerHTML='<div class="softNote" style="padding:20px;text-align:center;color:var(--dim)">No projects yet.</div>';return}
  if(projView==='list'){
    wrap.innerHTML=`<div class="projects">${biz.map(p=>`
      <div class="project" onclick="projectDetailId='${p.id}';navTo('project-detail')">
        <h3>${esc(p.name)}</h3>
        <div class="lane">${esc(p.lane||'')}${p.health?` · ${p.health}`:''}</div>
        <div class="desc">${esc(clip(p.description||'',90))}</div>
      </div>`).join('')}</div>`;
  } else {
    const pays=state.payments||[];
    const mrr=pays.filter(p=>p.type==='recurring'&&p.status==='paid').reduce((a,p)=>a+Number(p.amount||0),0);
    const paid30d=pays.filter(p=>p.status==='paid'&&p.date&&p.date>=todayKey(new Date(Date.now()-30*86400000))).reduce((a,p)=>a+Number(p.amount||0),0);
    const paidTotal=pays.filter(p=>p.status==='paid').reduce((a,p)=>a+Number(p.amount||0),0);
    const upcoming=pays.filter(p=>p.status==='upcoming').reduce((a,p)=>a+Number(p.amount||0),0);
    const pipeline=pays.filter(p=>p.status==='pipeline').reduce((a,p)=>a+Number(p.amount||0),0);
    
    // Monthly chart data
    const months={};const now=new Date();
    for(let i=5;i>=0;i--){const d=new Date(now.getFullYear(),now.getMonth()-i,1);const k=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');months[k]={paid:0,upcoming:0}}
    pays.forEach(p=>{if(!p.date)return;const k=p.date.slice(0,7);if(months[k]){if(p.status==='paid')months[k].paid+=Number(p.amount||0);else if(p.status==='upcoming')months[k].upcoming+=Number(p.amount||0)}});
    const sortedM=Object.entries(months);const max=Math.max(...sortedM.flatMap(([,v])=>[v.paid,v.upcoming]),1);
    
    const perProject=biz.map(b=>{
      const pp=pays.filter(p=>p.projectId===b.id);
      return{name:b.name,id:b.id,paid:pp.filter(p=>p.status==='paid').reduce((a,p)=>a+Number(p.amount||0),0),upcoming:pp.filter(p=>p.status==='upcoming').reduce((a,p)=>a+Number(p.amount||0),0),pipeline:pp.filter(p=>p.status==='pipeline').reduce((a,p)=>a+Number(p.amount||0),0),mrr:pp.filter(p=>p.type==='recurring'&&p.status==='paid').reduce((a,p)=>a+Number(p.amount||0),0)};
    }).filter(p=>p.paid||p.upcoming||p.pipeline||p.mrr);
    
    wrap.innerHTML=`
      <div class="revRow"><div class="revStat"><b>£${mrr.toLocaleString()}</b><span>MRR</span></div><div class="revStat" style="border-color:var(--green)"><b style="color:var(--green)">£${paid30d.toLocaleString()}</b><span>Paid 30d</span></div><div class="revStat" style="border-color:var(--amber)"><b style="color:var(--amber)">£${upcoming.toLocaleString()}</b><span>Upcoming</span></div></div>
      <div class="revRow"><div class="revStat" style="border-color:var(--blue)"><b>£${paidTotal.toLocaleString()}</b><span>Total Paid</span></div><div class="revStat" style="border-color:var(--red)"><b style="color:var(--red)">£${pipeline.toLocaleString()}</b><span>Pipeline</span></div><div class="revStat"><b>${pays.length}</b><span>Payments</span></div></div>
      
      <div style="background:var(--card);border-radius:var(--radius-lg);padding:14px;border:1px solid var(--line);margin-bottom:12px">
        <h3 style="font-size:13px;margin-bottom:10px;color:var(--muted)">6-Month Revenue</h3>
        <div class="barChart" style="height:120px">${sortedM.map(([k,v])=>`
          <div class="barWrap" style="position:relative">
            <div class="bar" style="height:${Math.max(v.paid/max*100,2)}%;background:var(--green);position:absolute;bottom:16px;width:35%;left:15%"></div>
            <div class="bar" style="height:${Math.max(v.upcoming/max*100,2)}%;background:var(--amber);position:absolute;bottom:16px;width:35%;right:15%"></div>
            <div class="barLabel" style="margin-top:auto">${k.slice(5)}</div>
          </div>`).join('')}</div>
        <div style="display:flex;gap:16px;font-size:11px;color:var(--muted);margin-top:8px"><span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:var(--green);border-radius:2px;display:inline-block"></span>Paid</span><span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:var(--amber);border-radius:2px;display:inline-block"></span>Upcoming</span></div>
      </div>
      
      <div><h3 style="font-size:14px;margin-bottom:8px">Per Project</h3></div>
      ${perProject.length?perProject.map(p=>`
        <div class="card" style="padding:12px;margin-bottom:6px;cursor:pointer" onclick="showProjectPayments(''+p.id+'')" title="Click to view/edit payments">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <b>${esc(p.name)}</b>
            <span style="font-size:11px;color:var(--muted)">MRR: £${p.mrr.toLocaleString()}</span>
          </div>
          <div style="display:flex;gap:10px;margin-top:6px;font-size:12px">
            <span style="color:var(--green)">Paid: £${p.paid.toLocaleString()}</span>
            <span style="color:var(--amber)">Upcoming: £${p.upcoming.toLocaleString()}</span>
            <span style="color:var(--red)">Pipeline: £${p.pipeline.toLocaleString()}</span>
          </div>
        </div>`).join(''):'<div class="softNote" style="color:var(--dim);padding:10px;font-size:12px">No payments recorded yet.</div>'}
      <button class="btn alt" onclick="addPayment()" style="margin-top:8px;width:100%">+ Add Payment</button>`;
  }
  document.querySelectorAll('#pvList,#pvStats').forEach(b=>b.classList.remove('active'));
  const btn=$(projView==='list'?'pvList':'pvStats');
  if(btn)btn.classList.add('active');
}
var projectDetailId=null;
function renderProjectDetail(){
  const wrap=$('pdWrap');
  if(!wrap)return;
  const p=(state.businesses||[]).find(x=>x.id===projectDetailId);
  if(!p){navTo('projects');return}
  const pays=(state.payments||[]).filter(pay=>pay.projectId===projectDetailId);
  const mrr=pays.filter(pay=>pay.type==='recurring'&&pay.status==='paid').reduce((a,pay)=>a+Number(pay.amount||0),0);
  const paidTotal=pays.filter(p=>p.status==='paid').reduce((a,p)=>a+Number(p.amount||0),0);
  const upcoming=pays.filter(p=>p.status==='upcoming').reduce((a,p)=>a+Number(p.amount||0),0);
  const pipeline=pays.filter(p=>p.status==='pipeline').reduce((a,p)=>a+Number(p.amount||0),0);
  const todos=(state.todos||{})[todayKey()]||[];
  const ptodos=todos.filter(t=>t.project===p.name);
  wrap.innerHTML=`
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:start">
        <div><h2 style="margin:0 0 4px">${esc(p.name)}</h2><div style="font-size:12px;color:var(--muted)">${esc(p.lane||'')}${p.priority?` · priority: ${p.priority}`:''}${p.health?` · health: ${p.health}`:''}</div></div>
        <button class="btn ghost" onclick="navTo('projects')">← Back</button>
      </div>
      <p style="font-size:13px;color:var(--muted);margin-top:8px">${esc(p.description||'')}</p>
      ${p.tags?`<div style="margin-top:6px;display:flex;gap:4px;flex-wrap:wrap">${p.tags.map(t=>`<span class="tag">${esc(t)}</span>`).join('')}</div>`:''}
    </div>
    <div class="revRow"><div class="revStat"><b>£${mrr.toLocaleString()}</b><span>MRR</span></div><div class="revStat" style="border-color:var(--green)"><b style="color:var(--green)">£${paidTotal.toLocaleString()}</b><span>Paid</span></div><div class="revStat" style="border-color:var(--amber)"><b style="color:var(--amber)">£${upcoming.toLocaleString()}</b><span>Upcoming</span></div></div>
    <div class="revRow"><div class="revStat" style="border-color:var(--red)"><b style="color:var(--red)">£${pipeline.toLocaleString()}</b><span>Pipeline</span></div><div class="revStat"><b>${pays.length}</b><span>Payments</span></div><div class="revStat"><b>£${(paidTotal+upcoming+pipeline).toLocaleString()}</b><span>Total Value</span></div></div>
    ${pays.length?`<div class="card"><div class="barChart" style="height:100px">${(()=>{const months={};pays.forEach(pay=>{if(!pay.date)return;const k=pay.date.slice(0,7);months[k]=(months[k]||0)+Number(pay.amount||0)});const sorted=Object.entries(months).sort().slice(-6);const max=Math.max(...sorted.map(([,v])=>v),1);return sorted.map(([k,v])=>`<div class="barWrap"><div class="bar" style="height:${Math.max(v/max*100,4)}%;background:var(--green)"></div><div class="barLabel">${k.slice(2)}</div></div>`).join('')})()}</div><div style="font-size:10px;color:var(--dim);text-align:center;margin-top:4px">Monthly paid revenue</div></div>`:''}
    <div class="card"><div style="display:grid;gap:6px">${ptodos.length?ptodos.map(t=>`<div style="background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);padding:10px 12px;cursor:pointer;position:relative;transition:border-color .12s" onclick="openTaskMenu('${t.id}')" onmouseenter="this.querySelector('.pdActions').style.opacity='1'" onmouseleave="this.querySelector('.pdActions').style.opacity='0'"><div style="font-size:12px;font-weight:600;line-height:1.4">${esc(t.text)}</div>${t.description?`<div style="font-size:10px;color:var(--muted);margin-top:3px;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden">${esc(clip(t.description,80))}</div>`:''}<div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:4px">${t.priority?`<span style="font:500 9px var(--mono);padding:1px 5px;border-radius:999px;border:1px solid var(--line);color:${t.priority==='high'?'var(--red)':t.priority==='medium'?'var(--amber)':'var(--dim)'}">● ${t.priority}</span>`:''}${t.minutes?`<span style="font:500 9px var(--mono);padding:1px 5px;border-radius:999px;border:1px solid var(--line);color:var(--muted)">⏱ ${t.minutes}m</span>`:''}${t.deadline?`<span style="font:500 9px var(--mono);padding:1px 5px;border-radius:999px;border:1px solid var(--line);color:var(--muted)">📅 ${t.deadline}</span>`:''}</div><div class="pdActions" style="position:absolute;top:6px;right:6px;display:flex;gap:2px;opacity:0;transition:opacity .12s"><button style="width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--green);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center" onclick="event.stopPropagation();taskDoneDirect('${t.id}')" title="Done">✅</button><button style="width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--blue);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center" onclick="event.stopPropagation();taskChatDirect('${t.id}')" title="Discuss">💬</button><button style="width:22px;height:22px;border-radius:6px;border:1px solid var(--line);background:var(--card);color:var(--amber);font-size:10px;padding:0;cursor:pointer;display:grid;place-items:center" onclick="event.stopPropagation();taskCodeDirect('${t.id}')" title="Code">⌘</button></div></div>`).join(''):'<div style="color:var(--dim);font-size:12px;text-align:center;padding:10px">No tasks for this project.</div>'}</div></div>
    <button class="btn alt" onclick="addPayment()" style="width:100%">+ Add Payment</button>`;
}

async function addPayment(){
  const amount=prompt('Amount (£)?');if(!amount||isNaN(parseFloat(amount)))return;
  const status=prompt('Status: paid / upcoming / pipeline?')||'paid';
  if(!['paid','upcoming','pipeline'].includes(status)){alert('Use: paid, upcoming, or pipeline');return}
  const type=status==='paid'?(confirm('Recurring (OK) or one-time (Cancel)?')?'recurring':'nonrecurring'):'nonrecurring';
  const desc=prompt('Description?')||'';
  const pid=projectDetailId||prompt('Project ID?')||'';
  const date=status==='paid'?todayKey():(prompt('Expected date (YYYY-MM-DD)?')||todayKey());
  await api('/api/payments',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({projectId:pid,amount:parseFloat(amount),type,status,description:desc,date})});
  await load();
}

// ─── SCHEDULE / TIMETABLE ─────────────────────────────
function renderTimetableConfig(){
  // Try calendar page container first, fall back to schedule page container
  let el=$('ttConfig')||$('timetableConfig');
  if(!el)return;
  const cfg=state.brain?.timetable||{};
  el.innerHTML=`
    <div class="card" style="padding:12px">
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <label style="font-size:11px">Start <input type="time" id="ttStart" value="${cfg.workStart||'08:00'}" class="input" style="width:auto;padding:4px 8px;font-size:12px"></label>
        <label style="font-size:11px">End <input type="time" id="ttEnd" value="${cfg.workEnd||'18:00'}" class="input" style="width:auto;padding:4px 8px;font-size:12px"></label>
        <label style="font-size:11px">Buffer <input type="number" id="ttBuf" value="${cfg.bufferMinutes||10}" class="input" style="width:50px;padding:4px 8px;font-size:12px"></label>
        <label style="font-size:11px">Max <input type="number" id="ttMax" value="${cfg.maxBlockMinutes||90}" class="input" style="width:50px;padding:4px 8px;font-size:12px"></label>
        <button class="btn" style="padding:4px 12px;font-size:11px" onclick="saveTtConfig()">Save config</button>
      </div>
    </div>`;
}
async function saveTtConfig(){
  const cfg={workStart:$('ttStart')?.value||'08:00',workEnd:$('ttEnd')?.value||'18:00',bufferMinutes:parseInt($('ttBuf')?.value)||10,maxBlockMinutes:parseInt($('ttMax')?.value)||90};
  await api('/api/timetable/config',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(cfg)});
  await load();
  generateTimetable();
}
function renderTimetable(t){
  const tl=$('timeline');
  if(!tl||!t)return;
  const cfg=t.config||{};
  const ws=parseTime(cfg.workStart||'08:00'),we=parseTime(cfg.workEnd||'18:00');
  const total=we-ws;const ppm=Math.max(1,400/Math.max(total,60));
  tl.style.height=(total*ppm)+'px';
  let html='';
  for(let m=ws;m<=we;m+=60){const h=Math.floor(m/60);html+=`<div class="timelineHour" style="top:${(m-ws)*ppm}px">${String(h).padStart(2,'0')}:00</div><div class="timelineLine" style="top:${(m-ws)*ppm}px"></div>`}
  (t.meetings||[]).forEach(e=>{const s=Math.max(parseTime(e.startTime),ws),en=Math.min(parseTime(e.endTime),we);if(en<=s)return;const top=(s-ws)*ppm;const h=Math.max(22,(en-s)*ppm);html+=`<div class="timetableBlock meeting" style="top:${top}px;height:${h}px"><div class="tbTitle">📅 ${esc(e.title||'')}</div><div class="tbTime">${e.startTime}–${e.endTime}</div></div>`});
  (t.scheduled||[]).forEach(s2=>{const s=Math.max(parseTime(s2.startTime),ws),en=Math.min(parseTime(s2.endTime),we);if(en<=s)return;const top=(s-ws)*ppm;const h=Math.max(20,(en-s)*ppm);html+=`<div class="timetableBlock task ${s2.priority||'medium'}" style="top:${top}px;height:${h}px"><div class="tbTitle">${esc(s2.text||'')}</div><div class="tbTime">${s2.startTime}–${s2.endTime}${s2.project?' · '+esc(s2.project):''}</div></div>`});
  tl.innerHTML=html;
}
function parseTime(s){if(!s)return 0;const p=s.split(':');return parseInt(p[0])*60+(parseInt(p[1])||0)}
async function generateTimetable(){
  const tl=$('timeline');
  if(tl)tl.innerHTML='<div style="padding:20px;color:var(--dim);font-size:12px">Scheduling…</div>';
  try{
    const res=await api('/api/timetable?date='+todayKey());
    renderTimetable(res.timetable);
  }catch(e){
    if(tl)tl.innerHTML='<div style="padding:20px;color:var(--red);font-size:12px">Failed: '+e.message+'</div>';
  }
}

// ─── CALENDAR + SCHEDULE (MERGED) ─────────────────────
function renderCalendar(){
  const grid=$('calGrid'),ml=$('calMonth');
  if(!grid)return;
  const y=calCursor.getFullYear(),m=calCursor.getMonth();
  const first=new Date(y,m,1).getDay()||7;const days=new Date(y,m+1,0).getDate();
  const today=todayKey();const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  if(ml)ml.textContent=months[m]+' '+y;
  
  // Default selected date to today
  if(!selectedDate||!selectedDate.startsWith(y+'-')) selectedDate=today;
  
  // Calendar events + tasks with deadlines
  const calEvents=state.brain?.calendar||[];
  const allTodos=Object.values(state.todos||{}).flat();
  
  function dayData(ds){
    const dayEvents=calEvents.filter(e=>e.start&&e.start.startsWith(ds));
    const dayTodos=allTodos.filter(t=>t.deadline===ds).filter(t=>!t.done);
    const todoCount=dayTodos.length;
    const urgentCount=dayTodos.filter(t=>t.priority==='high').length;
    return {events:dayEvents,todos:dayTodos,count:todoCount,urgent:urgentCount};
  }
  
  let totalDl=0, urgentDl=0;
  
  let html='';
  ['M','T','W','T','F','S','S'].forEach(d=>{html+=`<div style="font-size:9px;color:var(--dim);text-align:center;font-weight:700;padding:1px 0">${d}</div>`});
  
  for(let i=1-first+1;i<=days;i++){
    if(i<1){html+=`<div class="calDay other"></div>`;continue}
    const ds=y+'-'+String(m+1).padStart(2,'0')+'-'+String(i).padStart(2,'0');
    const info=dayData(ds);
    
    // Build mini previews
    let preview='';
    const previewItems=[];
    info.events.slice(0,2).forEach(e=>{previewItems.push('<span class="cpItem cpEvent">📅 '+esc(clip(e.title,28))+'</span>')});
    info.todos.slice(0,2).forEach(t=>{
      const cls=t.priority==='high'?'cpUrgent':'cpDeadline';
      previewItems.push('<span class="cpItem '+cls+'">⏰ '+esc(clip(t.text,25))+'</span>');
    });
    if(info.count>2||info.events.length+info.count>2){
      const more=info.count+info.events.length-2;
      previewItems.push('<span class="cpItem" style="color:var(--dim)">+'+more+' more</span>');
    }
    if(previewItems.length) preview='<div class="calPreview">'+previewItems.join('')+'</div>';
    
    const isToday=ds===today;
    const isSel=ds===selectedDate;
    html+=`<div class="calDay${isToday?' today':''}${isSel?' selected':''}" onclick="selectDay('${ds}')">`+
      `<span class="calNum">${i}</span>`+
      preview+
    `</div>`;
    
    if(info.count||info.events.length){totalDl+=info.count;urgentDl+=info.urgent}
  }
  grid.innerHTML=html;
  
  // Deadline total
  const dc=$('calDeadlineCount');
  if(dc) dc.textContent=urgentDl+' urgent · '+totalDl+' deadlines';
  
  // Sync status
  const syncStatus=$('calSyncStatus');
  if(syncStatus){
    const lastSync=state.brain?.sync?.lastCalendarSync;
    if(lastSync) syncStatus.textContent='☁️ GCal synced '+lastSync.slice(0,16).replace('T',' ');
    else syncStatus.textContent='⏳ GCal not connected';
  }
  
  // Schedule config
  renderTimetableConfig();
  
  // Generate timetable for selected date
  generateTimetableForDate(selectedDate);
  
  // Render day view
  renderDayView(selectedDate);
}

function selectDay(ds){
  selectedDate=ds;
  renderCalendar();
}

function renderDayView(ds){
  const el=$('dvContent');
  const title=$('dvTitle');
  const label=$('dvLabel');
  if(!el)return;
  
  const calEvents=state.brain?.calendar||[];
  const allTodos=Object.values(state.todos||{}).flat();
  const dayEvents=calEvents.filter(e=>e.start&&e.start.startsWith(ds));
  const dayTodos=allTodos.filter(t=>t.deadline===ds).filter(t=>!t.done);
  
  const today=todayKey();
  const daysUntil=Math.ceil((new Date(ds)-new Date(today))/(86400000));
  
  let titleText='', labelText='';
  const d=new Date(ds+'T12:00:00');
  const dayNames=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const monthNames=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  
  if(ds===today){titleText='Today';labelText=dayNames[d.getDay()]+', '+d.getDate()+' '+monthNames[d.getMonth()]}
  else if(daysUntil===1){titleText='Tomorrow';labelText=dayNames[d.getDay()]+', '+d.getDate()+' '+monthNames[d.getMonth()]}
  else if(daysUntil===2){titleText='Day after tomorrow';labelText=dayNames[d.getDay()]+', '+d.getDate()+' '+monthNames[d.getMonth()]}
  else if(daysUntil<0){titleText=Math.abs(daysUntil)+' days ago';labelText=dayNames[d.getDay()]+', '+d.getDate()+' '+monthNames[d.getMonth()]}
  else{titleText='In '+daysUntil+' days';labelText=dayNames[d.getDay()]+', '+d.getDate()+' '+monthNames[d.getMonth()]}
  
  if(title) title.textContent=titleText;
  if(label) label.textContent=labelText;
  
  let html='';
  
  // Calendar events
  if(dayEvents.length){
    html+=`<div class="daySection"><h4>📅 Calendar Events <span class="dsCount">${dayEvents.length}</span></h4>`+
      dayEvents.map(e=>`<div class="eventRow"><div class="edl"><span class="eTime">${e.time||e.start?.slice(11,16)||'all day'}</span><span class="eText">${esc(e.title||'Event')}</span></div></div>`).join('')+
    `</div>`;
  }
  
  // Deadline tasks
  if(dayTodos.length){
    html+=`<div class="daySection"><h4>⏰ Task Deadlines <span class="dsCount">${dayTodos.length}</span></h4>`+
      dayTodos.map(t=>{
        const prio=t.priority||'medium';
        const proj=t.project||'';
        const urg=prio==='high'&&(daysUntil<=1);
        return `<div class="eventRow" onclick="openTaskMenu('${t.id}')"><div class="edl">`+
          `<span class="eTag ${prio}">● ${prio}</span>`+
          `<span class="eText ${urg?'deadlineUrgent':prio==='high'?'deadlineSoon':''}">${esc(t.text)}</span>`+
          (proj?`<span class="eProj">${esc(proj)}</span>`:'')+
        `</div></div>`;
      }).join('')+
    `</div>`;
  }
  
  // Done tasks on this day
  const dayDone=allTodos.filter(t=>t.deadline===ds&&t.done);
  if(dayDone.length){
    html+=`<div class="daySection"><h4>✅ Completed <span class="dsCount">${dayDone.length}</span></h4>`+
      dayDone.map(t=>`<div class="eventRow" style="opacity:0.5"><div class="edl"><span class="eText" style="text-decoration:line-through">${esc(t.text)}</span></div></div>`).join('')+
    `</div>`;
  }
  
  if(!html){
    const isWeekend=[0,6].includes(d.getDay());
    html=`<div style="padding:20px 0;text-align:center;color:var(--dim);font-size:13px">${isWeekend?'🟢 Clear weekend':'✨ Nothing scheduled'}</div>`;
  }
  
  el.innerHTML=html;
}

function moveDay(d){
  const dt=new Date(selectedDate+'T12:00:00');
  dt.setDate(dt.getDate()+d);
  const ny=dt.getFullYear(), nm=String(dt.getMonth()+1).padStart(2,'0'), nd=String(dt.getDate()).padStart(2,'0');
  selectedDate=ny+'-'+nm+'-'+nd;
  calCursor.setMonth(dt.getMonth());
  calCursor.setFullYear(dt.getFullYear());
  renderCalendar();
}

function moveCal(d){calCursor.setMonth(calCursor.getMonth()+d);renderCalendar()}

async function generateTimetableForDate(dateStr){
  const tl=$('timeline');
  if(!tl)return;
  tl.innerHTML='<div style="padding:20px;color:var(--dim);font-size:12px;text-align:center">⏳ Generating schedule…</div>';
  try{
    const res=await api('/api/timetable?date='+dateStr);
    renderTimetableForDate(res.timetable);
  }catch(e){
    tl.innerHTML='<div style="padding:20px;color:var(--red);font-size:12px;text-align:center">'+esc(e.message)+'</div>';
  }
}

function renderTimetableForDate(t){
  const tl=$('timeline');
  if(!tl||!t)return;
  const cfg=t.config||{};
  const ws=parseTime(cfg.workStart||'08:00'),we=parseTime(cfg.workEnd||'18:00');
  const total=we-ws;const ppm=Math.max(1,200/Math.max(total,60));
  tl.style.height=(total*ppm)+'px';
  tl.style.position='relative';
  
  // Check if weekend or nothing scheduled
  const meetings=t.meetings||[];
  const scheduled=t.scheduled||[];
  if(!meetings.length&&!scheduled.length){
    tl.innerHTML='<div style="padding:20px;color:var(--dim);font-size:12px;text-align:center">🟢 Free day — no meetings or tasks scheduled</div>';
    tl.style.height='auto';
    return;
  }
  
  let html='';
  for(let m=ws;m<=we;m+=60){
    const h=Math.floor(m/60);
    html+=`<div style="position:absolute;top:${(m-ws)*ppm}px;left:0;font-size:9px;color:var(--dim);width:32px">${String(h).padStart(2,'0')}:00</div>`;
    html+=`<div style="position:absolute;top:${(m-ws)*ppm}px;left:36px;right:0;border-top:1px solid var(--line)"></div>`;
  }
  
  meetings.forEach(e=>{
    const s=Math.max(parseTime(e.startTime),ws),en=Math.min(parseTime(e.endTime),we);
    if(en<=s)return;
    const top=(s-ws)*ppm;
    const h=Math.max(22,(en-s)*ppm);
    html+=`<div style="position:absolute;top:${top}px;left:38px;right:4px;border-radius:6px;padding:3px 6px;overflow:hidden;font-size:10px;height:${h}px;background:color-mix(in srgb,var(--blue)15%,var(--card));border:1px solid color-mix(in srgb,var(--blue)30%,var(--line))">`+
      `<div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">📅 ${esc(e.title||'')}</div>`+
      `<div style="font-size:9px;color:var(--muted)">${e.startTime}–${e.endTime}</div></div>`;
  });
  
  scheduled.forEach(s2=>{
    const s=Math.max(parseTime(s2.startTime),ws),en=Math.min(parseTime(s2.endTime),we);
    if(en<=s)return;
    const top=(s-ws)*ppm;
    const h=Math.max(18,(en-s)*ppm);
    html+=`<div style="position:absolute;top:${top}px;left:38px;right:4px;border-radius:6px;padding:3px 6px;overflow:hidden;font-size:10px;height:${h}px;background:color-mix(in srgb,var(--green)10%,var(--card));border:1px solid color-mix(in srgb,var(--green)20%,var(--line))">`+
      `<div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(s2.text||'')}</div>`+
      `<div style="font-size:9px;color:var(--muted)">${s2.startTime}–${s2.endTime}${s2.project?' · '+esc(s2.project):''}</div></div>`;
  });
  
  tl.innerHTML=html;
}

// ─── CHAT ─────────────────────────────────────────────
function renderChat(){
  renderChatHist();
  // Desktop: show history by default with collapse button
  const hp=$('historyPane');
  if(hp&&window.innerWidth>=768) hp.classList.add('open');
  const c=currentThread();
  const msgs=c.messages||[];
  const ml=$('msgList');
  if(!ml)return;
  // Update chatWrap class based on whether there are messages
  const chatWrap=ml.closest('.chatWrap');
  if(chatWrap){
    const hasMsgs=msgs.filter(m=>m.role!=='system').length>0;
    chatWrap.classList.toggle('has-messages',hasMsgs);
  }
  ml.innerHTML=msgs.filter(m=>m.role!=='system').map(m=>{
    let body=esc(m.text||'');
    // Render media attachments (images/files)
    let mediaHtml = '';
    if(m.media && Array.isArray(m.media)){
      for(const med of m.media){
        if(med.type && med.type.startsWith('image/')){
          mediaHtml += `<div style="margin-top:6px"><img src="${esc(med.url)}" style="max-width:280px;max-height:200px;border-radius:8px;cursor:pointer" onclick="window.open('${esc(med.url)}','_blank')" loading="lazy"></div>`;
        } else {
          mediaHtml += `<div style="margin-top:4px"><a href="${esc(med.url)}" target="_blank" style="display:inline-flex;align-items:center;gap:6px;padding:6px 10px;background:var(--bg);border-radius:8px;font-size:12px;color:var(--blue);text-decoration:none">📄 ${esc(med.name||'File')}</a></div>`;
        }
      }
    }
    // Also detect image URLs in text for backward compat
    if(!mediaHtml){
      const imgMatch = body.match(/\[Images:\s*([^\]]+)\]/);
      if(imgMatch){
        const urls = imgMatch[1].split(',').map(u=>u.trim());
        mediaHtml = urls.map(u=>`<div style="margin-top:6px"><img src="${esc(u)}" style="max-width:280px;max-height:200px;border-radius:8px;cursor:pointer" onclick="window.open('${esc(u)}','_blank')" loading="lazy"></div>`).join('');
        body = body.replace(/\[Images:[^\]]+\]\n?/g, '');
      }
    }
    const ts=m.at?new Date(m.at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
    return `<div class="msg ${m.role==='user'?'user':''}"><div class="bubble">${body.replace(/\n/g,'<br>').replace(/\*\*(.+?)\*\*/g,'<b>$1</b>').replace(/```(\w*)\n?([\s\S]*?)```/g,'<pre style="background:var(--bg);padding:8px;border-radius:6px;overflow-x:auto;font-size:11px"><code>$2</code></pre>')}${mediaHtml}</div><span style="font-size:9px;color:var(--dim);margin-top:2px">${ts}</span></div>`;
  }).join('');
  if(ml)ml.scrollTop=ml.scrollHeight;
  // Update thread title
  const titleEl=$('chatThreadTitle');
  if(titleEl)titleEl.textContent=c.title||'Chat';
}
function renderChatHist(){
  const hl=$('histList');
  if(!hl)return;
  const threads=(state.brain?.threads||[]).slice().sort((a,b)=>{
    // Prioritize running chats (with pending messages) to top
    const aPending=(a.messages||[]).some(m=>m.role==='assistant'&&m.pending);
    const bPending=(b.messages||[]).some(m=>m.role==='assistant'&&m.pending);
    if(aPending&&!bPending)return -1;
    if(!aPending&&bPending)return 1;
    // Then sort by last interaction time
    const aLast=(a.messages||[]).slice(-1)[0]?.at||'';
    const bLast=(b.messages||[]).slice(-1)[0]?.at||'';
    return bLast.localeCompare(aLast);
  });
  hl.innerHTML=threads.map(t=>{
    const msgs=t.messages||[];
    const last=msgs.slice(-1)[0]||{};
    const isPending=last.role==='assistant'&&last.pending;
    const hasMsgs=msgs.filter(m=>m.role!=='system').length>0;
    const msgCount=msgs.filter(m=>m.role!=='system').length;
    const lastText=isPending?'⏳ Processing...':clip(last.text||'Empty',55);
    const statusIcon=isPending?'🟡':(hasMsgs?'🟢':'⚪');
    const timeAgo=last.at?timeSince(last.at):'';
    return `<div class="histWrap">
      <button class="histDel" onclick="event.stopPropagation();deleteThread('${t.id}')">✕</button>
      <button class="hist ${t.id===activeThread?'active':''}" onclick="activeThread='${t.id}';renderChat();if(window.innerWidth<768)toggleHistory()">
        <b>${statusIcon} ${esc(t.title||'Chat')}</b>
        <small style="display:flex;gap:4px;align-items:center">
          <span style="color:var(--muted)">${clip(lastText,50)}</span>
          <span style="color:var(--dim);font-size:9px">${msgCount>0?msgCount+' msgs':''}${timeAgo?' · '+timeAgo:''}</span>
        </small>
      </button>
    </div>`;
  }).join('')||'<div style="padding:10px;font-size:11px;color:var(--dim)">No chats</div>';
}
function currentThread(){
  state.brain=state.brain||{};state.brain.threads=state.brain.threads||[];
  // Find existing thread
  let t=state.brain.threads.find(x=>x.id===activeThread);
  if(t)return t;
  // If no thread exists, create one
  return ensureFreshThread();
}
function timeSince(iso){
  if(!iso)return '';
  const s=Math.floor((Date.now()-new Date(iso).getTime())/1000);
  if(s<60)return 'now';
  if(s<3600)return Math.floor(s/60)+'m';
  if(s<86400)return Math.floor(s/3600)+'h';
  return Math.floor(s/86400)+'d';
}

// ─── FILE UPLOAD & IMAGE PASTE ─────────────────────
let chatUploadedFiles = [];
let barUploadedFiles = [];

async function handleChatFileUpload(files){
  if(!files||!files.length) return;
  const input = $('chatInput');
  const statusEl = $('chatUploadStatus');
  for(const file of files){
    if(file.size > 50*1024*1024){ alert('File too large (max 50MB): '+file.name); continue; }
    // Read as base64 data URL
    const dataUrl = await new Promise((res,rej)=>{
      const r = new FileReader();
      r.onload = ()=>res(r.result);
      r.onerror = rej;
      r.readAsDataURL(file);
    });
    chatUploadedFiles.push({name:file.name, data:dataUrl, type:file.type});
    // Show visual indicator in input or below
    if(input){
      const preview = file.type.startsWith('image/') ? `<img src="${dataUrl}" style="max-height:60px;border-radius:6px;margin:2px;vertical-align:middle">` : `📄 ${file.name}`;
      if(statusEl) statusEl.innerHTML += `<span style="display:inline-block;margin:2px;padding:2px 6px;background:var(--card);border-radius:6px;font-size:10px;color:var(--muted)">${preview}</span>`;
    }
  }
  if(input) input.focus();
}

async function uploadFileToServer(fileObj){
  const res = await fetch('/api/upload', {
    method:'POST',
    headers:{'content-type':'application/json'},
    body: JSON.stringify({
      filename: fileObj.name,
      data: fileObj.data,
      folder: fileObj.type.startsWith('image/') ? 'inbound' : 'docs'
    })
  }).then(r=>r.json());
  return res;
}

async function handleBarFileUpload(files){
  if(!files||!files.length) return;
  for(const file of files){
    if(file.size > 50*1024*1024){ alert('File too large (max 50MB): '+file.name); continue; }
    const dataUrl = await new Promise((res,rej)=>{
      const r = new FileReader();
      r.onload = ()=>res(r.result);
      r.onerror = rej;
      r.readAsDataURL(file);
    });
    barUploadedFiles.push({name:file.name, data:dataUrl, type:file.type});
    const input = $('barChatInput');
    if(input){
      const label = file.type.startsWith('image/') ? '🖼️ '+file.name : '📎 '+file.name;
      input.value = (input.value ? input.value + ' ' : '') + '['+label+']';
    }
  }
}

async function setupChatPaste(){
  const input = $('chatInput');
  if(!input) return;
  input.addEventListener('paste', async (e)=>{
    const items = e.clipboardData?.items;
    if(!items) return;
    for(const item of items){
      if(item.type.startsWith('image/')){
        e.preventDefault();
        const file = item.getAsFile();
        if(!file) continue;
        const dataUrl = await new Promise((res,rej)=>{
          const r = new FileReader();
          r.onload = ()=>res(r.result);
          r.onerror = rej;
          r.readAsDataURL(file);
        });
        chatUploadedFiles.push({name:'pasted-image.png', data:dataUrl, type:file.type});
        const statusEl = $('chatUploadStatus');
        if(statusEl) statusEl.innerHTML += `<span style="display:inline-block;margin:2px"><img src="${dataUrl}" style="max-height:60px;border-radius:6px;vertical-align:middle"></span>`;
      }
    }
  });
  // Also setup paste for bar chat
  const barInput = $('barChatInput');
  if(barInput){
    barInput.addEventListener('paste', async (e)=>{
      const items = e.clipboardData?.items;
      if(!items) return;
      for(const item of items){
        if(item.type.startsWith('image/')){
          e.preventDefault();
          const file = item.getAsFile();
          if(!file) continue;
          const dataUrl = await new Promise((res,rej)=>{
            const r = new FileReader();
            r.onload = ()=>res(r.result);
            r.onerror = rej;
            r.readAsDataURL(file);
          });
          barUploadedFiles.push({name:'pasted-image.png', data:dataUrl, type:file.type});
          barInput.value = (barInput.value ? barInput.value + ' ' : '') + '[🖼️ pasted image]';
        }
      }
    });
  }
}
let chatCodeMode=false,chatToolsMode=false,chatResearchMode=false,chatProject='';
let barCodeMode=false,barResearchMode=false,barDeepReasoning=false,barLawyerMode=false;

function toggleHistory(){
  const pane=$('historyPane');
  if(pane)pane.classList.toggle('open');
}

function toggleChatMode(mode){
  if(mode==='code'){
    chatCodeMode=!chatCodeMode;
    const btn=$('codeModeBtn');
    if(btn){
      btn.style.background=chatCodeMode?'var(--blue)':'var(--card)';
      btn.style.color=chatCodeMode?'#fff':'var(--muted)';
      btn.style.borderColor=chatCodeMode?'var(--blue)':'var(--line-light)';
    }
    if(chatCodeMode) sendChatMessage('Entering code mode. Route future requests to OpenCode.');
  }
  if(mode==='tools'){
    chatToolsMode=!chatToolsMode;
    const btn=$('toolsModeBtn');
    if(btn){
      btn.style.background=chatToolsMode?'var(--blue)':'var(--card)';
      btn.style.color=chatToolsMode?'#fff':'var(--muted)';
      btn.style.borderColor=chatToolsMode?'var(--blue)':'var(--line-light)';
    }
  }
  if(mode==='research'){
    chatResearchMode=!chatResearchMode;
    const btn=$('researchModeBtn');
    if(btn){
      btn.style.background=chatResearchMode?'var(--blue)':'var(--card)';
      btn.style.color=chatResearchMode?'#fff':'var(--muted)';
      btn.style.borderColor=chatResearchMode?'var(--blue)':'var(--line-light)';
    }
    if(chatResearchMode) sendChatMessage('Deep research mode: I will search multiple sources and compile a comprehensive report.');
  }
  updateChatModeIndicator();
}

function setChatProject(projectId){
  chatProject=projectId;
  // Update thread context
  const thread=currentThread();
  if(thread){
    thread.context=thread.context||{};
    thread.context.businessIds=projectId?[projectId]:[];
  }
}

// ─── BAR MODES & SETTINGS ──────────────────────────
let barSelectedProjects=[];
let barSelectedSkills=[];

function toggleBarMode(mode){
  if(mode==='code'){
    barCodeMode=!barCodeMode;
    const btn=$('barCodeModeBtn');
    if(btn)btn.classList.toggle('active',barCodeMode);
    if(barCodeMode) sendChatMessage('Entering code mode. Route future requests to OpenCode.');
  }
  if(mode==='research'){
    barResearchMode=!barResearchMode;
    const btn=$('barResearchModeBtn');
    if(btn)btn.classList.toggle('active',barResearchMode);
    if(barResearchMode) sendChatMessage('Deep research mode: I will search multiple sources and compile a comprehensive report.');
  }
  updateBarModeIndicator();
}

function toggleBarSettings(){
  const pop=$('barSettingsPop');
  if(pop){
    const isOpen=pop.classList.contains('open');
    pop.classList.toggle('open');
    if(!isOpen) populateBarLists();
  }
}

function toggleBarDeepReasoning(){
  barDeepReasoning=!barDeepReasoning;
  const btn=$('barDeepReasonBtn');
  if(btn)btn.classList.toggle('active',barDeepReasoning);
  if(barDeepReasoning) sendChatMessage('Deep reasoning enabled. I will think step-by-step through complex problems.');
  updateBarModeIndicator();
}

function toggleBarLawyerMode(){
  barLawyerMode=!barLawyerMode;
  const btn=$('barLawyerBtn');
  if(btn)btn.classList.toggle('active',barLawyerMode);
  if(barLawyerMode) sendChatMessage('Lawyer mode activated. I will provide legal analysis and guidance with appropriate disclaimers.');
  updateBarModeIndicator();
}

function updateBarModeIndicator(){
  const indicator=$('barModeIndicator');
  if(!indicator)return;
  const modes=[];
  if(barCodeMode)modes.push('⌘ Code');
  if(barResearchMode)modes.push('🧠 Research');
  if(barDeepReasoning)modes.push('🧠 Deep');
  if(barLawyerMode)modes.push('⚖️ Legal');
  indicator.textContent=modes.length?modes.join(' · '):'DeepSeek Pro';
  indicator.style.color=(barCodeMode||barResearchMode||barDeepReasoning||barLawyerMode)?'var(--fg)':'var(--dim)';
}

function toggleBarProject(id){
  const idx=barSelectedProjects.indexOf(id);
  if(idx>=0)barSelectedProjects.splice(idx,1);
  else barSelectedProjects.push(id);
  chatProject=barSelectedProjects[0]||'';
  const thread=currentThread();
  if(thread){
    thread.context=thread.context||{};
    thread.context.businessIds=[...barSelectedProjects];
  }
}

function toggleBarSkill(name){
  const idx=barSelectedSkills.indexOf(name);
  if(idx>=0)barSelectedSkills.splice(idx,1);
  else barSelectedSkills.push(name);
}

function createNewProject(){
  const name=prompt('Project name:');
  if(!name)return;
  api('/api/businesses',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({name})}).then(()=>{
    populateBarLists();
    setTimeout(()=>load(),500);
  }).catch(()=>{});
}

function createNewSkill(){
  const name=prompt('Skill name:');
  if(!name)return;
  barSelectedSkills.push(name);
  populateBarLists();
}

async function populateBarLists(){
  // Projects
  const projList=$('barProjectList');
  if(projList){
    try{
      const s=await api('/api/state');
      const bizs=s.businesses||[];
      projList.innerHTML=bizs.map(b=>`<label class="checkItem"><input type="checkbox" ${barSelectedProjects.includes(b.id)?'checked':''} onchange="toggleBarProject('${b.id}')"> ${esc(b.name)}</label>`).join('')||'<div style="padding:6px 12px;font-size:11px;color:var(--dim)">No projects yet</div>';
    }catch(e){
      projList.innerHTML='<div style="padding:6px 12px;font-size:11px;color:var(--dim)">Failed to load</div>';
    }
  }
  // Skills
  const skillsList=$('barSkillsList');
  if(skillsList){
    const skills=['Web Research','Code Review','Data Analysis','Email Writing','Content Strategy','Debugging','UI Design'];
    skillsList.innerHTML=skills.map(s=>`<label class="checkItem"><input type="checkbox" ${barSelectedSkills.includes(s)?'checked':''} onchange="toggleBarSkill('${s}')"> ${s}</label>`).join('');
  }
}

// Populate project & skills selectors
setTimeout(()=>{
  // Chat page selectors
  const sel=$('chatProjectSelect');
  if(sel)api('/api/state').then(s=>{
    (s.businesses||[]).forEach(b=>{
      const opt=document.createElement('option');
      opt.value=b.id;opt.textContent='📁 '+b.name;
      sel.appendChild(opt);
    });
  }).catch(()=>{});
  
  const skSel=$('chatSkillsSelect');
  if(skSel)['Web Research','Code Review','Data Analysis','Email Writing','Content Strategy','Debugging','UI Design'].forEach(sk=>{
    const opt=document.createElement('option');
    opt.value=sk;opt.textContent='🎯 '+sk;
    skSel.appendChild(opt);
  });
},2000);

// Update code mode indicator
function updateChatModeIndicator(){
  const indicator=$('chatModeIndicator');
  if(!indicator)return;
  const modes=[];
  if(chatCodeMode)modes.push('⌘ Code ON');
  if(chatResearchMode)modes.push('🧠 Research');
  if(modes.length)indicator.textContent=modes.join(' · ')+' · DeepSeek Pro';
  else indicator.textContent='DeepSeek Pro';
  indicator.style.color=chatCodeMode?'var(--fg)':'var(--dim)';
}

// ─── AI CHAT BAR ──────────────────────────────────────
let barCollapsed=false;
let barActiveThread=null;

function autoResizeChatInput(el){
  if(!el)return;
  el.style.height='auto';
  el.style.height=Math.min(el.scrollHeight,200)+'px';
}

function toggleBarCollapse(){
  barCollapsed=!barCollapsed;
  const collapsed=$('barCollapsed');
  const inputRow=$('barInputRow');
  const preview=$('barChatPreview');
  if(collapsed)collapsed.style.display=barCollapsed?'block':'none';
  if(inputRow)inputRow.style.display=barCollapsed?'none':'flex';
  if(barCollapsed&&preview)preview.style.display='none';
}

function closeBarPreview(){
  const preview=$('barChatPreview');
  if(preview)preview.style.display='none';
}

function newBarChat(){
  barActiveThread=null;
  barUploadedFiles=[];
  const input=$('barChatInput');
  if(input) input.value='';
  // Clear the preview
  const preview=$('barChatPreview');
  if(preview) preview.style.display='none';
  const msgs=$('barPreviewMsgs');
  if(msgs) msgs.innerHTML='';
  // Ensure bar is expanded
  if(barCollapsed){ toggleBarCollapse(); }
  if(input) input.focus();
}

// Send from bottom bar - stays on current page
async function sendBarMessage(){
  const input=$('barChatInput');
  const text=(input?input.value:'').trim();
  
  // Handle file uploads
  const uploadedUrls = [];
  if(barUploadedFiles.length > 0){
    for(const f of barUploadedFiles){
      try {
        const upRes = await uploadFileToServer(f);
        if(upRes && upRes.ok) uploadedUrls.push({url:upRes.url, name:f.name, type:f.type});
      } catch(e){ console.error('Bar upload failed:', e); }
    }
    barUploadedFiles = [];
  }
  
  let fullText = text;
  if(uploadedUrls.length > 0){
    const imageUrls = uploadedUrls.filter(u=>u.type.startsWith('image/')).map(u=>u.url);
    const docUrls = uploadedUrls.filter(u=>!u.type.startsWith('image/')).map(u=>`${u.name}: ${u.url}`);
    if(imageUrls.length) fullText += '\n\n[Images: ' + imageUrls.join(', ') + ']';
    if(docUrls.length) fullText += '\n\n[Files: ' + docUrls.join(', ') + ']';
  }
  
  if(!fullText.trim() && uploadedUrls.length === 0) return;
  if(input){input.value='';input.style.height='auto';}
  // Ensure we have a thread for the bar
  if(!barActiveThread){
    state.brain=state.brain||{};state.brain.threads=state.brain.threads||[];
    const tid='bar_'+Date.now();
    state.brain.threads.unshift({id:tid,title:'Quick chat',messages:[],context:{businessIds:[],page:activePage}});
    barActiveThread=tid;
  }
  const thread=state.brain.threads.find(t=>t.id===barActiveThread);
  if(!thread)return;
  // Add user message
  const userMsg={id:'usr_'+Date.now(),role:'user',text:fullText,media:uploadedUrls.length>0?uploadedUrls:undefined,at:new Date().toISOString(),surface:'dashboard-bar',threadId:thread.id};
  thread.messages=thread.messages||[];
  thread.messages.push(userMsg);
  // Add Thinking placeholder
  const thinkMsg={id:'think_'+Date.now(),role:'assistant',text:'Thinking…',pending:true,at:new Date().toISOString()};
  thread.messages.push(thinkMsg);
  // Show preview (server persists via /api/commands)
  showBarPreview(thread);
  // Trigger AI via /api/commands (which internally routes to thread messages)
  fetch('/api/commands',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({text:fullText,threadId:thread.id,send:true})}).then(r=>r.json()).then(d=>{
    if(d.ok)pollBarThread(thread);
  }).catch(()=>{});
}

// Show chat preview in bottom bar
function showBarPreview(thread){
  const preview=$('barChatPreview');
  const msgsContainer=$('barPreviewMsgs');
  const title=$('barPreviewTitle');
  if(!preview||!msgsContainer)return;
  if(title)title.textContent=thread.title||'Chat';
  const msgs=(thread.messages||[]).filter(m=>m.role!=='system').slice(-3);
  msgsContainer.innerHTML=msgs.map(m=>{
    const isUser=m.role==='user';
    const isPending=m.pending;
    const text=isPending?'⏳ '+clip(m.text||'Thinking...',80):clip(m.text||'',80);
    return `<div style="display:flex;justify-content:${isUser?'flex-end':'flex-start'};margin-bottom:4px"><div style="max-width:80%;padding:6px 10px;border-radius:10px;font-size:12px;line-height:1.4;${isUser?'background:var(--accent);color:#fff':isPending?'background:var(--soft);color:var(--muted);font-style:italic':'background:var(--soft);color:var(--text)'}">${esc(text)}</div></div>`;
  }).join('');
  preview.style.display='block';
}

// Poll bar thread for updates (doesn't navigate)
function pollBarThread(thread){
  let attempts=0;
  const poll=()=>{
    attempts++;
    if(attempts>240){
      thread.messages=thread.messages.filter(m=>!(m.pending&&m.role==='assistant'));
      thread.messages.push({id:'sys_'+Date.now(),role:'system',text:'⚠️ Request timed out.',at:new Date().toISOString()});
      showBarPreview(thread);
      return;
    }
    api('/api/state').then(s=>{
      state=s;
      const t2=(s.brain?.threads||[]).find(x=>x.id===thread.id);
      if(t2){
        thread.messages=t2.messages||[];
        showBarPreview(thread);
        const lastMsg=thread.messages[thread.messages.length-1];
        if(lastMsg&&lastMsg.role==='assistant'&&!lastMsg.pending){
          return;
        }
        // Update thinking status with elapsed time
        if(lastMsg&&lastMsg.pending){
          const elapsed=Math.floor(attempts*0.5);
          const statusText=elapsed<5?'Thinking ⠋':elapsed<15?'Thinking ⠙ ('+elapsed+'s)':elapsed<30?'Processing ⠹ ('+elapsed+'s)':elapsed<60?'Working ⠸ ('+elapsed+'s)':'Almost there ⠴ ('+elapsed+'s)';
          const thinkIdx=thread.messages.findIndex(m=>m.pending&&m.role==='assistant');
          if(thinkIdx>=0&&thread.messages[thinkIdx].text!==statusText){
            thread.messages[thinkIdx].text=statusText;
            showBarPreview(thread);
          }
        }
        setTimeout(poll,500);
      } else setTimeout(poll,500);
    }).catch(()=>setTimeout(poll,500));
  };
  setTimeout(poll,500);
}

// Send from chat page
async function sendChatMessage(msg){
  const input=$('chatInput');
  const text=msg||(input?input.value:'').trim();
  
  // ─── Handle file uploads first ───
  const uploadedUrls = [];
  if(chatUploadedFiles.length > 0){
    for(const f of chatUploadedFiles){
      try {
        const upRes = await uploadFileToServer(f);
        if(upRes && upRes.ok) uploadedUrls.push({url:upRes.url, name:f.name, type:f.type});
      } catch(e){ console.error('Upload failed:', e); }
    }
    chatUploadedFiles = [];
    const statusEl = $('chatUploadStatus');
    if(statusEl) statusEl.innerHTML = '';
    // Refresh state so gallery/docs pick up new files
    setTimeout(()=>load(), 300);
  }
  
  // Build full message including uploaded files
  let fullText = text;
  if(uploadedUrls.length > 0){
    const imageUrls = uploadedUrls.filter(u=>u.type.startsWith('image/')).map(u=>u.url);
    const docUrls = uploadedUrls.filter(u=>!u.type.startsWith('image/')).map(u=>`${u.name}: ${u.url}`);
    if(imageUrls.length) fullText += '\n\n[Images: ' + imageUrls.join(', ') + ']';
    if(docUrls.length) fullText += '\n\n[Files: ' + docUrls.join(', ') + ']';
  }
  
  if(!fullText.trim() && uploadedUrls.length === 0) return;
  if(input){input.value='';input.style.height='auto';}
  
  // Parse commands locally — execute directly + ALSO send to AI
  const lower=fullText.toLowerCase();
  
  // Auto-detect payment data in ANY message
  // Match patterns like: "ProjectName £X paid", "ProjectName: £X upcoming", "£X for Project"
  const paymentPatterns=[];
  const lines=fullText.split(/[,;\n]+/);
  for(const line of lines){
    const ll=line.toLowerCase().trim();
    if(!ll)continue;
    // Try: "Project £X [status]" or "Project: £X [status]"
    let m=ll.match(/([a-z][a-z0-9\s]+?)\s*[:\-]?\s*[£$€]?\s*(\d+[.,]?\d*)\s*(k|k)?\s*(paid|upcoming|pipeline|monthly|mrr)?/i);
    if(!m) m=ll.match(/[£$€]\s*(\d+[.,]?\d*)\s*(k)?\s*(?:paid|upcoming|pipeline|monthly|mrr)?\s*(?:for|from|to|:)?\s*(.+)/i);
    if(m){
      let projectName='', amount=0, status='paid', desc='', type='nonrecurring';
      if(m[1]&&!/^\d+$/.test(m[1])&&parseFloat((m[2]||'0').replace(',','.'))>0){ // "Project £X [status]"
        projectName=m[1].trim().replace(/^[\s:,.-]+/,'').replace(/[\s:,.-]+$/,'');
        amount=parseFloat((m[2]||'0').replace(',','.'))*((m[3]||'').toLowerCase()==='k'?1000:1);
        if(m[4]){status=m[4].toLowerCase();if(status==='monthly'||status==='mrr'){status='paid';type='recurring'}}
        desc=projectName+' payment';
      } else if(m[3]&&m[4]){ // "£X [status] for Project"
        amount=parseFloat((m[1]||'0').replace(',','.'))*((m[2]||'').toLowerCase()==='k'?1000:1);
        status=m[3].toLowerCase();if(status==='monthly'||status==='mrr'){status='paid';type='recurring'}
        projectName=m[4].trim();
        desc=projectName+' payment';
      }
      if(projectName&&amount>10){
        const biz=(state.businesses||[]).find(b=>projectName.toLowerCase().includes(b.name.toLowerCase())||b.name.toLowerCase().includes(projectName.toLowerCase()));
        paymentPatterns.push({projectId:biz?biz.id:'',amount,type:type||'nonrecurring',status:status||'paid',description:desc,date:todayKey()});
      }
    }
  }
  
  // Execute detected payments
  for(const pp of paymentPatterns){
    api('/api/payments',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(pp)});
  }
  
  // Also handle explicit commands
  // "add task: X" or "add todo: X"
  if(lower.startsWith('add task')||lower.startsWith('add todo')||lower.startsWith('task:')){
    const taskText=fullText.replace(/^(add\s+task\s*:?|add\s+todo\s*:?|task\s*:?)\s*/i,'');
    if(taskText){
      api('/api/todos',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),text:taskText,priority:'medium'})});
    }
  }
  
  // "mark X as done" / "complete X"
  if(lower.includes('mark')&&(lower.includes('done')||lower.includes('complete'))){
    const kw=fullText.replace(/mark\s+|as\s+|done|complete/gi,'').trim().toLowerCase();
    const arr=(state.todos||{})[todayKey()]||[];
    const match=arr.find(t=>t.text.toLowerCase().includes(kw));
    if(match) api('/api/todos/'+match.id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify({done:true})});
  }
  
  // Navigation commands
  if(lower.includes('show projects')||lower.includes('go to projects')){navTo('projects');load();return}
  if(lower.includes('show stats')||lower.includes('show revenue')||lower.includes('show mrr')){projView='stats';navTo('projects');load();return}
  if(lower.includes('show list')||lower.includes('show calendar')){projView='list';navTo('projects');load();return}
  if(lower.includes('show schedule')||lower.includes('show timetable')){navTo('schedule');load();return}
  if(lower.includes('show chat')||lower.includes('go to chat')){navTo('chat');load();return}
  if(lower.includes('show todo')||lower.includes('show tasks')){navTo('todo');load();return}
  if(lower.includes('show home')){navTo('home');load();return}
  
  // ─── Daily check-in commands ───
  // "mood 4", "feeling great" (maps to mood 5), "productivity 7", "worked 6 hours"
  const moodMatch=fullText.match(/(?:mood|feeling)\s*(\d|awful|meh|okay|good|great)/i);
  if(moodMatch){
    let v=moodMatch[1].toLowerCase();
    if(v==='awful')v=1;else if(v==='meh')v=2;else if(v==='okay'||v==='ok')v=3;else if(v==='good')v=4;else if(v==='great')v=5;else v=parseInt(v)||3;
    fetch('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field:'mood',value:Math.min(5,Math.max(1,v))})}).catch(()=>{});
  }
  const prodMatch=fullText.match(/productivity\s*(\d+)/i);
  if(prodMatch){const v=Math.min(10,Math.max(1,parseInt(prodMatch[1])||5));fetch('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field:'productivity',value:v})}).catch(()=>{});}
  const hoursMatch=fullText.match(/(?:worked|did)\s*(\d+(?:\.\d+)?)\s*(?:hours?|hrs?|h)/i);
  if(hoursMatch){const v=Math.min(24,Math.max(0,parseFloat(hoursMatch[1])||0));fetch('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field:'hours',value:v})}).catch(()=>{});}
  
  // ─── Thread management: page-aware ───
  let thread;
  if(activePage==="chat"){
    thread=currentThread();
    pageThreads[activePage]=thread.id;
  } else {
    thread=ensureFreshThread();
  }
  // Tag thread with current page context if not already set
  thread.context=thread.context||{};
  thread.context.page=activePage;
  // On project detail page, inject the project ID so AI knows which project you're on
  if(activePage==='project-detail' && projectDetailId){
    thread.context.businessIds = [projectDetailId];
    const proj = (state.businesses||[]).find(b=>b.id===projectDetailId);
    if(proj) thread.context.projectName = proj.name;
  }
  
  const userMsg={id:'usr_'+Date.now(),role:'user',text:fullText,media:uploadedUrls.length>0?uploadedUrls:undefined,at:new Date().toISOString(),surface:'dashboard',threadId:thread.id};
  thread.messages=thread.messages||[];
  thread.messages.push(userMsg);
  // Add client-side Thinking placeholder immediately
  const thinkMsg={id:'think_'+Date.now(),role:'assistant',text:'Thinking…',pending:true,at:new Date().toISOString()};
  thread.messages.push(thinkMsg);
  // Render immediately (server persists via /api/commands)
  // Render immediately
  if(activePage==='chat')renderChat();
  else if(activePage!=='chat') openChatOverlay();
  
  // Trigger AI via /api/commands (which internally routes to thread messages)
  fetch('/api/commands',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({text:fullText,threadId:thread.id,send:true})}).then(r=>r.json()).then(d=>{
    if(d.ok)pollChatThread(thread);
  }).catch(()=>{});
  setTimeout(()=>load(),500);
}

// Poll chat page thread for updates
function pollChatThread(thread){
  let attempts=0;
  const poll=()=>{
    attempts++;
    if(attempts>240){
      thread.messages=thread.messages.filter(m=>!(m.pending&&m.role==='assistant'));
      thread.messages.push({id:'sys_'+Date.now(),role:'system',text:'⚠️ Request timed out after 2 minutes.',at:new Date().toISOString()});
      if(activePage==='chat')renderChat();
      else if($('chatOverlay')&&$('chatOverlay').classList.contains('open'))renderChatOverlayMsgs();
      return;
    }
    api('/api/state').then(s=>{
      state=s;
      const t2=(s.brain?.threads||[]).find(x=>x.id===thread.id);
      if(t2){
        const serverMsgs=t2.messages||[];
        const localMsgs=thread.messages||[];
        const hasNew=serverMsgs.length!==localMsgs.length||JSON.stringify(serverMsgs.slice(-1))!==JSON.stringify(localMsgs.slice(-1));
        if(hasNew){
          thread.messages=serverMsgs;
          if(activePage==='chat')renderChat();
          else if($('chatOverlay')&&$('chatOverlay').classList.contains('open'))renderChatOverlayMsgs();
        }
        const lastMsg=serverMsgs[serverMsgs.length-1];
        if(lastMsg&&lastMsg.role==='assistant'&&!lastMsg.pending){
          if(activePage==='todo')renderTodos();
          else if(activePage==='project-detail')renderProjectDetail();
          else if(activePage==='home')renderHomeStats();
          return;
        }
        // Update thinking status with elapsed time
        if(lastMsg&&lastMsg.pending){
          const elapsed=Math.floor(attempts*0.5);
          const statusText=elapsed<5?'Thinking ⠋':elapsed<15?'Thinking ⠙ ('+elapsed+'s)':elapsed<30?'Processing ⠹ ('+elapsed+'s)':elapsed<60?'Working ⠸ ('+elapsed+'s)':'Almost there ⠴ ('+elapsed+'s)';
          const thinkIdx=thread.messages.findIndex(m=>m.pending&&m.role==='assistant');
          if(thinkIdx>=0&&thread.messages[thinkIdx].text!==statusText){
            thread.messages[thinkIdx].text=statusText;
            if(activePage==='chat')renderChat();
          }
        }
        setTimeout(poll,500);
      } else setTimeout(poll,500);
    }).catch(()=>setTimeout(poll,500));
  };
  setTimeout(poll,500);
}
