async function renderSkills(){
  const grid=$('skillGrid');if(!grid)return;
  const filter=$('skillFilter');
  const search=$('skillSearch');
  
  // Populate filter dropdown (once)
  if(!filter.dataset.loaded){
    const cats=[...new Set(ALL_TOOLS.map(t=>t.c))].sort();
    filter.innerHTML='<option value="all">All categories</option>'+cats.map(c=>'<option value="'+esc(c)+'">'+esc(c)+'</option>').join('');
    filter.dataset.loaded='1';
  }
  
  const cat=filter.value;
  const q=(search.value||'').toLowerCase().trim();
  
  let filtered=cat==='all'?ALL_TOOLS:ALL_TOOLS.filter(t=>t.c===cat);
  if(q) filtered=filtered.filter(t=>t.n.toLowerCase().includes(q)||(t.d||'').toLowerCase().includes(q));
  
  if(!filtered.length){grid.innerHTML='<div style="color:var(--muted);padding:24px;text-align:center;font-size:13px">No tools found.</div>';return}
  
  grid.innerHTML=filtered.map(t=>{
    const url=t.gh?'https://github.com/'+t.gh:(t.w||'#');
    return '<div style="background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:14px;cursor:pointer;transition:border-color .15s" onclick="window.open(\''+url+'\',\'_blank\')" title="'+esc(t.d||'')+'">'+
      '<div style="font-size:10px;color:var(--blue);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.5px">'+esc(t.c)+'</div>'+
      '<div style="font-size:14px;font-weight:700;margin-bottom:4px">'+esc(t.n)+(t.local?' <span style="font-size:9px;color:var(--amber);font-weight:400">local</span>':'')+'</div>'+
      '<div style="font-size:11px;color:var(--muted)">'+esc(t.d||'')+'</div>'+
      (t.gh?'<div style="font-size:9px;color:var(--dim);margin-top:6px">→ github.com/'+esc(t.gh)+'</div>':'')+
    '</div>';
  }).join('');
}

// ─── CODE WORKSPACE ───────────────────────────────────
let codeThreads=[];
let _activeCodeThread=null;
let _activeCodeProject='__all';

async function renderCodePage(){
  const projSel=$('codeProject');if(!projSel)return;
  const chats=$('codeMessages');
  const stats=$('codeStats');
  const wrap=$('codeChatWrap');
  
  // Load coding-related threads (from businesses)
  const r=await fetch('/api/brain');
  const d=await r.json();
  const threads=d.brain?.threads||[];
  codeThreads=threads;
  
  // Populate project selector with businesses
  const bizs=d.businesses||[];
  const current=projSel.value;
  projSel.innerHTML='<option value="__all">⚡ All coding chats</option>'+bizs.map(b=>'<option value="'+esc(b.id)+'">'+esc(b.name)+'</option>').join('');
  if(current) projSel.value=current;
  
  // Stats
  const openTodos=Object.values(d.todos||{}).flat().filter(t=>!t.done).length;
  const activeBiz=bizs.filter(b=>b.status==='active'||b.status==='design').length;
  const runningCount=threads.filter(t=>(t.messages||[]).some(m=>m.pending)).length;
  if(stats) stats.innerHTML='<span>📦 '+bizs.length+' projects</span><span>✓ '+openTodos+' open tasks</span><span>💬 '+threads.length+' chats</span>'+(runningCount?' <span style="color:var(--amber)">⚡ '+runningCount+' running</span>':'');
  
  // Show messages for selected project
  switchCodeProject(projSel.value,false);
  startCodePoll();
}

// Poll every 10s for running thread updates (persists across refresh)
let _codePollTimer=null;
async function startCodePoll(){
  if(_codePollTimer) clearInterval(_codePollTimer);
  _codePollTimer=setInterval(async ()=>{
    if(activePage!=='code') return;
    try{
      const fresh=await api('/api/state');
      const prevCount=(state.brain?.threads||[]).filter(t=>(t.messages||[]).some(m=>m.pending)).length;
      state=fresh;
      const newCount=(fresh.brain?.threads||[]).filter(t=>(t.messages||[]).some(m=>m.pending)).length;
      codeThreads=fresh.brain?.threads||[];
      // Update thread list if running count changed
      if(newCount!==prevCount||_activeCodeThread){
        const proj=$('codeProject');
        if(proj) switchCodeProject(proj.value,false);
        if(_activeCodeThread) openCodeChat(_activeCodeThread);
      }
      // Update notification bell
      loadNotif();
    }catch(e){}
  },10000);
}

function switchCodeProject(projectId, clearThread){
  // clearThread=true means user switched projects explicitly
  // false/undefined means refresh (poll/load) — preserve active thread
  if(clearThread!==false) _activeCodeThread=null;
  const chats=$('codeMessages');if(!chats)return;
  const wrap=$('codeChatWrap');
  
  const allFiltered=projectId==='__all'?codeThreads:codeThreads.filter(t=>(t.context?.businessIds||[]).includes(projectId)||(t.title||'').toLowerCase().includes(projectId));
  
  // Split into running (has pending messages) and completed
  const running=allFiltered.filter(t=>(t.messages||[]).some(m=>m.pending));
  const completed=allFiltered.filter(t=>!(t.messages||[]).some(m=>m.pending));
  
  if(!allFiltered.length){
    chats.innerHTML='<div style="color:var(--muted);padding:24px;text-align:center;font-size:13px">No chats for this project yet. Send a command below.</div>';
    return;
  }
  
  let html='';
  
  // Running threads section
  if(running.length){
    html+='<div style="font-size:10px;font-weight:700;color:var(--amber);padding:4px 6px;margin-bottom:4px;display:flex;align-items:center;gap:4px">⚡ RUNNING <span style="font-weight:400;color:var(--muted);font-size:9px">'+running.length+' active</span></div>';
    html+=running.slice(0,5).map(t=>{
      const msgs=t.messages||[];
      const last=msgs.filter(m=>m.role!=='system').slice(-1)[0];
      const statusText=last&&last.pending?'⏳ Processing...':(last?esc(clip(last.text,80)):'No messages');
      return '<div class="threadCard" style="background:color-mix(in srgb,var(--amber)10%,var(--bg));border:1px solid color-mix(in srgb,var(--amber)30%,var(--line));border-radius:8px;padding:10px;margin-bottom:6px;cursor:pointer" onclick="openCodeChat(\''+esc(t.id)+'\')">'+
        '<button class="thrDel" onclick="event.stopPropagation();deleteThread(\''+esc(t.id)+'\')">✕</button>'+ 


        '<div style="display:flex;align-items:center;gap:6px">'+
          '<span style="width:8px;height:8px;border-radius:8px;background:var(--amber);flex-shrink:0"></span>'+
          '<div style="flex:1;min-width:0">'+
            '<div style="font-size:12px;font-weight:700">'+esc(t.title||'Untitled')+'</div>'+
            '<div style="font-size:10px;color:var(--muted);margin-top:2px">⏳ '+statusText+'</div>'+
          '</div>'+
        '</div>'+
        '<div style="font-size:9px;color:var(--muted);margin-top:4px">'+msgs.length+' msgs'+
          (t.context?.businessIds?.length?' · '+(t.context.businessIds.join(', ')):'')+
        '</div>'+
      '</div>';
    }).join('');
  }
  
  // Completed threads
  if(completed.length){
    if(running.length) html+='<div style="height:1px;background:var(--line);margin:8px 0"></div>';
    html+='<div style="font-size:10px;font-weight:700;color:var(--muted);padding:4px 6px;margin-bottom:4px">📁 Completed ('+completed.length+')</div>';
    html+=completed.slice(0,15).map(t=>{
      const msgs=t.messages||[];
      const last=msgs.filter(m=>m.role!=='system').slice(-1)[0];
      return '<div class="threadCard" style="background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:10px;margin-bottom:6px;cursor:pointer" onclick="openCodeChat(\''+esc(t.id)+'\')">'+
        '<button class="thrDel" onclick="event.stopPropagation();deleteThread(\''+esc(t.id)+'\')">✕</button>'+ 


        '<div style="font-size:12px;font-weight:700">'+esc(t.title||'Untitled')+'</div>'+
        '<div style="font-size:10px;color:var(--dim);margin-top:2px">'+(last?esc(clip(last.text,120)):'No messages')+'</div>'+
        '<div style="font-size:9px;color:var(--muted);margin-top:2px">'+msgs.length+' msgs'+
          (t.context?.businessIds?.length?' · '+(t.context.businessIds.join(', ')):'')+
        '</div>'+
      '</div>';
    }).join('');
  }
  
  chats.innerHTML=html;
}

function openCodeChat(threadId){
  // Track which thread we're viewing
  _activeCodeThread=threadId;
  // Stay on code page — show thread messages inline
  const chatDiv=$('codeMessages');
  const wrap=$('codeChatWrap');
  if(!chatDiv)return;
  const thread=codeThreads.find(t=>t.id===threadId);
  if(!thread)return;
  const msgs=thread.messages||[];
  chatDiv.innerHTML=
    '<div style="text-align:center;margin-bottom:8px"><button class="btn alt" style="font-size:11px" onclick="switchCodeProject(document.getElementById(\'codeProject\').value)">← Back to threads</button></div>'+
    msgs.filter(m=>m.role!=='system').map(m=>{
      const body=esc(m.text||'');
      const ts=m.at?new Date(m.at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
      return '<div style="background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:10px;margin-bottom:8px">'+
        '<div style="font-size:10px;color:var(--dim);margin-bottom:4px">'+(m.role==='user'?'🧑‍💻 You':'🤖 Kaneki')+' · '+ts+'</div>'+
        '<div style="font-size:13px;line-height:1.5;white-space:pre-wrap">'+body.replace(/\n/g,'<br>').replace(/\*\*(.+?)\*\*/g,'<b>$1</b>').replace(/\`\`\`(\w*)\n?([\s\S]*?)\`\`\`/g,'<pre style="background:var(--bg);padding:8px;border-radius:6px;overflow-x:auto;font-size:11px"><code>$2</code></pre>')+'</div>'+
      '</div>';
    }).join('')||'<div style="color:var(--muted);padding:24px;text-align:center;font-size:13px">No messages yet.</div>';
  if(chatDiv)chatDiv.scrollTop=chatDiv.scrollHeight;
}

async function sendCodeCommand(){
  const input=$('codeInput');
  const text=input.value.trim();
  if(!text)return;
  input.value='';
  
  const project=$('codeProject').value;
  _activeCodeProject=project;
  
  // Use the thread the user is currently viewing (set by openCodeChat)
  let threadId=_activeCodeThread;
  
  if(!threadId){
    // No thread selected yet — create a new one via state
    const s=await api('/api/state');
    s.brain=s.brain||{};s.brain.threads=s.brain.threads||[];
    const tid='code-'+Date.now();
    s.brain.threads.unshift({id:tid,title:'⌘ Code: '+clip(text,40),messages:[],context:{businessIds:project==='__all'?[]:[project],page:'code'},scope:'Coding workspace chat'});
    // Use threads API (not full-state overwrite)
    fetch('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({id:tid,title:'⌘ Code: '+clip(text,40),context:{businessIds:project==='__all'?[]:[project],page:'code'},scope:'Coding workspace chat'})}).catch(()=>{});
    state=s;
    threadId=tid;
  }
  
  // Send the message via /api/commands
  await fetch('/api/commands',{
    method:'POST',
    headers:{'content-type':'application/json'},
    body:JSON.stringify({text:text,threadId:threadId,send:true})
  });
  
  // Stay on code page — show the thread with Thinking… and poll for response
  await load();
  renderCodePage();
  openCodeChat(threadId);
  
  // Poll for AI response every 2s (up to 120s)
  let polls=0;
  const pollTimer=setInterval(async ()=>{
    polls++;
    if(polls>60){
      clearInterval(pollTimer);
      // Timeout — update local state to show error
      var fresh2=await fetch('/api/state');var sd2=await fresh2.json();state=sd2;
      var t2=state.brain?.threads?.find(function(x){return x.id===threadId;});
      if(t2&&(t2.messages||[]).some(function(m){return m.pending;})){
        var pIdx=(t2.messages||[]).findLastIndex(function(m){return m.role==='assistant'&&m.pending;});
        if(pIdx>=0)t2.messages.splice(pIdx,1);
        t2.messages.push({id:'sys_'+Date.now(),role:'system',text:'⚠️ Request timed out. Try using Telegram for real-time AI interaction.',at:new Date().toISOString(),threadId:threadId});
        // Persist timeout message via targeted endpoint
        fetch('/api/threads/'+threadId+'/messages',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({message:'⚠️ Request timed out.',localOnly:true})}).catch(()=>{});
      }
      openCodeChat(threadId);
      return;
    }
    try{
      const fresh=await api('/api/state');
      state=fresh;
      const t=fresh.brain?.threads?.find(x=>x.id===threadId);
      if(t){
        const msgs=t.messages||[];
        const hasPending=msgs.some(m=>m.pending);
        if(!hasPending){
          // AI responded — update the view
          clearInterval(pollTimer);
          openCodeChat(threadId);
          // Trigger notification
          loadNotif();
        }
      }
    }catch(e){}
  },2000);
}

// ─── LEADS ─────────────────────────────────────────────
function renderLeads(){
  // handled by iframe, no extra JS needed
}

// ─── RENDER DISPATCH ──────────────────────────────────
window.addEventListener('error',function(e){
  var main=document.getElementById('appMain');
  if(main) main.innerHTML='<div style="padding:40px;text-align:center"><div style="font-size:40px;margin-bottom:12px">⚠️</div><div style="color:var(--red);font-weight:700">'+escape(e.message)+'</div><div style="font-size:11px;color:var(--dim);margin-top:8px">'+escape(e.filename||'')+':'+e.lineno+'</div><button class="btn" onclick="location.reload()" style="margin-top:16px">↻ Reload</button></div>';
});
var _origRenderPage=renderPage;
renderPage=function(id){
  try {
    _origRenderPage(id);
    if(id==='code')renderCodePage();
    if(id==='leads')renderLeads();
  } catch(e) {
    console.error('[render] error:',e);
    var main=document.getElementById('appMain');
    if(main) main.innerHTML='<div style="padding:40px;text-align:center"><div style="font-size:40px;margin-bottom:12px">⚠️</div><div style="color:var(--red);font-weight:700">Render error: '+escape(e.message)+'</div><button class="btn" onclick="location.reload()" style="margin-top:16px">↻ Reload</button></div>';
  }
};

// ─── DOCUMENTS ─────────────────────────────────────────
let allDocs=[];
let docFiltered=[];
let docTab = 'docs';

function switchDocTab(tab){
  docTab = tab;
  const docBtn = document.getElementById('docsTabBtn');
  const galBtn = document.getElementById('galleryTabBtn');
  const docView = document.getElementById('docsDocView');
  const galView = document.getElementById('docsGalleryView');
  if(tab==='docs'){
    if(docBtn){docBtn.style.background='var(--blue)';docBtn.style.color='#fff';}
    if(galBtn){galBtn.style.background='var(--card)';galBtn.style.color='var(--text)';}
    if(docView)docView.style.display='block';
    if(galView)galView.style.display='none';
    renderDocs();
  } else {
    if(docBtn){docBtn.style.background='var(--card)';docBtn.style.color='var(--text)';}
    if(galBtn){galBtn.style.background='var(--blue)';galBtn.style.color='#fff';}
    if(docView)docView.style.display='none';
    if(galView)galView.style.display='block';
    loadGalleryInline();
  }
}

async function loadGalleryInline(){
  var grid=document.getElementById('galleryGridInline');
  if(!grid)return;
  grid.innerHTML='<div style="text-align:center;padding:20px;color:var(--dim);font-size:12px">Loading...</div>';
  try{
    var res=await fetch('/api/gallery');
    var data=await res.json();
    if(data.images&&data.images.length){
      grid.innerHTML=data.images.map(function(img){
        var f=img.file||'';
        var isVideo=img.type==='video'||['mp4','webm','mov','mkv'].indexOf(img.ext)>=0;
        if(isVideo){
          return '<div style="border-radius:6px;overflow:hidden;border:1px solid var(--line);background:var(--card);cursor:pointer;position:relative" onclick="openGalleryMedia(\''+f+'\',\'video\')"><div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:1;pointer-events:none"><div style="width:28px;height:28px;border-radius:50%;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px">\u25b6</div></div><video src="/media/'+f+'" style="width:100%;height:110px;object-fit:cover;display:block" preload="metadata"></video></div>';
        }
        return '<div style="border-radius:6px;overflow:hidden;border:1px solid var(--line);background:var(--card);cursor:pointer" onclick="openGalleryMedia(\''+f+'\',\'image\')"><img src="/media/'+f+'" style="width:100%;height:110px;object-fit:cover;display:block" loading="lazy" onerror="this.parentElement.innerHTML=\'<div style=\"padding:30px;text-align:center;color:var(--dim)\">Broken</div>\'"></div>';
      }).join('');
    } else {
      grid.innerHTML='<div style="text-align:center;padding:40px;color:var(--dim);font-size:13px">No files yet.</div>';
    }
  }catch(e){
    grid.innerHTML='<div style="text-align:center;padding:40px;color:var(--dim);font-size:13px">Could not load gallery.</div>';
  }
}


async function renderDocs(){
  const list=$('docList');if(!list)return;
  const stats=$('docStats');
  try{
    // Query the RAG system for document listing
    const r=await fetch('/api/skills'); // reuse for now, real doc list via vault
    // Build doc list from known files in lamatrader-ingest
    const r2=await fetch('/api/vault');
    const vault=await r2.json();
    allDocs=vault.files||[];
    docFiltered=allDocs;
  }catch(e){list.innerHTML='<div style="color:var(--muted);padding:16px;text-align:center">No documents loaded yet.</div>';return}
  
  if(stats) stats.innerHTML='<span>📄 '+allDocs.length+' files</span>';
  
  if(!allDocs.length){
    list.innerHTML='<div style="color:var(--muted);padding:16px;text-align:center">No documents found.</div>';
    return;
  }
  
  list.innerHTML=docFiltered.map(f=>
    '<div style="background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:10px;font-size:12px">'+
      '<div style="display:flex;justify-content:space-between;align-items:center">'+
        '<strong>📄 '+esc(f.title||f.path.split('/').pop())+'</strong>'+
        '<span style="color:var(--muted);font-size:10px">'+(f.size?((f.size/1024).toFixed(1)+' KB'):'')+'</span>'+
      '</div>'+
      '<div style="color:var(--muted);margin-top:2px;font-size:10px">'+esc(f.path)+'</div>'+
      '<div style="color:var(--dim);margin-top:4px;font-size:11px">'+(f.sections?f.sections.length+' sections':'')+'</div>'+
    '</div>'
  ).join('');
}

function filterDocs(q){
  if(!q){docFiltered=allDocs;renderDocs();return}
  const lower=q.toLowerCase();
  docFiltered=allDocs.filter(f=>
    (f.title||'').toLowerCase().includes(lower)||
    f.path.toLowerCase().includes(lower)
  );
  renderDocs();
}

let docUploadQueue=[];
function handleDocUpload(files){
  for(const f of files) docUploadQueue.push(f);
  alert('Uploaded '+(files.length)+' file(s). They are queued for processing.');
  // In a full implementation, we'd send to a server endpoint for indexing
}
function handleDocDrop(e){
  e.preventDefault();
  handleDocUpload(e.dataTransfer.files);
}


</script>  
<script>
// ── MarkItDown file converter ──
const CONVERT_API = '/convert/api/convert';
let convertResult = '';

async function handleDrop(e) {
  const file = e.dataTransfer.files[0];
  if (file) await convertFile(file);
}
async function handleFileInput(input) {
  const file = input.files[0];
  if (file) await convertFile(file);
}
async function convertFile(file) {
  document.getElementById('uploadPrompt').classList.add('hidden');
  document.getElementById('converting').classList.remove('hidden');
  document.getElementById('resultArea').classList.add('hidden');
  
  try {
    const form = new FormData();
    form.append('file', file);
    const r = await fetch(CONVERT_API, { method: 'POST', body: form });
    const d = await r.json();
    
    document.getElementById('converting').classList.add('hidden');
    
    if (d.error) {
      alert('Error: ' + d.error);
      resetConvert();
      return;
    }
    
    convertResult = d.text_content || '';
    document.getElementById('resultFilename').textContent = d.filename + ' (' + (d.title || 'no title') + ')';
    document.getElementById('resultLength').textContent = convertResult.length + ' chars · ready for AI';
    document.getElementById('resultText').value = convertResult;
    document.getElementById('resultArea').classList.remove('hidden');
  } catch(e) {
    document.getElementById('converting').classList.add('hidden');
    alert('Conversion failed: ' + e.message);
    resetConvert();
  }
}
function copyResult() {
  if (!convertResult) return;
  navigator.clipboard.writeText(convertResult).then(() => {
    const btn = event.target;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });
}
function resetConvert() {
  document.getElementById('uploadPrompt').classList.remove('hidden');
  document.getElementById('converting').classList.add('hidden');
  document.getElementById('resultArea').classList.add('hidden');
  convertResult = '';
}
</script><script>if("serviceWorker" in navigator){window.addEventListener("load",function(){navigator.serviceWorker.register("/sw.js").then(function(r){console.log("SW registered:",r.scope)},function(e){console.log("SW failed:",e)})})}</script>
</body></html>
