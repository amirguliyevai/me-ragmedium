<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><title>Amir Command</title><meta name="theme-color" content="#111111"><meta name="mobile-web-app-capable" content="yes"><meta name="apple-mobile-web-app-capable" content="yes"><meta name="apple-mobile-web-app-title" content="Command"><meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"><link rel="manifest" href="/manifest.webmanifest"><link rel="apple-touch-icon" href="/icons/icon-192.png"><link rel="icon" href="/icons/icon-192.png"><style>
:root {
  --bg: #f8f9fb;
  --card: #fff;
  --soft: #f1f3f6;
  --text: #1a1d23;
  --muted: #6b7280;
  --dim: #9ca3af;
  --line: #e5e7eb;
  --ink: #111827;
  --green: #059669;
  --amber: #d97706;
  --red: #dc2626;
  --blue: #3b82f6;
  --shadow-sm: 0 1px 2px rgba(16,24,40,.04);
  --shadow: 0 1px 3px rgba(16,24,40,.05), 0 4px 16px rgba(16,24,40,.04);
  --shadow-lg: 0 8px 32px rgba(16,24,40,.08);
  --shadow-xl: 0 12px 48px rgba(16,24,40,.12);
  --radius-sm: 6px;
  --radius: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-2xl: 20px;
  --font: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  --mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
}
html.dark {
  --bg: #0d1117;
  --card: #161b22;
  --soft: #1c2129;
  --text: #e6edf3;
  --muted: #8b949e;
  --dim: #5c6570;
  --line: #30363d;
  --ink: #f0f6fc;
  --shadow-sm: 0 1px 2px rgba(0,0,0,.2);
  --shadow: 0 1px 3px rgba(0,0,0,.25), 0 4px 16px rgba(0,0,0,.2);
  --shadow-lg: 0 8px 32px rgba(0,0,0,.35);
  --shadow-xl: 0 12px 48px rgba(0,0,0,.4);
}

/* ═══════════════════════════════════════
   BASE / RESET
   ═══════════════════════════════════════ */
* { box-sizing: border-box; }
html, body { height: 100%; overflow: hidden; }
body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  -webkit-font-smoothing: antialiased;
  font-size: 14px;
  line-height: 1.5;
}

/* ═══════════════════════════════════════
   LAYOUT
   ═══════════════════════════════════════ */
.app {
  max-width: 1220px;
  padding-bottom: 120px !important;
  height: calc(100dvh - 76px - env(safe-area-inset-bottom));
  overflow: hidden;
  margin: auto;
  padding: 16px 16px 8px;
}

/* ═══════════════════════════════════════
   TOP BAR
   ═══════════════════════════════════════ */
.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

/* ═══════════════════════════════════════
   TYPOGRAPHY
   ═══════════════════════════════════════ */
.k {
  font: 700 10px var(--mono);
  letter-spacing: .12em;
  color: var(--dim);
  text-transform: uppercase;
}
.title {
  font-size: 24px;
  font-weight: 700;
  letter-spacing: -.03em;
  margin: 2px 0 0;
  line-height: 1.2;
}
.sub {
  font-size: 13px;
  color: var(--muted);
  margin-top: 4px;
  line-height: 1.4;
}

/* ═══════════════════════════════════════
   BUTTONS
   ═══════════════════════════════════════ */
.btn {
  border: 0;
  background: var(--ink);
  color: var(--bg);
  border-radius: var(--radius);
  padding: 8px 14px;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: opacity .15s;
  line-height: 1.4;
}
.btn:hover { opacity: .88; }
.btn:active { opacity: .76; }
.btn.alt {
  background: var(--card);
  color: var(--text);
  border: 1px solid var(--line);
}
.btn.ghost {
  background: transparent;
  color: var(--muted);
  border: 1px solid var(--line);
}
.btn.ghost:hover { background: var(--soft); color: var(--text); }

/* ═══════════════════════════════════════
   CARDS
   ═══════════════════════════════════════ */
.card {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 20px;
  box-shadow: var(--shadow-sm);
}

/* ═══════════════════════════════════════
   VIEWS
   ═══════════════════════════════════════ */
.view { display: none; }
.view.active {
  display: block;
  height: calc(100dvh - 150px - env(safe-area-inset-bottom));
  overflow: hidden;
}
.view.active > .card,
.view.active > .grid,
.view.active > .checkGrid,
.view.active > .reflectionHero,
.view.active > .chatWrap {
  height: 100%;
  overflow: hidden;
}
.view.active main,
.view.active aside,
.sideStack,
.card { min-height: 0; }
.view.active main,
.view.active aside { overflow: auto; }
.view.active#chats { height: calc(100dvh - 160px - env(safe-area-inset-bottom)); }

/* ═══════════════════════════════════════
   GRID LAYOUTS
   ═══════════════════════════════════════ */
.grid { display: grid; grid-template-columns: 1fr 340px; gap: 16px; }
.row { display: flex; gap: 8px; align-items: center; }
.wrap { flex-wrap: wrap; }

/* ═══════════════════════════════════════
   FORM ELEMENTS
   ═══════════════════════════════════════ */
.input, select, textarea {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  border-radius: var(--radius);
  padding: 8px 12px;
  font: inherit;
  font-size: 13px;
  width: 100%;
  outline: none;
  transition: border-color .15s, box-shadow .15s;
}
.input:focus, select:focus, textarea:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(59,130,246,.12);
}
textarea { resize: vertical; }

/* ═══════════════════════════════════════
   FILTERS
   ═══════════════════════════════════════ */
.filters {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr auto;
  gap: 8px;
  margin: 16px 0;
}

/* ═══════════════════════════════════════
   TODO LIST
   ═══════════════════════════════════════ */
.todoList { display: grid; gap: 8px; }
.todo {
  display: grid;
  grid-template-columns: 42px 1fr auto auto;
  align-items: center;
  gap: 12px;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 56px;
  transition: box-shadow .15s, border-color .15s;
}
.todo:hover {
  border-color: color-mix(in srgb, var(--blue) 30%, var(--line));
  box-shadow: var(--shadow-sm);
}
.todo.dragging { opacity: .55; }
.rank {
  height: 100%;
  display: grid;
  place-items: center;
  background: var(--soft);
  font: 700 14px var(--mono);
  color: var(--muted);
  cursor: grab;
}
.rank:active { cursor: grabbing; }
.todoMain { min-width: 0; padding: 10px 0; }
.todoText {
  font-size: 14px;
  font-weight: 600;
  line-height: 1.3;
}
.todo.done .todoText {
  text-decoration: line-through;
  color: var(--muted);
}
.todoMeta { margin-top: 4px; display: flex; gap: 6px; flex-wrap: wrap; }

/* ═══════════════════════════════════════
   TAGS
   ═══════════════════════════════════════ */
.tag {
  font: 600 10px var(--mono);
  border: 1px solid var(--line);
  background: var(--soft);
  color: var(--muted);
  padding: 3px 8px;
  border-radius: 999px;
  letter-spacing: .02em;
}
.tag.high {
  color: var(--red);
  background: color-mix(in srgb, var(--red) 8%, var(--soft));
  border-color: color-mix(in srgb, var(--red) 20%, var(--line));
}
.tag.medium {
  color: var(--amber);
  background: color-mix(in srgb, var(--amber) 8%, var(--soft));
  border-color: color-mix(in srgb, var(--amber) 20%, var(--line));
}
.check {
  width: 24px;
  height: 24px;
  border-radius: var(--radius);
  border: 1.5px solid var(--line);
  background: var(--soft);
  cursor: pointer;
  transition: background .15s, border-color .15s;
}
.check.on {
  background: var(--green);
  border-color: var(--green);
}
/* Add checkmark when on */
.check.on::after {
  content: '✓';
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  line-height: 1;
}
.x {
  border: 0;
  background: transparent;
  color: var(--dim);
  font-size: 18px;
  padding: 12px;
  cursor: pointer;
  border-radius: var(--radius);
  transition: color .15s, background .15s;
  line-height: 1;
}
.x:hover { color: var(--red); background: color-mix(in srgb, var(--red) 6%, transparent); }

/* ═══════════════════════════════════════
   ADD BAR
   ═══════════════════════════════════════ */
.addBar {
  display: grid;
  grid-template-columns: 1fr 160px 120px auto;
  gap: 8px;
  margin-top: 16px;
}

/* ═══════════════════════════════════════
   SIDEBAR
   ═══════════════════════════════════════ */
.sideStack { display: grid; gap: 16px; }
.sideButtons { display: grid; gap: 6px; }
.sideButtons button {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  border-radius: var(--radius);
  padding: 10px 14px;
  text-align: left;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: background .12s, border-color .12s;
}
.sideButtons button:hover { background: var(--soft); }
.sideButtons button.active {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
}

/* ═══════════════════════════════════════
   STATS
   ═══════════════════════════════════════ */
.statGrid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
.stat {
  background: var(--soft);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 14px 16px;
  text-align: center;
}
.stat b { font-size: 22px; font-weight: 700; letter-spacing: -.02em; }
.stat span { display: block; color: var(--muted); font-size: 11px; margin-top: 2px; }

.metricGrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.metricCard {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 18px 20px;
  box-shadow: var(--shadow-sm);
}
.metricCard b { font-size: 26px; font-weight: 700; letter-spacing: -.03em; }
.metricCard span { display: block; color: var(--muted); font-size: 12px; margin-top: 4px; }

/* ═══════════════════════════════════════
   CHECK-IN
   ═══════════════════════════════════════ */
.checkGrid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.questionList { display: grid; gap: 10px; }
.q {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 14px 16px;
}
.q label { display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; }
.rangeRow { display: grid; grid-template-columns: 1fr 52px; gap: 10px; align-items: center; }
.rangeRow output {
  font: 700 16px var(--mono);
  text-align: center;
  background: var(--soft);
  border-radius: var(--radius);
  padding: 8px 4px;
}

/* ═══════════════════════════════════════
   CHARTS
   ═══════════════════════════════════════ */
.chartBox {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 16px;
}
.chartBox svg { width: 100%; height: 190px; display: block; }
.chartLine { fill: none; stroke: var(--ink); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
.chartArea { fill: color-mix(in srgb, var(--ink) 8%, transparent); }
.chartGrid { stroke: var(--line); stroke-width: 1; }
.chartText { fill: var(--muted); font: 600 9px var(--mono); }

.bars { display: grid; gap: 12px; }
.bar {
  height: 10px;
  background: var(--soft);
  border-radius: 999px;
  overflow: hidden;
  border: 1px solid var(--line);
}
.bar i {
  display: block;
  height: 100%;
  background: var(--ink);
  border-radius: 999px;
  transition: width .3s ease;
}

/* ═══════════════════════════════════════
   REFLECTION
   ═══════════════════════════════════════ */
.reflectionHero { display: grid; grid-template-columns: 1fr 280px; gap: 16px; }
.promptCard {
  border: 1px dashed var(--line);
  background: color-mix(in srgb, var(--soft) 50%, transparent);
  border-radius: var(--radius-lg);
  padding: 14px 16px;
  font-size: 13px;
}
.softNote { color: var(--muted); font-size: 13px; line-height: 1.5; }

/* ═══════════════════════════════════════
   SUGGESTIONS
   ═══════════════════════════════════════ */
.suggestionHead {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 16px 0 8px;
}
.suggestionList { display: grid; gap: 8px; }
.todo.suggested {
  border-style: dashed;
  background: color-mix(in srgb, var(--soft) 50%, transparent);
  opacity: .72;
  transition: opacity .15s;
}
.todo.suggested .rank { background: transparent; }
.todo.suggested .check {
  font-size: 18px;
  color: var(--muted);
  display: grid;
  place-items: center;
}
.todo.suggested:hover { opacity: 1; }

/* ═══════════════════════════════════════
   CHAT MESSAGES
   ═══════════════════════════════════════ */
.miniChat { display: grid; gap: 8px; }
.miniChat textarea { min-height: 94px; }
.msgList {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 0;
  max-height: 56vh;
  overflow: auto;
  padding: 16px;
  background: linear-gradient(180deg, color-mix(in srgb, var(--soft) 40%, transparent), transparent);
  border-radius: var(--radius-2xl);
  scroll-behavior: smooth;
}
.msg {
  max-width: min(76%, 720px);
  padding: 10px 14px;
  border: 0;
  background: var(--soft);
  white-space: normal;
  font-size: 13px;
  line-height: 1.5;
  box-shadow: 0 1px 0 rgba(0, 0, 0, .03);
  overflow-wrap: anywhere;
}
.msg.user {
  align-self: flex-end;
  background: #e8f0fe;
  border-radius: 18px 18px 6px 18px;
}
.msg.assistant,
.msg.system {
  align-self: flex-start;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 18px 18px 18px 6px;
}
.dark .msg.user { background: #1a2d4a; }
.dark .msg.assistant,
.dark .msg.system { background: var(--soft); }
.msg p { margin: 0 0 6px; }
.msg p:last-child { margin-bottom: 0; }
.msg ul,
.msg ol { margin: 6px 0 6px 20px; padding: 0; }
.msg li { margin: 3px 0; }
.msg code {
  font-family: var(--mono);
  font-size: 11px;
  background: var(--soft);
  border-radius: 4px;
  padding: 1px 5px;
}
.msg pre {
  white-space: pre-wrap;
  background: var(--soft);
  border-radius: var(--radius-lg);
  padding: 12px;
  overflow: auto;
  font-size: 12px;
}
.msgTime {
  display: block;
  text-align: right;
  margin-top: 4px;
  font-size: 10px;
  color: var(--dim);
}

/* ═══════════════════════════════════════
   STRUCTURED / VISUAL CONTENT
   ═══════════════════════════════════════ */
.structured { display: grid; gap: 8px; }
.sTabs {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 4px;
}
.sTabs button {
  border: 1px solid var(--line);
  background: var(--soft);
  color: var(--text);
  border-radius: 999px;
  padding: 4px 10px;
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  transition: background .12s;
}
.sTabs button:hover { background: var(--card); }
.sPanel {
  border: 1px solid var(--line);
  background: color-mix(in srgb, var(--soft) 40%, transparent);
  border-radius: var(--radius-lg);
  padding: 12px;
}
.vizBox {
  border: 1px solid var(--line);
  background: linear-gradient(135deg, color-mix(in srgb, var(--soft) 60%, transparent), transparent);
  border-radius: var(--radius-xl);
  padding: 14px;
  margin: 6px 0;
}
.vizBox h4 { margin: 0 0 8px; font-size: 13px; font-weight: 700; }
.vizSteps { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 8px; }
.vizStep {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: var(--radius);
  padding: 10px;
  font-size: 12px;
}

/* ═══════════════════════════════════════
   CHAT HISTORY SIDEBAR
   ═══════════════════════════════════════ */
.history { display: grid; grid-template-columns: 190px 1fr; gap: 12px; }
.histList {
  display: grid;
  gap: 4px;
  min-height: 0;
  max-height: none;
  overflow: auto;
}
.hist {
  padding: 9px 10px;
  border: 0;
  border-radius: var(--radius);
  background: transparent;
  text-align: left;
  color: var(--text);
  cursor: pointer;
  min-width: 0;
  transition: background .1s;
}
.hist:hover { background: var(--soft); }
.hist b {
  display: block;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.hist small {
  display: block;
  margin-top: 2px;
  color: var(--muted);
  font-size: 11px;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.hist.active {
  background: var(--soft);
  outline: 0;
  font-weight: 600;
}
.historyPane {
  padding: 12px;
  min-height: 0;
  overflow: hidden;
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
}
.chatHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 0 0 12px;
}
.chatTitle { min-width: 0; }
.chatTitle b {
  display: block;
  font-size: 15px;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.chatTitle span { font-size: 12px; color: var(--muted); }

/* ═══════════════════════════════════════
   PROJECTS
   ═══════════════════════════════════════ */
.projects { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
.project {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: var(--radius-xl);
  padding: 18px 20px;
  cursor: pointer;
  transition: box-shadow .15s, border-color .15s, transform .1s;
}
.project:hover {
  box-shadow: var(--shadow);
  border-color: color-mix(in srgb, var(--blue) 20%, var(--line));
  transform: translateY(-1px);
}
.project h3 { margin: 0 0 8px; font-size: 16px; font-weight: 700; }
.project p { color: var(--muted); font-size: 13px; line-height: 1.45; }

/* ═══════════════════════════════════════
   CONTENT SYSTEM
   ═══════════════════════════════════════ */
.contentTabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
.contentTabs button {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  border-radius: 999px;
  padding: 8px 16px;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: background .12s, color .12s;
}
.contentTabs button:hover { background: var(--soft); }
.contentTabs button.active { background: var(--ink); color: var(--bg); }
.contentPanel { display: none; }
.contentPanel.active { display: block; }
.contentMatrix { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; }
.personaCard,
.platformCard {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 14px 16px;
}
.personaCard h3,
.platformCard h3 { margin: 0 0 8px; font-size: 14px; font-weight: 700; }
.contentToolbar { display: flex; justify-content: space-between; gap: 8px; align-items: center; flex-wrap: wrap; }
.miniBoard { display: grid; grid-template-columns: repeat(4, minmax(170px, 1fr)); gap: 12px; overflow: auto; }
.enginePulse {
  border: 1px dashed var(--line);
  background: color-mix(in srgb, var(--soft) 50%, transparent);
  border-radius: var(--radius-xl);
  padding: 16px;
}
.planTextarea { min-height: 88px; }

/* ═══════════════════════════════════════
   KANBAN BOARD
   ═══════════════════════════════════════ */
.board { display: grid; grid-template-columns: repeat(4, minmax(200px, 1fr)); gap: 12px; overflow: auto; }
.col {
  background: var(--soft);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 12px;
  min-height: 220px;
}
.col h3 { font: 700 10px var(--mono); color: var(--dim); text-transform: uppercase; letter-spacing: .08em; }
.item {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 10px 12px;
  margin-bottom: 8px;
  font-size: 13px;
}

/* ═══════════════════════════════════════
   CRM
   ═══════════════════════════════════════ */
.crmShell {
  display: grid;
  grid-template-rows: auto auto auto minmax(0, 1fr);
  gap: 16px;
  height: 100%;
  overflow: hidden;
}
.crmStats {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}
.crmStats .stat {
  padding: 16px;
  border-radius: var(--radius-lg);
}

/* Stats color accents */
.crmStats .stat:first-child b { color: var(--ink); }
.crmStats .stat:nth-child(2) b { color: var(--blue); }
.crmStats .stat:nth-child(3) b { color: var(--green); }
.crmStats .stat:nth-child(4) b { color: var(--amber); }

.crmTableWrap {
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: var(--card);
}
.crmTable {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  min-width: 900px;
}
.crmTable th {
  position: sticky;
  top: 0;
  z-index: 1;
  background: var(--soft);
  font: 700 10px var(--mono);
  color: var(--dim);
  text-transform: uppercase;
  letter-spacing: .06em;
  text-align: left;
  padding: 10px 14px;
  border-bottom: 1px solid var(--line);
}
.crmTable td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--line);
  vertical-align: middle;
  font-size: 13px;
}
.crmTable tr:last-child td { border-bottom: 0; }
.crmTable tr:hover td { background: color-mix(in srgb, var(--soft) 40%, transparent); }
.crmStage {
  font: 700 9px var(--mono);
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 4px 8px;
  background: var(--soft);
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .04em;
}
.crmCellMain b { display: block; font-weight: 600; }
.crmCellMain small { display: block; color: var(--muted); margin-top: 2px; font-size: 11px; }
.crmBoard2 { display: grid; grid-template-columns: repeat(4, minmax(250px, 1fr)); gap: 12px; overflow: auto; min-height: 0; }
.crmCol {
  border: 1px solid var(--line);
  background: var(--soft);
  border-radius: var(--radius-lg);
  padding: 12px;
  min-height: 0;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
}
.crmCol h3 {
  font: 700 10px var(--mono);
  color: var(--dim);
  text-transform: uppercase;
  letter-spacing: .06em;
  margin: 0 0 10px;
  display: flex;
  justify-content: space-between;
}
.crmMiniTable { overflow: auto; }
.crmMiniTable table { width: 100%; border-collapse: collapse; }
.crmMiniTable td {
  font-size: 12px;
  padding: 8px 6px;
  border-top: 1px solid var(--line);
  vertical-align: top;
}
.crmMiniTable b { font-size: 13px; }
.crmMiniTable small { display: block; color: var(--muted); line-height: 1.3; font-size: 11px; }
.crmViewToggle button.active { background: var(--ink); color: var(--bg); }

/* ═══════════════════════════════════════
   CALENDAR
   ═══════════════════════════════════════ */
.calGrid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; overflow: hidden; min-width: 0; }
.day {
  min-height: 90px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--card);
  padding: 8px;
  min-width: 0;
  overflow: hidden;
  cursor: pointer;
  transition: border-color .15s;
}
.day:hover { border-color: var(--dim); }
.day.today {
  outline: 2px solid var(--ink);
  outline-offset: -1px;
}
.event {
  font-size: 10px;
  margin-top: 4px;
  background: var(--soft);
  border-radius: 6px;
  padding: 3px 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ═══════════════════════════════════════
   LOGS
   ═══════════════════════════════════════ */
.logs { display: grid; gap: 8px; max-height: 70vh; overflow: auto; }

/* ═══════════════════════════════════════
   BOTTOM NAV
   ═══════════════════════════════════════ */
.bottomNav {
  position: fixed;
  left: 50%;
  right: auto;
  bottom: calc(8px + env(safe-area-inset-bottom));
  z-index: 100;
  background: color-mix(in srgb, var(--card) 94%, transparent);
  border: 1px solid var(--line);
  border-radius: var(--radius-2xl);
  transform: translateX(-50%);
  width: min(1060px, calc(100vw - 24px));
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 4px;
  padding: 6px;
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}
.bottomNav button {
  border: 0;
  background: transparent;
  color: var(--muted);
  border-radius: var(--radius-lg);
  padding: 6px 2px;
  font-size: 10px;
  font-weight: 600;
  display: grid;
  gap: 1px;
  place-items: center;
  min-width: 0;
  min-height: 46px;
  transition: background .12s, color .12s;
}
.bottomNav button:hover {
  background: var(--soft);
  color: var(--text);
}
.bottomNav button span { min-width: 0; }
.bottomNav button span:last-child {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bottomNav button.active {
  background: var(--ink);
  color: var(--bg);
}
.bottomNav button span:first-child { font-size: 17px; }

/* ═══════════════════════════════════════
   FAB / SIDE PANEL
   ═══════════════════════════════════════ */
.fabPanel {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  min-height: 0;
  height: 100%;
}
.fabTab {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 28px;
  height: 48px;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: var(--card);
  box-shadow: var(--shadow);
  cursor: pointer;
  font-size: 15px;
  display: grid;
  place-items: center;
  transition: background .12s;
}
.fabTab:hover { background: var(--soft); }
.fabMsgs { min-height: 0; overflow: auto; margin: 6px 0 4px; padding: 10px; align-content: end; }
.fabComposer {
  border: 1px solid var(--line);
  border-radius: var(--radius-2xl);
  padding: 8px;
  background: var(--card);
  align-self: end;
}
.fabComposer textarea {
  border: 0;
  background: transparent;
  min-height: 54px;
  max-height: 120px;
  padding: 8px;
  font-size: 13px;
}
.iconRow { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
.iconRow .toolGroup { gap: 4px; }
.fab .msg { max-width: 88%; font-size: 13px; }
.fab {
  position: fixed;
  right: 0;
  top: 86px;
  bottom: calc(86px + env(safe-area-inset-bottom));
  z-index: 50;
  transition: transform .25s cubic-bezier(.4, 0, .2, 1);
  border: 1px solid var(--line);
  border-right: 0;
  background: var(--card);
  box-shadow: var(--shadow-lg);
  border-radius: var(--radius-2xl) 0 0 var(--radius-2xl);
  padding: 14px;
  width: min(390px, calc(100vw - 22px));
  display: grid;
  grid-template-rows: auto 1fr;
}
.fab.closed {
  transform: translateX(calc(100% - 28px));
  width: min(390px, calc(100vw - 22px));
}
.fab.closed .fabPanel { opacity: 0; pointer-events: none; }
.fabHead { display: flex; justify-content: space-between; align-items: center; gap: 8px; min-height: 36px; }
#fabTitle { min-width: 0; max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.fab textarea { resize: none; }
.fabHint { font-size: 12px; color: var(--muted); line-height: 1.4; }

/* ═══════════════════════════════════════
   CHAT WRAPPER
   ═══════════════════════════════════════ */
.chatWrap {
  display: grid;
  grid-template-columns: minmax(0, 190px) minmax(0, 1fr);
  gap: 12px;
  min-height: 0;
}
.chatWrap.collapsed { grid-template-columns: 44px 1fr; }
.chatWrap.collapsed .histList,
.chatWrap.collapsed .histTopText,
.chatWrap.collapsed .hist { display: none; }
.historyToggle { width: 100%; height: 36px; }
.chatCard {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  height: 100%;
  min-height: 0;
  padding: 16px;
  overflow: hidden;
}
.chatMeta { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }

/* ═══════════════════════════════════════
   COMPOSER
   ═══════════════════════════════════════ */
.composer2 {
  border: 1px solid var(--line);
  border-radius: var(--radius-2xl);
  background: var(--card);
  padding: 8px 10px 10px;
  box-shadow: var(--shadow-sm);
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  transition: border-color .15s, box-shadow .15s;
}
.composer2:focus-within {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(59, 130, 246, .1);
}
.composer2 textarea {
  border: 0;
  background: transparent;
  resize: none;
  min-height: 46px;
  max-height: 150px;
  padding: 8px;
  font-size: 13px;
}
.composer2 textarea:focus { box-shadow: none; }
.composerTools { display: flex; align-items: center; justify-content: space-between; gap: 8px; flex-wrap: wrap; padding: 0 4px 2px; }
.toolGroup { display: flex; gap: 6px; align-items: center; }
.imagePill { display: flex; align-items: center; gap: 6px; }
.imagePill img { width: 32px; height: 32px; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--line); }
.tiny { font-size: 12px; color: var(--muted); }

/* ═══════════════════════════════════════
   ACTION MENU
   ═══════════════════════════════════════ */
details.actions { position: relative; }
details.actions summary { list-style: none; cursor: pointer; }
details.actions summary::-webkit-details-marker { display: none; }
.actionMenu {
  position: absolute;
  bottom: 42px;
  left: 0;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: 6px;
  display: grid;
  gap: 2px;
  width: 190px;
  z-index: 5;
}
.actionMenu button {
  border: 0;
  background: transparent;
  text-align: left;
  border-radius: var(--radius);
  padding: 8px 10px;
  color: var(--text);
  font-size: 13px;
  cursor: pointer;
  transition: background .1s;
}
.actionMenu button:hover { background: var(--soft); }

/* ═══════════════════════════════════════
   FILE PILL / SKILLS
   ═══════════════════════════════════════ */
.filePill {
  font-size: 11px;
  background: var(--soft);
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 3px 8px;
  cursor: pointer;
}
.skillTray { display: flex; gap: 4px; flex-wrap: wrap; align-items: center; }
.skillChip {
  border: 1px solid var(--line);
  background: var(--soft);
  color: var(--text);
  border-radius: 999px;
  padding: 4px 9px;
  font: 600 10px var(--mono);
  cursor: pointer;
  transition: background .12s, color .12s;
}
.skillChip:hover { background: var(--card); }
.skillChip.on { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.skillPop {
  position: absolute;
  left: 8px;
  right: 8px;
  bottom: 88px;
  max-height: 260px;
  overflow: auto;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  padding: 8px;
  z-index: 8;
  display: none;
}
.skillPop.open { display: grid; gap: 4px; }
.skillOpt {
  border: 0;
  background: transparent;
  color: var(--text);
  text-align: left;
  border-radius: var(--radius);
  padding: 8px 10px;
  cursor: pointer;
  transition: background .1s;
}
.skillOpt:hover,
.skillOpt.active { background: var(--soft); }
.skillOpt b { display: block; font-size: 13px; }
.skillOpt small { display: block; color: var(--muted); line-height: 1.3; margin-top: 2px; font-size: 11px; }
.skillGrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 12px; overflow: auto; max-height: 100%; }
.skillCard {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: var(--radius-xl);
  padding: 16px;
  transition: box-shadow .15s;
}
.skillCard:hover { box-shadow: var(--shadow-sm); }
.skillCard h3 { margin: 0 0 8px; font-size: 14px; font-weight: 700; }
.skillCard p { color: var(--muted); font-size: 12px; line-height: 1.4; max-height: 70px; overflow: hidden; }

/* ═══════════════════════════════════════
   PROJECT SELECT
   ═══════════════════════════════════════ */
.projectSelect { max-width: 170px; }

/* ═══════════════════════════════════════
   TOP MINIMAL / CHAT MODE
   ═══════════════════════════════════════ */
.top.minimal { margin-bottom: 12px; }
.top.minimal .sub,
.top.minimal .k { display: none; }
.top.minimal .title { font-size: 20px; }
body.chatMode .top { display: none; }
body.chatMode .app {
  padding-top: 12px;
  max-width: 1120px;
  height: calc(100dvh - 76px - env(safe-area-inset-bottom));
}
.chatCard .msgList { height: 100%; max-height: none; min-height: 0; }

/* ═══════════════════════════════════════
   MODE POPUP
   ═══════════════════════════════════════ */
.modePop {
  position: absolute;
  right: 8px;
  bottom: 88px;
  width: min(360px, calc(100vw - 28px));
  max-height: 300px;
  overflow: auto;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  padding: 8px;
  z-index: 9;
  display: none;
}
.modePop.open { display: grid; gap: 4px; }
.modeOpt {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  text-align: left;
  border-radius: var(--radius-lg);
  padding: 10px 12px;
  cursor: pointer;
  transition: background .1s;
}
.modeOpt:hover { background: var(--soft); }
.modeOpt.active {
  background: linear-gradient(135deg, color-mix(in srgb, var(--blue) 12%, var(--card)), color-mix(in srgb, var(--green) 8%, var(--card)));
  border-color: color-mix(in srgb, var(--blue) 30%, var(--line));
}
.modeOpt b { display: block; font-size: 13px; }
.modeOpt small { display: block; color: var(--muted); line-height: 1.3; margin-top: 2px; font-size: 11px; }
.modeHint {
  font: 600 9px var(--mono);
  letter-spacing: .06em;
  color: var(--dim);
  text-transform: uppercase;
  padding: 4px;
}

/* ═══════════════════════════════════════
   SETTINGS POPUP
   ═══════════════════════════════════════ */
.settingsPop {
  position: fixed;
  left: 50%;
  bottom: calc(84px + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  width: min(220px, calc(100vw - 24px));
  max-height: 240px;
  overflow: hidden;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  padding: 6px;
  z-index: 120;
  display: none;
}
.settingsPop.open { display: grid; gap: 4px; }
.settingsOpt {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  text-align: left;
  border-radius: var(--radius);
  padding: 10px 12px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: background .1s;
}
.settingsOpt:hover { background: var(--soft); }
.settingsOpt .stIcon { font-size: 16px; width: 22px; text-align: center; }

/* ═══════════════════════════════════════
   MIND MAP
   ═══════════════════════════════════════ */
.mindMapShell { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 16px; height: 100%; }
.mindMapFrame { width: 100%; height: 100%; border: 1px solid var(--line); border-radius: var(--radius-2xl); background: var(--card); }
.mindMapPanel { display: grid; gap: 12px; align-content: start; }

/* ═══════════════════════════════════════
   MESSAGE FORMATTING
   ═══════════════════════════════════════ */
.msg h1,
.msg h2,
.msg h3 { margin: 8px 0 6px; line-height: 1.2; }
.msg h1 { font-size: 18px; }
.msg h2 { font-size: 16px; }
.msg h3 { font-size: 14px; }
.msg blockquote {
  margin: 8px 0;
  padding: 8px 14px;
  border-left: 3px solid var(--ink);
  background: var(--soft);
  border-radius: var(--radius);
  font-size: 13px;
}
.msg table {
  border-collapse: separate;
  border-spacing: 0;
  width: 100%;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  font-size: 12px;
}
.msg th,
.msg td { border-bottom: 1px solid var(--line); padding: 8px 10px; text-align: left; }
.msg th { background: var(--soft); font-weight: 700; font-size: 11px; }
.msg tr:last-child td { border-bottom: 0; }

/* ═══════════════════════════════════════
   VIZ CANVAS
   ═══════════════════════════════════════ */
.vizCanvas {
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 12px;
  background: radial-gradient(circle at 10% 10%, rgba(59, 130, 246, .1), transparent 28%),
    radial-gradient(circle at 90% 20%, rgba(5, 150, 105, .08), transparent 26%),
    linear-gradient(135deg, color-mix(in srgb, var(--soft) 60%, transparent), transparent);
  margin: 6px 0;
}
.vizCanvas svg { width: 100%; height: auto; display: block; }
.vizNode { filter: drop-shadow(0 6px 14px rgba(0, 0, 0, .08)); }

/* ═══════════════════════════════════════
   CODING MODE
   ═══════════════════════════════════════ */
.codingMode .chatCard {
  position: relative;
  background: linear-gradient(180deg, #0a0f0a 0%, #0d130d 40%, #0a100a 100%);
  border-color: #1a3a1a;
}
.codingMode .card.chatCard::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 255, 65, .015) 2px, rgba(0, 255, 65, .015) 4px);
  pointer-events: none;
  z-index: 0;
  border-radius: var(--radius-xl);
}
.codingMode .chatCard .msgList,
.codingMode .chatCard .composer2,
.codingMode .chatCard .chatHeader { position: relative; z-index: 1; }
.codingMode .msg.user { background: #0d2a0d; color: #a0ffa0; border: 1px solid #1a4a1a; }
.codingMode .msg.assistant,
.codingMode .msg.system { background: #0a120a; border: 1px solid #1a3a1a; color: #b0ffb0; }
.codingMode .composer2 { background: #0a120a; border-color: #1a3a1a; }
.codingMode .composer2 textarea { color: #00ff41; }
.codingMode .chatCard .chatHeader { color: #00ff41; }

/* ═══════════════════════════════════════
   TIMELINE / TIMETABLE
   ═══════════════════════════════════════ */
.timeline { position: relative; min-height: 600px; padding-left: 50px; }
.timelineHour {
  position: absolute;
  left: 0;
  width: 44px;
  text-align: right;
  font: 600 10px var(--mono);
  color: var(--dim);
  transform: translateY(-7px);
}
.timelineLine {
  position: absolute;
  left: 48px;
  right: 8px;
  height: 1px;
  background: var(--line);
  transform: translateY(-.5px);
}
.timetableBlock {
  position: absolute;
  left: 54px;
  right: 8px;
  border-radius: var(--radius);
  padding: 8px 10px;
  overflow: hidden;
  font-size: 13px;
  line-height: 1.3;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 28px;
}
.timetableBlock.meeting {
  background: color-mix(in srgb, var(--blue) 14%, var(--soft));
  border: 1px solid color-mix(in srgb, var(--blue) 25%, var(--line));
}
.timetableBlock.task { background: var(--card); border: 1px solid var(--line); cursor: pointer; }
.timetableBlock.task.high { border-left: 3px solid var(--red); }
.timetableBlock.task.medium { border-left: 3px solid var(--amber); }
.timetableBlock.task.low { border-left: 3px solid var(--green); }
.timetableBlock .tbTitle { font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.timetableBlock .tbTime {
  font-size: 10px;
  color: var(--muted);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.timetableConfig { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.timetableConfig label { font: 700 10px var(--mono); color: var(--dim); text-transform: uppercase; }
.timetableConfig input,
.timetableConfig select {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  border-radius: var(--radius);
  padding: 7px 9px;
  font: inherit;
  width: 100%;
}
.overflowTasks { display: grid; gap: 6px; max-height: 200px; overflow: auto; }
.overflowTask {
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--soft);
  font-size: 13px;
  overflow: hidden;
}
.overflowTask b { display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.overflowTask .tiny { display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.timelineWrap { position: relative; overflow: auto; max-height: calc(100vh - 320px); }

/* ═══════════════════════════════════════
   TOAST OVERLAY
   ═══════════════════════════════════════ */
.toastOverlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, .55);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
.toastBox {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 24px;
  max-width: 380px;
  width: 90%;
  box-shadow: var(--shadow-xl);
  text-align: center;
}
.toastBox h3 { margin: 0 0 8px; font-size: 16px; }
.toastBox p { color: var(--muted); font-size: 14px; line-height: 1.5; margin: 0 0 18px; }
.toastBox .toastBtns { display: flex; gap: 8px; justify-content: center; }
.toastBox button { padding: 10px 22px; border-radius: var(--radius); font-weight: 600; cursor: pointer; border: 0; font-size: 13px; }
.toastYes { background: var(--ink); color: var(--bg); }
.toastNo { background: var(--soft); color: var(--text); border: 1px solid var(--line) !important; }

/* ═══════════════════════════════════════
   PROJECT DETAIL
   ═══════════════════════════════════════ */
.projDetail { display: grid; grid-template-rows: auto auto auto auto; gap: 16px; height: 100%; overflow: auto; padding-bottom: 40px; }
.projHeader { display: grid; grid-template-columns: auto 1fr auto; gap: 12px; align-items: center; }
.projHeader .backBtn {
  border: 1px solid var(--line);
  background: var(--card);
  color: var(--text);
  border-radius: var(--radius);
  padding: 8px 14px;
  cursor: pointer;
  font-size: 16px;
  font-weight: 600;
  transition: background .1s;
}
.projHeader .backBtn:hover { background: var(--soft); }
.projName { font-size: 24px; font-weight: 700; letter-spacing: -.025em; margin: 0; }
.projLane { font-size: 13px; color: var(--muted); margin-top: 3px; }
.projHealth { font: 600 9px var(--mono); text-transform: uppercase; padding: 4px 10px; border-radius: 999px; letter-spacing: .04em; }
.projHealth.green { background: color-mix(in srgb, var(--green) 14%, transparent); color: var(--green); }
.projHealth.amber { background: color-mix(in srgb, var(--amber) 14%, transparent); color: var(--amber); }
.projHealth.red { background: color-mix(in srgb, var(--red) 14%, transparent); color: var(--red); }
.projHealth.gray { background: var(--soft); color: var(--dim); }
.projStatRow { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; }
.projStat {
  background: var(--soft);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 14px;
  text-align: center;
}
.projStat b { font-size: 20px; display: block; font-weight: 700; }
.projStat span { font-size: 11px; color: var(--muted); display: block; margin-top: 3px; }
.projGrid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.projPanel {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: var(--radius-xl);
  padding: 16px;
  min-height: 0;
}
.projPanel h3 { font: 700 10px var(--mono); color: var(--dim); text-transform: uppercase; letter-spacing: .06em; margin: 0 0 12px; }
.projTodo {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 8px;
  align-items: center;
  padding: 8px 10px;
  border-radius: var(--radius);
  margin-bottom: 4px;
  transition: background .1s;
}
.projTodo:hover { background: var(--soft); }
.projTodo .check { width: 22px; height: 22px; }
.projChatRow {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 6px;
  align-items: center;
  padding: 8px 10px;
  border-radius: var(--radius);
  cursor: pointer;
  margin-bottom: 2px;
  transition: background .1s;
}
.projChatRow:hover { background: var(--soft); }
.projChatRow b { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.projChatRow small { font-size: 11px; color: var(--muted); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.projChatRow .tag { font-size: 9px; }
.projEmpty { color: var(--dim); font-size: 12px; text-align: center; padding: 24px; }
.projDesc { font-size: 13px; color: var(--muted); line-height: 1.5; margin: 4px 0 0; }
.projTagRow { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
.projActionRow { display: flex; gap: 8px; flex-wrap: wrap; }

/* ═══════════════════════════════════════
   MOBILE (max-width: 850px)
   ═══════════════════════════════════════ */
@media(max-width:850px) {
  .fab { z-index: 50 !important; }
  .bottomNav { z-index: 100 !important; width: 100vw; border-radius: 0; bottom: 0; }

  /* App container */
  .app {
    height: calc(100dvh - 70px - env(safe-area-inset-bottom));
    padding: 12px 12px 8px;
    padding-bottom: 120px !important;
  }
  .view.active#chats { height: calc(100dvh - 180px - env(safe-area-inset-bottom)); }

  /* Mobile bottom nav */
  .bottomNav {
    width: calc(100vw - 10px);
    bottom: calc(4px + env(safe-area-inset-bottom));
    padding: 5px 4px;
    gap: 2px;
    border-radius: var(--radius-2xl);
    overflow-x: auto;
    grid-template-columns: repeat(7, minmax(48px, 1fr));
    box-shadow: 0 -2px 16px rgba(0, 0, 0, .06);
    -webkit-overflow-scrolling: touch;
  }
  .bottomNav button {
    font-size: 9px;
    min-height: 42px;
    padding: 5px 1px;
    border-radius: var(--radius);
  }
  .bottomNav button span:first-child { font-size: 15px; }

  /* Cards */
  .card { padding: 14px; border-radius: var(--radius-lg); }

  /* Top bar */
  .top { align-items: flex-start; }
  .title { font-size: 20px; }

  /* Grid layouts collapse */
  .grid,
  .history,
  .chatWrap {
    grid-template-columns: 1fr;
  }

  /* Chat */
  .historyPane { display: none; }
  .chatCard {
    height: 100%;
    min-height: 0;
    border-radius: 0;
    border-left: 0;
    border-right: 0;
    padding: 12px;
  }
  .chatCard .msgList { height: 100%; max-height: none; min-height: 0; padding: 12px; }
  .msg { max-width: 88%; font-size: 13px; }
  .chatHeader { padding-bottom: 10px; }

  /* Sidebar moves up */
  .sideStack { order: -1; }

  /* Filters */
  .filters { grid-template-columns: 1fr 1fr; }
  .addBar { grid-template-columns: 1fr; }

  /* Todo items */
  .todo { grid-template-columns: 36px 1fr auto; }
  .todo .x { display: none; }

  /* Projects */
  .projects { grid-template-columns: 1fr; }
  .project { padding: 16px; }

  /* Board */
  .board { grid-template-columns: repeat(4, 82vw); }

  /* FAB */
  .fab {
    top: auto;
    left: 8px;
    right: 8px;
    bottom: calc(74px + env(safe-area-inset-bottom));
    width: auto;
    max-height: 62vh;
    border: 1px solid var(--line);
    border-radius: var(--radius-2xl);
    padding: 12px;
  }
  .fab.closed { transform: translateY(calc(100% - 44px)); width: auto; }
  .fab textarea { min-height: 70px; }
  .fabTab {
    left: 50%;
    top: 0;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 36px;
    border-radius: var(--radius);
  }

  /* Stats */
  .statGrid { grid-template-columns: repeat(4, 1fr); }
  .stat {
    padding: 10px;
    border-radius: var(--radius);
  }
  .stat b { font-size: 17px; }

  /* Metrics */
  .metricGrid,
  .checkGrid,
  .reflectionHero { grid-template-columns: 1fr; }
  .metricGrid { gap: 10px; }
  .metricCard { padding: 14px; }
  .metricCard b { font-size: 22px; }

  /* CRM */
  .crmStats { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }
  .crmStats .stat { padding: 12px 8px; }

  /* Subtitle */
  .sub { display: none; }

  /* Composer */
  .composerTools { display: grid; grid-template-columns: 1fr; }
  .toolGroup { flex-wrap: wrap; }
  .projectSelect { max-width: none; flex: 1; min-width: 140px; }

  /* Settings */
  .settingsPop { bottom: calc(76px + env(safe-area-inset-bottom)); }

  /* Mind map */
  .mindMapShell { grid-template-columns: 1fr; }
  .mindMapPanel { display: none; }

  /* Project detail */
  .projGrid { grid-template-columns: 1fr; }
  .projHeader { grid-template-columns: auto 1fr; }
  .projHeader .projActionRow { grid-column: 1 / -1; }
  .projStatRow { grid-template-columns: repeat(3, 1fr); }

  /* Sidebar */
  .sideStack { display: grid; gap: 12px; }
}
</style></head><body><div class="app"><div class="top minimal"><div><div class="k">Amir Dashboard · calm execution</div><h1 class="title" id="pageTitle">To-do</h1><div class="sub" id="pageSub">Clear actions. Drag to reorder.</div></div><div class="row"><button class="btn alt" onclick="toggleTheme()">☀︎/☾</button><button class="btn" onclick="toggleFab()">⚡</button></div></div>
<section class="view active" id="todo"><div class="grid"><main class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Priority queue</div><h2 style="margin:3px 0 0">Today</h2></div><button class="btn alt" onclick="suggestTodos(true)">Refresh AI</button></div><div class="filters"><select id="fProject" onchange="renderTodos()"><option value="">All projects</option></select><select id="fPriority" onchange="renderTodos()"><option value="">All priorities</option><option value="high">High</option><option value="medium">Medium</option><option value="low">Low</option></select><select id="fType" onchange="renderTodos()"><option value="">All actions</option><option value="outreach">Outreach</option><option value="strategy">Strategy</option><option value="build">Build</option><option value="admin">Admin</option></select><button class="btn ghost" onclick="clearDone()">Clear done</button></div><div class="todoList" id="todoList"></div><div class="suggestionHead"><div><div class="k">Kaneki suggestions</div><span class="tiny">Grey = suggested. Tap + to commit.</span></div></div><div class="suggestionList" id="suggestions"></div><div class="addBar"><input class="input" id="todoText" placeholder="Add a clear action…"><select id="todoProject"></select><select id="todoPriority"><option value="high">High</option><option value="medium" selected>Medium</option><option value="low">Low</option></select><button class="btn" onclick="addTodo()">Add</button></div></main><aside class="sideStack"><div class="card"><div class="k">Today tools</div><div class="sideButtons" style="margin-top:10px"><button onclick="setTodaySub('queue')" data-sub="queue">✓ Queue</button><button onclick="setTodaySub('checkin')" data-sub="checkin">◉ Check-in</button><button onclick="setTodaySub('stats')" data-sub="stats">▥ Stats</button><button onclick="setTodaySub('reflect')" data-sub="reflect">☾ Reflect</button><button onclick="setTodaySub('mindmap')" data-sub="mindmap">🧠 Mind map</button><button onclick="setTodaySub('timetable')" data-sub="timetable">⏱ Timetable</button></div></div><div class="card"><div class="k">Snapshot</div><div class="statGrid" style="margin-top:10px"><div class="stat"><b id="sOpen">0</b><span>open</span></div><div class="stat"><b id="sHigh">0</b><span>high</span></div><div class="stat"><b id="sDone">0</b><span>done</span></div><div class="stat"><b id="sMin">0</b><span>mins</span></div></div></div></aside></div></section>
<section class="view todaySub" id="checkin"><div class="checkGrid"><main class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Productivity check-in</div><h2 style="margin:3px 0 0">Score the day</h2><div class="softNote">Fast inputs. No overthinking. Build the feedback loop.</div></div><button class="btn ghost" onclick="openSideFor('productivity check-in')">⚡</button></div><div class="questionList" style="margin-top:14px"><div class="q"><label>MMR movement</label><div class="rangeRow"><input id="mmrDelta" type="range" min="-50" max="50" value="0" oninput="mmrOut.value=this.value"><output id="mmrOut">0</output></div></div><div class="q"><label>Deep work hours</label><input class="input" id="workHours" type="number" min="0" max="18" step="0.25" placeholder="0"></div><div class="q"><label>Daily rating</label><div class="rangeRow"><input id="dayRating" type="range" min="1" max="10" value="7" oninput="ratingOut.value=this.value"><output id="ratingOut">7</output></div></div><div class="q"><label>Energy</label><div class="rangeRow"><input id="energyRating" type="range" min="1" max="10" value="7" oninput="energyOut.value=this.value"><output id="energyOut">7</output></div></div><div class="q"><label>What actually moved forward?</label><textarea id="movedForward" class="input" placeholder="Evidence, not vibes…"></textarea></div><button class="btn" onclick="saveCheckin()">Save check-in</button></div></main><aside class="card"><div class="k">Relevant prompts</div><div class="questionList" style="margin-top:12px" id="checkinPrompts"></div></aside></div></section>
<section class="view todaySub" id="stats"><div class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Stats</div><h2>MMR / hours / ratings</h2></div><button class="btn ghost" onclick="openSideFor('stats review')">⚡</button></div><div class="metricGrid" style="margin-top:14px"><div class="metricCard"><b id="statMmr">1000</b><span>current MMR</span></div><div class="metricCard"><b id="statHours">0</b><span>7d work hours</span></div><div class="metricCard"><b id="statRating">—</b><span>avg daily rating</span></div><div class="metricCard"><b id="statStreak">0</b><span>check-in streak</span></div></div><div id="statChart" style="margin-top:18px"></div><div class="bars" id="statBars" style="margin-top:18px"></div></div></section>
<section class="view todaySub" id="reflect"><div class="reflectionHero"><main class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Reflection / wind-down</div><h2>Close the loop</h2><div class="softNote">Answer what matters. Kaneki can challenge you from the side tab.</div></div><button class="btn ghost" onclick="openAlterEgo()">⚡</button></div><div class="questionList" style="margin-top:14px"><div class="q"><label>How well did you work today — honestly?</label><textarea id="reflectWorked" class="input" placeholder="What would a strict coach say?"></textarea></div><div class="q"><label>What distracted you?</label><textarea id="reflectDistracted" class="input" placeholder="Name the leak."></textarea></div><div class="q"><label>What is tomorrow’s one win?</label><textarea id="reflectTomorrow" class="input" placeholder="One outcome. Not ten."></textarea></div><div class="q"><label>Wind-down command</label><textarea id="reflectWind" class="input" placeholder="What do you need to shut down cleanly?"></textarea></div><button class="btn" onclick="saveReflection()">Save reflection</button></div></main><aside class="card"><div class="k">Project RAG</div><h3>Alter ego room</h3><p class="softNote">A dedicated space to talk things out, juggle ideas, and get pushed without turning the main dashboard into noise.</p><button class="btn alt" onclick="openAlterEgo()">Open side tab</button><div id="reflectionLast" class="logs" style="margin-top:12px"></div></aside></div></section>
<section class="view todaySub" id="mindmap"><div class="card"><div class="mindMapShell"><div style="position:relative; width:100%; height:100%;"><iframe class="mindMapFrame" src="http://100.111.98.27:4444/" title="RAGmind Mind Map" style="width:100%; height:100%; border:0;"></iframe><div style="position:absolute; bottom:10px; right:10px; font-size:10px; color:var(--muted); pointer-events:none;">Mindmap requires port 4444 to be accessible</div></div><aside class="mindMapPanel"><div><div class="k">Embedded RAGmind</div><h2>Mind map</h2><p class="softNote">Use the side chat while the map stays open. Ask Kaneki to suggest edits, expansions, links, or research branches in real time.</p></div><button class="btn ghost" onclick="setTodaySub('queue')">← Today queue</button><button class="btn" onclick="openSideFor('mind map live editing')">Suggest changes</button><button class="btn ghost" onclick="window.open('http://100.111.98.27:4444/','_blank')">Open full page</button><div class="promptCard">Try: “Add a branch for Grademy GTM”, “visualize this as a colorful system map”, or “deep research this node.”</div></aside></div></div></section>
<section class="view todaySub" id="timetable"><div class="reflectionHero"><main class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Smart scheduler</div><h2>Timetable</h2><div class="softNote">Motion-style auto-scheduling. Tasks placed around meetings.</div></div><div class="row"><button class="btn alt" onclick="openTimetableConfig()">⚙</button><button class="btn" onclick="generateTimetable()">Schedule day</button></div></div><div class="timelineWrap" id="timelineWrap"><div class="timeline" id="timeline"></div></div><div class="metricGrid" style="margin-top:8px"><div class="metricCard"><b id="ttScheduled">0</b><span>tasks scheduled</span></div><div class="metricCard"><b id="ttOverflow">0</b><span>overflow</span></div><div class="metricCard"><b id="ttHours">0h</b><span>planned hours</span></div><div class="metricCard"><b id="ttMeetings">0</b><span>meetings</span></div></div></main><aside class="sideStack"><div class="card" id="ttConfigCard" style="display:none"><div class="row" style="justify-content:space-between"><div class="k">Preferences</div><button class="btn ghost" onclick="saveTimetableConfig()">Save</button></div><div class="timetableConfig" style="margin-top:10px"><label>Work start<input type="time" id="ttWorkStart" value="08:00"></label><label>Work end<input type="time" id="ttWorkEnd" value="18:00"></label><label>Buffer (min)<input type="number" id="ttBuffer" value="10" min="0" max="30"></label><label>Max focus block (min)<input type="number" id="ttMaxBlock" value="90" min="15" max="240"></label><label>Break at<input type="time" id="ttBreakAt" value="12:30"></label><label>Break duration (min)<input type="number" id="ttBreakMin" value="30" min="0" max="120"></label></div><label style="margin-top:8px;display:flex;align-items:center;gap:6px"><input type="checkbox" id="ttPreferMorning" checked> Prefer morning slots</label></div><div class="card"><div class="k">Unplaced tasks</div><h3>Overflow</h3><div class="overflowTasks" id="overflowList"><div class="softNote">Tasks that didn't fit. Try rescheduling or adjusting preferences.</div></div></div><div class="card"><div class="k">Quick actions</div><div class="sideButtons" style="margin-top:10px"><button onclick="openSideFor('timetable: review and optimize my schedule')">⚡ Review schedule</button><button onclick="syncCalendar();setTimeout(generateTimetable,1500)">↻ Sync calendar</button></div></div></aside></div></section>
<section class="view" id="chats"><div class="chatWrap" id="chatWrap"><aside class="card historyPane"><button class="btn ghost historyToggle" onclick="toggleHistory()">☰</button><div class="histTopText" style="margin:8px 0;display:grid;gap:8px"><button class="btn alt" onclick="newChat()">+ Chat</button><select class="input" id="chatProjectFilter" onchange="chatFilter=this.value;renderChatList()"><option value="">All projects</option></select></div><div class="histList" id="histList"></div></aside><main class="card chatCard"><div class="chatHeader"><div class="chatTitle"><b id="chatTitle">Kaneki</b><span id="chatSub">Clean thread</span></div><button class="btn ghost" onclick="exportChat()" title="Copy entire chat to clipboard">⎙ Export</button><button class="btn ghost" onclick="newChat()">+ New</button></div><div class="msgList" id="msgList"></div><div class="composer2"><textarea id="chatInput" placeholder="Message Kaneki… paste images too"></textarea><div class="chatMeta" id="fileList"></div><div class="composerTools"><div class="toolGroup"><button class="btn ghost" title="Attach" onclick="pickFile()">＋</button><input id="fileInput" type="file" multiple accept="image/*,.txt,.md,.csv,.json,.pdf" style="display:none" onchange="handleFiles(this.files)"><select class="input projectSelect" id="composerProject" onchange="composerProjectChanged()"><option value="">◇</option></select><button class="btn ghost" title="Skills" onclick="toggleSkillPop('skillPop')">✧</button></div><div class="skillTray" id="skillTray"></div><div class="skillPop" id="skillPop"></div><div class="modePop" id="modePop"></div><div class="toolGroup"><button class="btn ghost" id="actionLabel" title="Modes: auto-listening stays on" onclick="toggleModePop('modePop')">Modes</button><button class="btn" title="Send" onclick="sendChat()">➤</button></div></div></div></main></div></section><section class="view" id="projects"><div class="projects" id="projectsGrid"></div></section>
<section class="view" id="project-detail"><div class="projDetail" id="projDetail"><div class="card projHeader"><button class="backBtn" onclick="show('projects')">←</button><div><h2 class="projName" id="pdName">—</h2><div class="projLane" id="pdLane">—</div><div class="projDesc" id="pdDesc"></div><div class="projTagRow" id="pdTags"></div></div><div class="projActionRow"><button class="btn" id="pdChatBtn" onclick="startProjectFromDetail()">💬 Chat</button><button class="btn alt" id="pdResumeBtn" onclick="resumeLatestChat()" style="display:none">↻ Resume</button></div></div><div class="projStatRow" id="pdStats"></div><div class="projGrid"><div class="projPanel"><h3>Open to-dos</h3><div id="pdTodos"><div class="projEmpty">No open tasks for this project.</div></div></div><div class="projPanel"><h3>Recent chats</h3><div id="pdChats"><div class="projEmpty">No chats for this project yet.</div></div></div></div></div></section>
<section class="view" id="calendar"><div class="grid"><main class="card"><div class="row" style="justify-content:space-between"><button class="btn alt" onclick="moveMonth(-1)">←</button><h2 id="monthLabel"></h2><button class="btn alt" onclick="moveMonth(1)">→</button></div><div class="calGrid" id="calGrid"></div></main><aside class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Selected</div><h2 id="selectedDay"></h2></div><div class="toolGroup"><button class="btn ghost" title="Discuss selected day" onclick="openSideFor('calendar')">⚡</button><button class="btn alt" onclick="syncCalendar()">↻</button></div></div><div class="logs" id="dayEvents"></div></aside></div></section>
<section class="view" id="content"><div class="card"><div class="contentToolbar"><div><div class="k">Content system</div><h2>Planner + engine monitor</h2><div class="softNote">Mass distribution engine on one side. Personal content plan on the other.</div></div><div class="toolGroup"><button class="btn ghost" onclick="openSideFor('content engine and personal content plan')">⚡</button><button class="btn alt" onclick="addContent()">＋</button></div></div><div class="contentTabs" style="margin-top:14px"><button data-content-tab="engine" onclick="setContentTab('engine')">Engine portal</button><button data-content-tab="personal" onclick="setContentTab('personal')">Personal plan</button></div><div class="contentPanel active" id="content-engine"><div class="grid"><main><div class="metricGrid"><div class="metricCard"><b id="contentPostCount">0</b><span>content items</span></div><div class="metricCard"><b id="contentAcctCount">0</b><span>accounts</span></div><div class="metricCard"><b id="contentPersonaCount">0</b><span>personas</span></div><div class="metricCard"><b id="contentPlatformCount">0</b><span>platforms</span></div></div><div class="enginePulse" style="margin-top:12px"><div class="k">AI engine status</div><h3 id="engineFocus">—</h3><p class="softNote" id="engineThought"></p><div class="row wrap" id="engineBacklog" style="margin-top:8px"></div></div><h3>Distribution pipeline</h3><div class="miniBoard" id="contentBoard"></div></main><aside><div class="card"><div class="row" style="justify-content:space-between"><div class="k">Accounts</div><button class="btn ghost" onclick="addContentAccount()">＋</button></div><div id="contentAccounts" class="logs" style="margin-top:10px"></div></div></aside></div></div><div class="contentPanel" id="content-personal"><div class="grid"><main><div class="card"><div class="row" style="justify-content:space-between"><div><div class="k">Personal content plan</div><h2>Mission / theme / notes</h2></div><button class="btn ghost" onclick="saveContentPlan()">Save</button></div><textarea id="planMission" class="input planTextarea" placeholder="Mission"></textarea><textarea id="planTheme" class="input planTextarea" placeholder="Weekly theme" style="margin-top:8px"></textarea><textarea id="planNotes" class="input planTextarea" placeholder="Notes / guardrails" style="margin-top:8px"></textarea></div><h3>Personas</h3><div class="contentMatrix" id="personaGrid"></div><button class="btn alt" onclick="addPersona()" style="margin-top:10px">＋ Persona</button></main><aside><div class="card"><div class="k">Platforms</div><div class="contentMatrix" id="platformGrid" style="margin-top:10px"></div><button class="btn alt" onclick="addPlatform()" style="margin-top:10px">＋ Platform</button></div></aside></div></div></div></section><section class="view" id="crm"><div class="card crmShell"><div class="row" style="justify-content:space-between;align-items:flex-start"><div><div class="k">CRM pipeline</div><h2>Lead tracker</h2><div class="softNote">Table-first tracking with optional kanban columns by stage.</div></div><div class="toolGroup crmViewToggle"><button class="btn ghost" id="crmTableBtn" onclick="setCrmView('table')">Table</button><button class="btn ghost" id="crmKanbanBtn" onclick="setCrmView('kanban')">Kanban</button><button class="btn alt" onclick="addLead()">+ Lead</button></div></div><div class="crmStats"><div class="stat"><b id="crmTotal">0</b><span>Total leads</span></div><div class="stat"><b id="crmReplied">0</b><span>Replied+</span></div><div class="stat"><b id="crmBooked">0</b><span>Booked/Won</span></div><div class="stat"><b id="crmValue">€0</b><span>Pipeline value</span></div></div><div class="filters" style="margin:0"><input class="input" id="crmSearch" placeholder="Search leads…" oninput="renderCRM()"><select class="input" id="crmStageFilter" onchange="renderCRM()"><option value="">All stages</option></select><select class="input" id="crmProjectFilter" onchange="renderCRM()"><option value="">All projects</option></select><button class="btn ghost" onclick="openSideFor('CRM pipeline')">Ask</button></div><div id="leadBoard"></div></div></section>
<section class="view" id="skills"><div class="card"><div class="row" style="justify-content:space-between;align-items:flex-start"><div><div class="k">Skill archive</div><h2>Configured skills</h2><div class="softNote">Slash-select these in chat with /, or use the ✧ selector next to project context. Multiple skills can be active per chat.</div></div><button class="btn" onclick="configureSkills()">Configure skills</button></div><div class="filters"><input class="input" id="skillSearch" placeholder="Search skills…" oninput="renderSkillsPage()"><select class="input" id="skillGroup" onchange="renderSkillsPage()"><option value="">All groups</option></select><button class="btn ghost" onclick="clearThreadSkills()">Clear chat skills</button><button class="btn alt" onclick="openSideFor('skills')">Ask</button></div><div class="skillGrid" id="skillGrid"></div></div></section><section class="view" id="logs"><div class="card"><div class="k">Ops logs</div><h2>System activity</h2><div class="logs" id="opsLogs"></div></div></section>
<section class="view" id="sync"><div class="card"><div class="row" style="justify-content:space-between"><h2>Nervous system</h2><button class="btn" onclick="refreshSync()">Refresh</button></div><div id="syncList" class="logs"></div></div></section>
</div><div class="fab closed" id="fab"><button class="fabTab" onclick="toggleFab()">⚡</button><div class="fabPanel"><div class="fabHead"><b id="fabTitle">Kaneki</b><select id="modelSelector" style="border:1px solid var(--line);border-radius:9px;padding:4px 6px;font-size:11px;background:var(--card);color:var(--text);margin:0 8px;max-width:130px;cursor:pointer" onchange="updateModelProfile()"><option value="opencode-go/deepseek-v4-flash">DeepSeek V4 Flash</option><option value="deepseek/deepseek-v4-pro">DeepSeek V4 Pro</option><option value="opencode-go/minimax-m2-5">MiniMax M2.5</option><option value="opencode-go/qwen-3.5-plus">Qwen 3.5 Plus</option></select><div style="margin-left:auto;"><div class="toolGroup"><button class="btn ghost" title="New chat" onclick="newChat()">＋</button><button class="btn ghost" title="Open full chat" onclick="show('chats');toggleFab()">↗</button><button class="btn ghost" title="Close" onclick="toggleFab()">×</button></div></div></div><div class="msgList fabMsgs" id="fabMsgList"></div><div class="fabComposer"><textarea id="fabText" placeholder="Message… paste images"></textarea><div class="chatMeta" id="fabFileList"></div><div class="iconRow"><div class="toolGroup"><button class="btn ghost" title="Attach" onclick="pickFile()">＋</button><select class="input projectSelect" id="fabProject" onchange="fabProjectChanged()"><option value="">◇</option></select><button class="btn ghost" title="Skills" onclick="toggleSkillPop('fabSkillPop')">✧</button></div><div class="skillTray" id="fabSkillTray"></div><div class="skillPop" id="fabSkillPop"></div><div class="modePop" id="fabModePop"></div><div class="toolGroup"><button class="btn ghost" title="Modes: auto-listening stays on" id="fabActionLabel" onclick="toggleModePop('fabModePop')">Modes</button><button class="btn" title="Send" onclick="sendFab()">➤</button></div></div></div></div></div><nav class="bottomNav" id="bottomNav"></nav><div class="settingsPop" id="settingsPop"></div><script>
const tabs=[['todo','✓','Today'],['chats','💬','Chat'],['projects','□','Projects'],['calendar','◷','Calendar'],['content','✦','Content'],['crm','◎','CRM']];let state={},active='todo',activeThread='general',lastRenderedThread='',chatFilter='',dragId=null,calCursor=new Date(),selectedDate=key(new Date()),latest=[],suggestionsLoadedFor='',chatAction='auto',pendingFiles=[],contentTab='engine',skillQuery='',crmView='table',activeModes=new Set(),projectDetailId=null;const $=id=>document.getElementById(id);function clip(s,n=140){ s=String(s||'').replace(/\s+/g,' ').trim(); return s.length>n?s.slice(0,n-1)+'…':s; } function clip(s,n=140){ s=String(s||'').replace(/\s+/g,' ').trim(); return s.length>n?s.slice(0,n-1)+'…':s; } 
function key(d){d=new Date(d);return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`}function today(){const d=new Date();if(d.getHours()<6)d.setDate(d.getDate()-1);return key(d)}async function api(u,o){const r=await fetch(u,o);const j=await r.json().catch(()=>({}));if(!r.ok)throw Error(j.detail||j.error||'request failed');return j}let todaySub='queue';function currentViewId(){return active==='todo'&&todaySub!=='queue'?todaySub:active}function show(v){if(['checkin','stats','reflect','mindmap','timetable'].includes(v)){todaySub=v;v='todo'}else if(v==='todo'){todaySub='queue'}active=v;document.body.classList.toggle('chatMode',v==='chats');const vid=v==='project-detail'?'project-detail':currentViewId();document.querySelectorAll('.view').forEach(x=>x.classList.toggle('active',x.id===vid));document.querySelectorAll('.todaySub').forEach(x=>x.classList.toggle('active',active==='todo'&&x.id===todaySub));document.querySelectorAll('[data-sub]').forEach(b=>b.classList.toggle('active',b.dataset.sub===todaySub));const names={todo:['Today','Priority queue.'],checkin:['Check-in','MMR, hours, rating.'],stats:['Stats','Track productive output.'],reflect:['Reflect','Wind down and review.'],mindmap:['Mind map','Embedded RAGmind with side chat.'],timetable:['Timetable','Auto-schedule tasks around meetings.'],chats:['Chat','Focused conversations with project context.'],projects:['Projects','Click a project to see its dashboard.'],'project-detail':['Project','Dashboard, tasks, and chats for this project.'],calendar:['Calendar','Month view and schedule chat.'],content:['Content','Ideas, accounts, publishing flow.'],crm:['CRM','Leads by stage.'],logs:['Ops logs','Audit trail, not your workspace.'],skills:['Skills','Slash-select skills for sharper chat context.'],sync:['Nervous system','Connected sources.']};$('pageTitle').textContent=names[v]?.[0]||v;$('pageSub').textContent=names[v]?.[1]||'';nav();render();if(v==='project-detail')renderProjectDetail()}function nav(){const n=$('bottomNav');n.innerHTML='';tabs.forEach(t=>{const b=document.createElement('button');b.className=active===t[0]?'active':'';b.innerHTML=`<span>${t[1]}</span><span>${t[2]}</span>`;b.onclick=()=>show(t[0]);n.appendChild(b)});const gear=document.createElement('button');gear.className='';gear.id='navGear';gear.innerHTML=`<span style="font-size:18px">⚙</span><span>More</span>`;gear.onclick=e=>{e.stopPropagation();toggleSettingsPop()};n.appendChild(gear)}async function load(){const prev=activeThread;state=await api('/api/state');if(prev&&chats().some(t=>t.id===prev))activeThread=prev;else activeThread=state.brain?.activeThread||chats()[0]?.id||activeThread;setupSelects();render();if(active==='project-detail')renderProjectDetail();autoSuggestTodos()}function projects(){return state.businesses||[]}function chats(){return state.brain?.threads||[]}function skills(){return state.brain?.skills||[]}function chat(){return chats().find(x=>x.id===activeThread)||chats()[0]||{messages:[],context:{businessIds:[]}}}function todos(){return state.todos?.[today()]||[]}function events(){return state.brain?.calendar||[]}function setupSelects(){for(const id of ['fProject','todoProject','composerProject','fabProject','chatProjectFilter','crmProjectFilter']){const el=$(id);if(!el||el.dataset.ready)continue; if(id==='todoProject'||id==='composerProject'||id==='fabProject')el.innerHTML=(id==='composerProject'||id==='fabProject')?'<option value="">◇</option><option value="__new">＋</option>':''; if(id==='chatProjectFilter')el.innerHTML='<option value="">All projects</option>'; if(id==='crmProjectFilter')el.innerHTML='<option value="">All projects</option>'; projects().forEach(p=>{const o=document.createElement('option');o.value=id==='todoProject'?p.name:p.id;o.textContent=p.name;el.appendChild(o)});el.dataset.ready=1}}function render(){renderTodos();renderCheckin();renderStats();renderReflection();renderChats();renderProjects();renderCalendar();renderContent();renderCRM();renderSkillsPage();renderLogs();renderSync()}function renderTodos(){const p=$('fProject')?.value||'',prio=$('fPriority')?.value||'',type=$('fType')?.value||'';let arr=todos().filter(t=>(!p||t.project===p||t.businessId===p)&&(!prio||t.priority===prio)&&(!type||(t.tags||[]).includes(type)||String(t.text).toLowerCase().includes(type)));$('sOpen').textContent=todos().filter(t=>!t.done).length;$('sHigh').textContent=todos().filter(t=>!t.done&&t.priority==='high').length;$('sDone').textContent=todos().filter(t=>t.done).length;$('sMin').textContent=todos().filter(t=>!t.done).reduce((a,b)=>a+(+b.minutes||30),0);const el=$('todoList');if(!el)return;el.innerHTML='';arr.forEach((t,i)=>{const d=document.createElement('div');d.className='todo '+(t.done?'done':'');d.draggable=true;d.innerHTML=`<div class="rank">${i+1}</div><div class="todoMain"><div class="todoText">${esc(cleanTask(t.text,t.project))}</div><div class="todoMeta"><span class="tag">${esc(t.project||'General')}</span><span class="tag ${t.priority||''}">${t.priority||'medium'}</span></div></div><button class="check ${t.done?'on':''}"></button><button class="x">×</button>`;d.ondragstart=()=>{dragId=t.id;d.classList.add('dragging')};d.ondragend=()=>d.classList.remove('dragging');d.ondragover=e=>e.preventDefault();d.ondrop=()=>reorder(dragId,t.id);d.querySelector('.check').onclick=()=>patchTodo(t.id,{done:!t.done});d.querySelector('.x').onclick=()=>delTodo(t.id);el.appendChild(d)});renderSuggestions()}function cleanTask(text,project){if(!project)return text;return String(text).replace(new RegExp('^'+project.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+':?\\s*','i'),'')}async function patchTodo(id,b){await api('/api/todos/'+id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify(b)});await load()}async function delTodo(id){await api('/api/todos/'+id,{method:'DELETE'});await load()}async function reorder(from,to){if(!from||from===to)return;const arr=[...todos()];const a=arr.findIndex(x=>x.id===from),b=arr.findIndex(x=>x.id===to);if(a<0||b<0)return;const [m]=arr.splice(a,1);arr.splice(b,0,m);state.todos[today()]=arr;renderTodos();await api('/api/todos/reorder',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:today(),order:arr.map(x=>x.id)})})}async function addTodo(){const text=$('todoText').value.trim();if(!text)return;await api('/api/todos',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:today(),text,project:$('todoProject').value,priority:$('todoPriority').value})});$('todoText').value='';await load()}async function clearDone(){for(const t of todos().filter(x=>x.done)) await delTodo(t.id)}async function autoSuggestTodos(){if(active!=='todo')return;const k=today()+':'+todos().map(t=>t.id+t.done).join('|');if(suggestionsLoadedFor===k||latest.length)return;suggestionsLoadedFor=k;await suggestTodos(false)}async function suggestTodos(force=false){const out=await api('/api/ai/suggest',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({prompt:'simple todo actions based on dashboard state'})});latest=out.suggestions||[];if(force)suggestionsLoadedFor='';renderSuggestions()}function renderSuggestions(){const el=$('suggestions');if(!el)return;el.innerHTML='';latest.slice(0,4).forEach((s,i)=>{const d=document.createElement('div');d.className='todo suggested';d.innerHTML=`<div class="rank">AI</div><div class="todoMain"><div class="todoText">${esc(cleanTask(s.text,s.project))}</div><div class="todoMeta"><span class="tag">${esc(s.project||'Execution')}</span><span class="tag ${s.priority||''}">${s.priority||'medium'}</span></div></div><button class="check">+</button><button class="x">×</button>`;d.querySelector('.check').onclick=async()=>{await api('/api/todos',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:today(),...s})});latest=latest.filter((_,idx)=>idx!==i);await load()};d.querySelector('.x').onclick=()=>{latest=latest.filter((_,idx)=>idx!==i);renderSuggestions()};el.appendChild(d)})}function renderChatList(){const hl=$('histList');if(!hl)return;const sel=$('chatProjectFilter');if(sel&&sel.value!==chatFilter)sel.value=chatFilter;hl.innerHTML='';const list=chats().filter(t=>!chatFilter||(t.context?.businessIds||[]).includes(chatFilter));list.forEach(t=>{const last=(t.messages||[]).filter(m=>m.role!=='system').slice(-1)[0];const proj=(t.context?.businessIds||[]).map(id=>projects().find(p=>p.id===id)?.name).filter(Boolean).join(', ');const b=document.createElement('button');b.className='hist '+(t.id===activeThread?'active':'');b.innerHTML=`<b>${esc(t.title||'Chat')}</b><small>${esc(proj?proj+' · '+preview(last?.text||'No messages yet',58):preview(last?.text||'No messages yet'))}</small>`;b.onclick=()=>{activeThread=t.id;state.brain.activeThread=t.id;lastRenderedThread='';renderChats()};hl.appendChild(b)});if(!list.length){const d=document.createElement('div');d.className='tiny';d.style.padding='10px';d.textContent='No chats for this project yet.';hl.appendChild(d)}}function nearBottom(el){return el.scrollHeight-el.scrollTop-el.clientHeight<80}function renderMsgBox(id,force=false){
  const el=$(id),c=chat();
  if(!el)return;
  const msgs=(c.messages||[]).slice(-100);
  const threadChanged=lastRenderedThread!==c.id;

  // Full rebuild on thread switch or first render
  if(threadChanged||!el.dataset.rendered){
    el.innerHTML='';
    msgs.forEach(m=>{
      const div=document.createElement('div');
      div.className='msg '+(m.role==='user'?'user':(m.role==='system'?'system':'assistant'));
      div.dataset.msgId=m.id||'';
      div.innerHTML=formatMsg(m.text)+`<span class="msgTime">${time(m.at)||''}</span>`;
      el.appendChild(div);
    });
    el.dataset.rendered='1';
    el.scrollTop=el.scrollHeight;
    return;
  }

  // Smart sync: diff existing DOM against new messages
  const existing={};
  el.querySelectorAll('.msg').forEach(d=>{ if(d.dataset.msgId)existing[d.dataset.msgId]=d; });
  const isAtBottom=el.scrollHeight-el.scrollTop-el.clientHeight<50;
  const shouldStick=force||(isAtBottom&&!el.dataset.manualScroll);
  let changed=false;

  msgs.forEach(m=>{
    const id=m.id||'';
    if(existing[id]){
      // Update in place (handles pending->resolved transitions)
      const div=existing[id];
      const newHtml=formatMsg(m.text)+`<span class="msgTime">${time(m.at)||''}</span>`;
      if(div.innerHTML!==newHtml){ div.innerHTML=newHtml; changed=true; }
      delete existing[id];
    }else{
      // New message — append
      const div=document.createElement('div');
      div.className='msg '+(m.role==='user'?'user':(m.role==='system'?'system':'assistant'));
      div.dataset.msgId=id;
      div.innerHTML=formatMsg(m.text)+`<span class="msgTime">${time(m.at)||''}</span>`;
      el.appendChild(div);
      changed=true;
    }
  });
  // Remove stale elements (messages deleted server-side)
  for(const id in existing){ existing[id].remove(); changed=true; }
  if(shouldStick)el.scrollTop=el.scrollHeight;
}
function renderChats(){renderChatList();const c=chat();if($('chatTitle')){$('chatTitle').textContent=c.title||'Kaneki';$('chatSub').textContent=preview(c.scope||'Focused chat',70)}if($('fabTitle'))$('fabTitle').textContent=clip(c.title||'Kaneki',36);renderSkillTrays();renderMsgBox('msgList');renderMsgBox('fabMsgList');lastRenderedThread=c.id;for(const id of ['composerProject','fabProject']){const sel=$(id);if(sel)sel.value=(c.context?.businessIds||[])[0]||''}}

function skillById(id){return skills().find(s=>s.id===id)}function selectedSkillIds(){return chat().context?.skillIds||[]}function renderSkillTrays(){for(const id of ['skillTray','fabSkillTray']){const el=$(id);if(!el)continue;el.innerHTML='';selectedSkillIds().map(skillById).filter(Boolean).forEach(sk=>{const b=document.createElement('button');b.className='skillChip on';b.textContent='✧ '+sk.name;b.onclick=()=>toggleThreadSkill(sk.id);el.appendChild(b)})}renderSkillPop('skillPop');renderSkillPop('fabSkillPop')}function renderSkillPop(id,q=''){const el=$(id);if(!el)return;const query=(q||skillQuery||'').toLowerCase();el.innerHTML='';skills().filter(sk=>!query||sk.name.toLowerCase().includes(query)||sk.description.toLowerCase().includes(query)||sk.group.toLowerCase().includes(query)).slice(0,12).forEach(sk=>{const b=document.createElement('button');b.className='skillOpt '+(selectedSkillIds().includes(sk.id)?'active':'');b.innerHTML=`<b>${esc(sk.name)}</b><small>${esc(sk.group)} · ${esc(preview(sk.description,110))}</small>`;b.onclick=()=>toggleThreadSkill(sk.id);el.appendChild(b)});if(!el.innerHTML)el.innerHTML='<div class="tiny" style="padding:8px">No matching skills.</div>'}function toggleSkillPop(id){const el=$(id);if(!el)return;skillQuery='';renderSkillPop(id);el.classList.toggle('open')}async function toggleThreadSkill(skillId){const c=chat();const set=new Set(c.context?.skillIds||[]);set.has(skillId)?set.delete(skillId):set.add(skillId);c.context={...(c.context||{}),skillIds:[...set]};await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)});await load()}async function clearThreadSkills(){const c=chat();c.context={...(c.context||{}),skillIds:[]};await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)});await load()}function slashSkillQuery(text){const m=String(text||'').match(/(?:^|\s)\/([A-Za-z0-9_-]{0,40})$/);return m?m[1]:null}function handleSlashSkills(inputId,popId){const q=slashSkillQuery($(inputId).value);const pop=$(popId);if(q===null){pop?.classList.remove('open');return}skillQuery=q;renderSkillPop(popId,q);pop?.classList.add('open')}async function configureSkills(){const out=await api('/api/skills/configure',{method:'POST'});state=out.state||state;renderSkillsPage();renderSkillTrays()}function renderSkillsPage(){const grid=$('skillGrid');if(!grid)return;const groupSel=$('skillGroup');if(groupSel&&!groupSel.dataset.ready){[...new Set(skills().map(s=>s.group).filter(Boolean))].sort().forEach(g=>{const o=document.createElement('option');o.value=g;o.textContent=g;groupSel.appendChild(o)});groupSel.dataset.ready=1}const q=($('skillSearch')?.value||'').toLowerCase(),g=groupSel?.value||'';grid.innerHTML='';skills().filter(sk=>(!g||sk.group===g)&&(!q||sk.name.toLowerCase().includes(q)||sk.description.toLowerCase().includes(q))).forEach(sk=>{const d=document.createElement('div');d.className='skillCard';d.innerHTML=`<h3>${esc(sk.name)}</h3><p>${esc(sk.description)}</p><div class="row wrap"><span class="tag">${esc(sk.group)}</span><span class="tag">configured</span></div><button class="btn ghost" style="margin-top:8px" onclick="toggleThreadSkill('${sk.id}')">${selectedSkillIds().includes(sk.id)?'Remove from chat':'Add to chat'}</button>`;grid.appendChild(d)});if(!grid.innerHTML)grid.innerHTML='<div class="tiny">No skills found yet. Hit Configure skills.</div>'}
function genericTitle(t){return !t||/^new chat$/i.test(t)||/^chat$/i.test(t)||/^kaneki$/i.test(t)}function smartChatTitle(msg,c){let text=String(msg||'').replace(/^Turn this into clean dashboard to-dos.*?:\s*/i,'').replace(/^Create useful content ideas.*?:\s*/i,'').replace(/^Make a concise execution plan.*?:\s*/i,'').replace(/^VISUALIZE this\..*?:\s*/i,'').replace(/^Return a structured.*?:\s*/i,'').replace(/\s+/g,' ').trim();const proj=(c.context?.businessIds||[]).map(id=>projects().find(p=>p.id===id)?.name).filter(Boolean)[0];text=text.replace(/^(can you|could you|please|hey|hi|yo|bro|ibr)[,.\s]*/i,'').trim();let title=clip(text,48).replace(/[?.!,:;]+$/,'');if(!title)title=proj?`${proj} chat`:'New thread';return proj&&!title.toLowerCase().includes(proj.toLowerCase().split(' ')[0])?`${proj}: ${title}`:title}async function toggleContext(c,id){const s=new Set(c.context?.businessIds||[]);s.has(id)?s.delete(id):s.add(id);c.context={...(c.context||{}),businessIds:[...s]};await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)});await load()}async function newChat(){const stay=active!=='chats';const out=await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({title:'New chat',context:{businessIds:[]}})});state=out.state;activeThread=out.thread.id;if(stay){renderChats();quickOpen('')}else show('chats')}async function renameChat(){const c=chat(),title=prompt('Name',c.title);if(!title)return;c.title=title;await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)});await load()}function toggleHistory(){$('chatWrap').classList.toggle('collapsed')}const modeDefs={ask:['Ask','Direct answer, no forced structure.'],visual:['Visualize','Colorful Claude-style maps, flows, SVG cards.'],web:['Web search','Prefer fresh web context when useful.'],research:['Deep research','Go broader/deeper before answering.'],reason:['Deep reasoning','Think through tradeoffs and edge cases.'],present:['Present','Polished explanation / pitch / narrative.'],coding:['Coding','Deep technical mindset, specialized in implementation and debug.'],tasks:['Todo','Convert into dashboard-ready action items.'],content:['Content','Shape ideas for posts, personas, platforms.'],plan:['Plan','Roadmap, sequence, timeline.'],structured:['Tabs','Summary, options, recommendation, next actions.']};
function actionIcon(a){return modeDefs[a]?.[0]||'Auto'}
function detectMode(s){s=String(s||'').toLowerCase();const found=[];if(/deep research|research this|investigate|sources|market scan/.test(s))found.push('research');if(/web search|search web|latest|current|google|online/.test(s))found.push('web');if(/think deeply|deep reasoning|reason through|tradeoffs|edge cases/.test(s))found.push('reason');if(/visuali[sz]e|diagram|map|flow|architecture|funnel|system|workflow|mind.?map/.test(s))found.push('visual');if(/present|pitch|deck|story|explain beautifully/.test(s))found.push('present');if(/content|post|thread|script|persona|platform|caption|newsletter|distribution/.test(s))found.push('content');if(/todo|task|action items?|checklist|to-do/.test(s))found.push('tasks');if(/plan|roadmap|strategy|steps|timeline|schedule/.test(s))found.push('plan');if(/compare|options|pros|cons|decision|structure|summari[sz]e|break down/.test(s))found.push('structured');if(/code|program|debug|script|refactor|function|api|implement|backend|frontend/i.test(s))found.push('coding');return found.length?found:['ask']}
function selectedModesFor(msg){return [...new Set([...detectMode(msg),...activeModes])]}
function modePrompt(modes){const bits=[];if(modes.includes('visual'))bits.push('When helpful, create a rich visual answer like Claude: colorful structured map/flow, compact SVG-friendly sections, not just markdown or ASCII. Use labels that can render as cards/nodes.');if(modes.includes('web'))bits.push('Use web search / fresh sources if current facts would improve the answer; cite useful sources.');if(modes.includes('research'))bits.push('Do deep research: broaden the search space, compare sources, synthesize findings, and separate facts from assumptions.');if(modes.includes('reason'))bits.push('Use deeper reasoning: examine tradeoffs, failure modes, and best recommendation.');if(modes.includes('present'))bits.push('Present the answer polished and persuasive, with a clear narrative.');if(modes.includes('tasks'))bits.push('Extract concrete dashboard-ready todos and next actions.');if(modes.includes('content'))bits.push('Shape the output for content planning: angle, platform fit, hooks, repurposing paths.');if(modes.includes('plan'))bits.push('Return an execution plan with stages, order, and timeline.');if(modes.includes('coding'))bits.push('You are in Coding Mode. Focus on technical accuracy, efficient algorithms, and clean code. Use DeepSeek v4 Pro for complex logic. Explain architectural choices briefly.');if(modes.includes('structured'))bits.push('Use clear sections: Summary, Options, Recommendation, Next Actions.');return bits.length?'[Active modes: '+modes.map(actionIcon).join(', ')+']\n'+bits.join('\n')+'\n\n':''}
function renderModePops(){for(const id of ['modePop','fabModePop']){const el=$(id);if(!el)continue;el.innerHTML='<div class="modeHint">Auto-listening is always on. Toggle extra modes.</div>'+Object.entries(modeDefs).filter(([k])=>k!=='ask').map(([k,v])=>`<button class="modeOpt ${activeModes.has(k)?'active':''}" onclick="toggleMode('${k}')"><b>${activeModes.has(k)?'✓ ':''}${esc(v[0])}</b><small>${esc(v[1])}</small></button>`).join('')}}
function toggleModePop(id){renderModePops();$(id)?.classList.toggle('open')}
function toggleSettingsPop(){const el=$('settingsPop');if(!el)return;if(el.classList.contains('open')){el.classList.remove('open');return}el.innerHTML=[['↻','Sync','sync'],['✧','Skills','skills'],['≡','Logs','logs']].map(([icon,name,id])=>`<button class="settingsOpt" onclick="show('${id}');toggleSettingsPop()"><span class="stIcon">${icon}</span> ${name}</button>`).join('');el.classList.add('open')}
function toggleMode(m){activeModes.has(m)?activeModes.delete(m):activeModes.add(m);if(m==='coding'){document.body.classList.toggle('codingMode',activeModes.has('coding'))}setAction('auto');renderModePops()}
function setAction(a){chatAction=a;const label=activeModes.size?'Modes · '+[...activeModes].map(actionIcon).join(' + '):'Modes';if($('actionLabel'))$('actionLabel').textContent=label;if($('fabActionLabel'))$('fabActionLabel').textContent=label;renderModePops()}
function pickFile(){$('fileInput').click()}function readAsDataURL(f){return new Promise(r=>{const fr=new FileReader();fr.onload=()=>r(fr.result);fr.onerror=()=>r('');fr.readAsDataURL(f)})}async function handleFiles(files,{append=false}={}){if(!append)pendingFiles=[];for(const f of files){let text='',dataUrl='';if((f.type||'').startsWith('image/'))dataUrl=await readAsDataURL(f);else try{text=(await f.text()).slice(0,12000)}catch{}pendingFiles.push({name:f.name||'pasted-image.png',type:f.type,size:f.size,text,dataUrl})}renderFiles()}function renderFiles(){for(const id of ['fileList','fabFileList']){const el=$(id);if(!el)continue;el.innerHTML='';pendingFiles.forEach((f,i)=>{const b=document.createElement('button');b.className='filePill '+(f.dataUrl?'imagePill':'');b.innerHTML=(f.dataUrl?`<img src="${f.dataUrl}" alt="">`:'')+`<span>× ${esc(f.name)}</span>`;b.onclick=()=>{pendingFiles.splice(i,1);renderFiles()};el.appendChild(b)})}}async function composerProjectChanged(){const v=$('composerProject').value;if(v==='__new'){await createProjectFromComposer();return}const c=chat();c.context={...(c.context||{}),businessIds:v?[v]:[]};await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)});await load()}async function fabProjectChanged(){const v=$('fabProject').value;if(v==='__new'){await createProjectFromComposer();return}const c=chat();c.context={...(c.context||{}),businessIds:v?[v]:[]};await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)});await load()}function cycleAction(){setAction('auto')}async function createProjectFromComposer(){const name=prompt('Project name?');if(!name){$('composerProject').value='';return}const item={name,lane:'Project',status:'active',priority:'medium',health:'green',description:'Created from chat composer.',tags:[]};const out=await api('/api/businesses',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(item)});document.querySelectorAll('select').forEach(x=>delete x.dataset.ready);await load();$('composerProject').value=out.item.id;await composerProjectChanged()}function showCodingToast(inputId,msg){const old=document.querySelector('.toastOverlay');if(old)old.remove();const d=document.createElement('div');d.className='toastOverlay';d.innerHTML=`<div class="toastBox"><h3>🖥️ Coding intent detected</h3><p>Detected coding intent. Switch to Coding Mode?</p><div class="toastBtns"><button class="toastYes">Yes</button><button class="toastNo">No</button></div></div>`;d.querySelector('.toastYes').onclick=()=>{d.remove();toggleMode('coding');$(inputId).value=msg;sendFrom(inputId)};d.querySelector('.toastNo').onclick=()=>{d.remove();$(inputId).value=msg;sendFrom(inputId)};d.addEventListener('click',e=>{if(e.target===d)d.remove()});document.body.appendChild(d)}async function sendFrom(inputId){let msg=$(inputId).value.trim();if(!msg&&!pendingFiles.length)return;$(inputId).value='';const detected=detectMode(msg);if(detected.includes('coding')&&!activeModes.has('coding')){showCodingToast(inputId,msg);return}const c=chat();c.messages ||= [];const modes=selectedModesFor(msg);setAction('auto');if(genericTitle(c.title)){c.title=smartChatTitle(msg,c);await api('/api/threads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(c)})}let files=pendingFiles.map(f=>`

[Attachment: ${f.name}${f.type?' · '+f.type:''}]
${f.text|| (f.dataUrl?'(image pasted/attached — visible in dashboard preview, describe or reference it if needed)':'(binary/unreadable file attached)')}`).join('');pendingFiles=[];renderFiles();msg=modePrompt(modes)+msg+files;c.messages.push({id:'local-'+Date.now(),role:'user',text:msg,at:new Date().toISOString(),surface:'dashboard',threadId:activeThread});c.messages.push({id:'local-pending-'+Date.now(),role:'assistant',text:'Thinking…',pending:true,at:new Date().toISOString(),surface:'openclaw',threadId:activeThread});renderChats();renderMsgBox('msgList',true);renderMsgBox('fabMsgList',true);const out=await api('/api/threads/'+activeThread+'/messages',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({message:msg,async:true,model:localStorage.modelProfile||""})});state=out.state;renderChats();watchReply()}function sendChat(){return sendFrom('chatInput')}function sendFab(){return sendFrom('fabText')}
function setTodaySub(v){todaySub=v;active='todo';const vid=currentViewId();document.querySelectorAll('.view').forEach(x=>x.classList.toggle('active',x.id===vid));document.querySelectorAll('.todaySub').forEach(x=>x.classList.toggle('active',x.id===v));document.querySelectorAll('[data-sub]').forEach(b=>b.classList.toggle('active',b.dataset.sub===v));render();if(v==='timetable'){loadTimetableConfig().then(()=>generateTimetable());}}function prod(){state.metrics ||= {}; state.metrics.productivity ||= {daily:{},mmrBase:1000}; state.metrics.productivity.daily ||= {}; state.metrics.productivity.mmrBase ||= 1000; return state.metrics.productivity}function todayEntry(){const p=prod();p.daily[today()] ||= {};return p.daily[today()]}function recentEntries(n=7){const p=prod().daily||{};return Object.keys(p).sort().slice(-n).map(k=>({date:k,...p[k]}))}function renderCheckin(){if(!$('checkinPrompts'))return;const e=todayEntry();for(const pair of [['mmrDelta',e.mmrDelta??0],['workHours',e.hours??''],['dayRating',e.rating??7],['energyRating',e.energy??7],['movedForward',e.moved||'']]){if($(pair[0]))$(pair[0]).value=pair[1]}if($('mmrOut'))$('mmrOut').value=$('mmrDelta').value;if($('ratingOut'))$('ratingOut').value=$('dayRating').value;if($('energyOut'))$('energyOut').value=$('energyRating').value;const qs=['Did you protect deep work or just stay busy?','What got avoided because it felt uncomfortable?','What would make tomorrow a +20 MMR day?','Did prayer/body/wealth all get a vote today?'];$('checkinPrompts').innerHTML=qs.map(q=>`<div class="promptCard">${q}</div>`).join('')}function mmr(){return (prod().mmrBase||1000)+Object.values(prod().daily||{}).reduce((a,e)=>a+(+e.mmrDelta||0),0)}async function saveState(){await api('/api/state',{method:'PUT',headers:{'content-type':'application/json'},body:JSON.stringify(state)});await load()}async function saveCheckin(){const e=todayEntry();e.mmrDelta=+$('mmrDelta').value||0;e.hours=+$('workHours').value||0;e.rating=+$('dayRating').value||0;e.energy=+$('energyRating').value||0;e.moved=$('movedForward').value.trim();e.checkedAt=new Date().toISOString();await saveState()}function renderStats(){if(!$('statMmr'))return;const rows=recentEntries(7);$('statMmr').textContent=mmr();$('statHours').textContent=rows.reduce((a,e)=>a+(+e.hours||0),0).toFixed(1);const rated=rows.filter(e=>e.rating);$('statRating').textContent=rated.length?(rated.reduce((a,e)=>a+(+e.rating||0),0)/rated.length).toFixed(1):'—';let streak=0;for(let i=0;i<30;i++){const d=new Date();d.setDate(d.getDate()-i);const k=key(d);if(prod().daily[k]?.checkedAt)streak++;else break}$('statStreak').textContent=streak;renderStatChart(rows);const bars=$('statBars');bars.innerHTML=rows.map(e=>`<div><div class="row" style="justify-content:space-between"><b>${e.date.slice(5)}</b><span class="tiny">${e.hours||0}h · ${e.rating||'—'}/10 · ${e.mmrDelta||0} MMR</span></div><div class="bar"><i style="width:${Math.min(100,(+e.hours||0)/8*100)}%"></i></div></div>`).join('')||'<div class="softNote">No check-ins yet.</div>'}function renderStatChart(rows){const el=$('statChart');if(!el)return;if(!rows.length){el.innerHTML='';return}const vals=rows.map(e=>+e.rating||0),hrs=rows.map(e=>+e.hours||0),max=Math.max(10,...hrs);const pts=vals.map((v,i)=>[36+i*(320/Math.max(1,vals.length-1)),160-(v/10)*125]);const hpts=hrs.map((v,i)=>[36+i*(320/Math.max(1,hrs.length-1)),160-(v/max)*125]);const path=a=>a.map((p,i)=>(i?'L':'M')+p[0].toFixed(1)+' '+p[1].toFixed(1)).join(' ');el.innerHTML=`<div class="chartBox"><svg viewBox="0 0 390 190" preserveAspectRatio="none"><path class="chartGrid" d="M30 35H370M30 95H370M30 160H370"/><path class="chartArea" d="${path(pts)} L ${pts.at(-1)?.[0]||36} 160 L 36 160Z"/><path class="chartLine" d="${path(pts)}"/><path d="${path(hpts)}" fill="none" stroke="var(--blue)" stroke-width="2" stroke-dasharray="5 5"/><text class="chartText" x="32" y="24">rating = solid · hours = dashed</text>${rows.map((e,i)=>`<text class="chartText" x="${36+i*(320/Math.max(1,rows.length-1))-8}" y="180">${e.date.slice(5)}</text>`).join('')}</svg></div>`}function renderReflection(){if(!$('reflectionLast'))return;const e=todayEntry();for(const pair of [['reflectWorked',e.reflectWorked||''],['reflectDistracted',e.reflectDistracted||''],['reflectTomorrow',e.reflectTomorrow||''],['reflectWind',e.reflectWind||'']]){if($(pair[0]))$(pair[0]).value=pair[1]}$('reflectionLast').innerHTML=[e.reflectWorked&&'Worked: '+e.reflectWorked,e.reflectTomorrow&&'Tomorrow: '+e.reflectTomorrow].filter(Boolean).map(x=>`<div class="promptCard">${esc(x)}</div>`).join('')||'<div class="softNote">No reflection saved today.</div>'}async function saveReflection(){const e=todayEntry();e.reflectWorked=$('reflectWorked').value.trim();e.reflectDistracted=$('reflectDistracted').value.trim();e.reflectTomorrow=$('reflectTomorrow').value.trim();e.reflectWind=$('reflectWind').value.trim();e.reflectedAt=new Date().toISOString();await saveState()}function openAlterEgo(){quickOpen('Project RAG / alter ego: help me think this through honestly. ')}function renderProjects(){const el=$('projectsGrid');if(!el)return;el.innerHTML='';projects().forEach(p=>{const d=document.createElement('div');d.className='project';d.innerHTML=`<h3>${esc(p.name)}</h3><p>${esc(p.description||'')}</p><div class="row wrap"><span class="tag">${esc(p.lane||'Project')}</span><span class="tag">${esc(p.priority||'')}</span></div>`;d.onclick=()=>showProjectDetail(p.id);el.appendChild(d)})}async function startProject(id){const out=await api('/api/projects/'+id+'/start-chat',{method:'POST',headers:{'content-type':'application/json'},body:'{}'});state=out.state;activeThread=out.thread.id;show('chats')}
async function showProjectDetail(id){projectDetailId=id;const out=await api('/api/projects/'+id+'/dashboard');if(out.project){renderProjectDetail(out);show('project-detail')}else show('projects')}
function startProjectFromDetail(){if(!projectDetailId)return;startProject(projectDetailId)}
function resumeLatestChat(){if(!projectDetailId)return;const p=projects().find(b=>b.id===projectDetailId);if(!p)return;const existing=chats().find(t=>(t.context?.businessIds||[]).includes(projectDetailId)&&(t.messages||[]).length>0);if(existing){activeThread=existing.id;state.brain.activeThread=existing.id;show('chats')}else startProject(projectDetailId)}
async function renderProjectDetail(data){if(!data){try{data=await api('/api/projects/'+projectDetailId+'/dashboard')}catch(e){$('projDetail').innerHTML='<div class="projEmpty">Could not load project data.</div>';return}}const p=data.project;if(!p){$('projDetail').innerHTML='<div class="projEmpty">Project not found.</div>';return}$('pdName').textContent=p.name;$('pdLane').textContent=[p.lane,p.status,p.type].filter(Boolean).join(' · ');$('pdDesc').textContent=p.description||'';$('pdTags').innerHTML=(p.tags||[]).map(t=>`<span class="tag">${esc(t)}</span>`).join('')+(p.health?` <span class="projHealth ${p.health}">${p.health}</span>`:'');const resumeBtn=$('pdResumeBtn');const existing=chats().find(t=>(t.context?.businessIds||[]).includes(p.id)&&(t.messages||[]).length>0);resumeBtn.style.display=existing?'inline-block':'none';if(existing)resumeBtn.textContent='↻ Resume';
const stats=data.stats||{};$('pdStats').innerHTML=`<div class="projStat"><b>${stats.openTodos||0}</b><span>open tasks</span></div><div class="projStat"><b>${stats.highTodos||0}</b><span>high priority</span></div><div class="projStat"><b>${stats.totalChats||0}</b><span>chats</span></div><div class="projStat"><b>${stats.totalLeads||0}</b><span>leads</span></div><div class="projStat"><b>${stats.doneTodos||0}</b><span>done</span></div>`;let todoHtml='';if(data.todos&&data.todos.length){data.todos.slice(0,12).forEach(t=>{todoHtml+=`<div class="projTodo"><button class="check ${t.done?'on':''}" onclick="patchTodo('${t.id}',{done:!${!!t.done}});setTimeout(()=>showProjectDetail('${p.id}'),500)"></button><div><div class="todoText" style="font-size:13px">${esc(cleanTask(t.text,t.project))}</div><div class="todoMeta"><span class="tag ${t.priority||''}">${t.priority||'medium'}</span></div></div></div>`})}else todoHtml='<div class="projEmpty">No open tasks for this project.</div>';$('pdTodos').innerHTML=todoHtml;let chatHtml='';if(data.chats&&data.chats.length){data.chats.slice(0,8).forEach(c=>{const preview=c.lastMessage?clip(c.lastMessage,70):'No messages';chatHtml+=`<div class="projChatRow" onclick="activeThread='${c.id}';state.brain.activeThread='${c.id}';show('chats')"><div><b>${esc(c.title)}</b><small>${esc(preview)}</small></div><span class="tag">${c.messageCount||0} msgs</span></div>`})}else chatHtml='<div class="projEmpty">No chats for this project yet.</div>';$('pdChats').innerHTML=chatHtml}function renderCalendar(){if(!$('calGrid'))return;const start=new Date(calCursor.getFullYear(),calCursor.getMonth(),1),first=new Date(start);first.setDate(1-start.getDay());$('monthLabel').textContent=start.toLocaleString([],{month:'long',year:'numeric'});$('selectedDay').textContent=selectedDate;const g=$('calGrid');g.innerHTML='';['S','M','T','W','T','F','S'].forEach(x=>{const d=document.createElement('div');d.className='k';d.textContent=x;g.appendChild(d)});for(let i=0;i<42;i++){const d=new Date(first);d.setDate(first.getDate()+i);const k=key(d);const cell=document.createElement('div');cell.className='day '+(k===today()?'today':'');cell.innerHTML=`<b>${d.getDate()}</b>`;events().filter(e=>String(e.start||'').slice(0,10)===k).slice(0,2).forEach(e=>{const v=document.createElement('div');v.className='event';v.textContent=e.title;cell.appendChild(v)});cell.onclick=()=>{selectedDate=k;renderCalendar()};g.appendChild(cell)}fill('dayEvents',events().filter(e=>String(e.start||'').slice(0,10)===selectedDate).map(e=>`${time(e.start)} ${e.title}`))}function moveMonth(n){calCursor.setMonth(calCursor.getMonth()+n);renderCalendar()}async function syncCalendar(){await api('/api/calendar/sync',{method:'POST',headers:{'content-type':'application/json'},body:'{}'});await load()}function setContentTab(t){contentTab=t;document.querySelectorAll('[data-content-tab]').forEach(b=>b.classList.toggle('active',b.dataset.contentTab===t));document.querySelectorAll('.contentPanel').forEach(p=>p.classList.toggle('active',p.id==='content-'+t))}function content(){state.brain ||= {}; state.brain.content ||= {posts:[],accounts:[],personas:[],platforms:[],engine:{},personalPlan:{}};return state.brain.content}function renderContent(){const c=content();setContentTab(contentTab);if($('contentPostCount')){$('contentPostCount').textContent=(c.posts||[]).length;$('contentAcctCount').textContent=(c.accounts||[]).length;$('contentPersonaCount').textContent=(c.personas||[]).length;$('contentPlatformCount').textContent=(c.platforms||[]).length;$('engineFocus').textContent=c.engine?.focus||'Content engine not configured';$('engineThought').textContent=c.engine?.lastThought||'';const eb=$('engineBacklog');eb.innerHTML=(c.engine?.backlog||[]).map(x=>`<span class="tag">${esc(x)}</span>`).join('')||'<span class="tiny">No backlog yet.</span>'}const b=$('contentBoard');if(b){b.innerHTML='';['idea','scripted','scheduled','posted'].forEach(st=>{const col=document.createElement('div');col.className='col';col.innerHTML=`<h3>${st}</h3>`;(c.posts||[]).filter(p=>(p.status||'idea')===st).forEach(p=>{const it=document.createElement('div');it.className='item';it.innerHTML=`<b>${esc(p.title)}</b><small>${esc([p.platform,p.persona,p.format].filter(Boolean).join(' · '))}</small><div class="row wrap"><span class="tag">${esc(p.businessId||'personal')}</span><span class="tag">${esc(p.type||'post')}</span></div>`;col.appendChild(it)});b.appendChild(col)})}fill('contentAccounts',(c.accounts||[]).map(a=>`${a.platform}: ${a.handle} · ${a.status}${a.persona?' · '+a.persona:''}`));const pp=c.personalPlan||{};if($('planMission')){$('planMission').value=pp.mission||'';$('planTheme').value=pp.weeklyTheme||'';$('planNotes').value=pp.notes||''}const pg=$('personaGrid');if(pg){pg.innerHTML='';(c.personas||[]).forEach(p=>{const d=document.createElement('div');d.className='personaCard';d.innerHTML=`<h3>${esc(p.name)}</h3><p class="softNote">${esc(p.angle||'')}</p><span class="tag">${esc(p.tone||'')}</span>`;pg.appendChild(d)})}const pl=$('platformGrid');if(pl){pl.innerHTML='';(c.platforms||[]).forEach(p=>{const d=document.createElement('div');d.className='platformCard';d.innerHTML=`<h3>${esc(p.name)}</h3><p class="softNote">${esc((p.formats||[]).join(', '))}</p><span class="tag">${esc(p.cadence||'')}</span>`;pl.appendChild(d)})}}async function addContent(){const title=prompt('Content idea?');if(!title)return;const c=content();const persona=(c.personas||[])[0]?.name||'';const platform=(c.platforms||[])[0]?.name||'';await api('/api/content/posts',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({title,status:'idea',persona,platform,format:'post'})});await load()}async function addContentAccount(){const handle=prompt('Account handle/name?');if(!handle)return;const platform=prompt('Platform?','LinkedIn')||'LinkedIn';await api('/api/content/accounts',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({handle,platform,status:'planned'})});await load()}async function addPersona(){const name=prompt('Persona name?');if(!name)return;const angle=prompt('Angle?','')||'';const tone=prompt('Tone?','')||'';await api('/api/content/personas',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({name,angle,tone})});await load()}async function addPlatform(){const name=prompt('Platform?');if(!name)return;const formats=(prompt('Formats comma-separated?','post, short, carousel')||'').split(',').map(x=>x.trim()).filter(Boolean);const cadence=prompt('Cadence?','weekly')||'weekly';await api('/api/content/platforms',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({name,formats,cadence,status:'planned'})});await load()}async function saveContentPlan(){await api('/api/content/plan',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({mission:$('planMission').value,weeklyTheme:$('planTheme').value,notes:$('planNotes').value})});await load()}function openContentMindmap(){window.open('http://100.111.98.27:4444/','_blank')}function crmStages(){return state.crm?.pipelines?.leads?.stages||['new','researching','contacted','replied','qualified','booked','won','lost']}function crmLeads(){const q=($('crmSearch')?.value||'').toLowerCase(),st=$('crmStageFilter')?.value||'',pid=$('crmProjectFilter')?.value||'';return (state.crm?.leads||[]).filter(l=>(!st||(l.stage||'new')===st)&&(!pid||l.businessId===pid||l.projectId===pid)&&(!q||[l.company,l.name,l.email,l.owner,l.nextAction,l.business,l.notes].some(x=>String(x||'').toLowerCase().includes(q))))}function setCrmView(v){crmView=v;renderCRM()}function money(n){n=Number(n||0);return n?new Intl.NumberFormat('en-DE',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(n):'€0'}function leadProject(l){return projects().find(p=>p.id===l.businessId||p.id===l.projectId)?.name||l.business||l.project||'—'}function stageOptions(cur){return crmStages().map(st=>`<option value="${esc(st)}" ${st===(cur||'new')?'selected':''}>${esc(st)}</option>`).join('')}function renderCRM(){const b=$('leadBoard');if(!b)return;const stages=crmStages();const sf=$('crmStageFilter');if(sf&&!sf.dataset.ready){stages.forEach(st=>{const o=document.createElement('option');o.value=st;o.textContent=st;sf.appendChild(o)});sf.dataset.ready=1}const all=state.crm?.leads||[],leads=crmLeads();$('crmTotal').textContent=all.length;$('crmReplied').textContent=all.filter(l=>['replied','qualified','booked','won'].includes(l.stage)).length;$('crmBooked').textContent=all.filter(l=>['booked','won'].includes(l.stage)).length;$('crmValue').textContent=money(all.reduce((a,l)=>a+(+l.value||+l.dealValue||0),0));$('crmTableBtn')?.classList.toggle('active',crmView==='table');$('crmKanbanBtn')?.classList.toggle('active',crmView==='kanban');b.innerHTML='';if(crmView==='kanban'){b.className='crmBoard2';stages.forEach(st=>{const arr=leads.filter(l=>(l.stage||'new')===st);const col=document.createElement('div');col.className='crmCol';col.innerHTML=`<h3><span>${esc(st)}</span><span>${arr.length}</span></h3><div class="crmMiniTable"><table>${arr.map(l=>`<tr><td><b>${esc(l.company||l.name||'Unnamed')}</b><small>${esc(leadProject(l))}</small></td><td><small>${esc(l.nextAction||'No next action')}</small></td><td><select class="input" onchange="patchLead('${l.id}',{stage:this.value})">${stageOptions(l.stage)}</select></td></tr>`).join('')||'<tr><td><small>Empty</small></td></tr>'}</table></div>`;b.appendChild(col)});return}b.className='crmTableWrap';b.innerHTML=`<table class="crmTable"><thead><tr><th>Lead</th><th>Project</th><th>Stage</th><th>Owner</th><th>Next action</th><th>Value</th><th>Last touch</th></tr></thead><tbody>${leads.map(l=>`<tr><td class="crmCellMain"><b>${esc(l.company||l.name||'Unnamed')}</b><small>${esc(l.email||l.phone||l.source||'')}</small></td><td>${esc(leadProject(l))}</td><td><select class="input" onchange="patchLead('${l.id}',{stage:this.value})">${stageOptions(l.stage)}</select></td><td>${esc(l.owner||'—')}</td><td>${esc(l.nextAction||'—')}</td><td>${money(l.value||l.dealValue)}</td><td>${esc(String(l.lastTouch||l.updatedAt||l.createdAt||'').slice(0,10)||'—')}</td></tr>`).join('')||'<tr><td colspan="7" class="tiny" style="padding:18px">No leads yet. Add one or import a lead table.</td></tr>'}</tbody></table>`}async function patchLead(id,patch){await api('/api/crm/leads/'+id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify(patch)});await load()}async function addLead(){const company=prompt('Lead/company?');if(!company)return;const nextAction=prompt('Next action?','Research/contact')||'';await api('/api/crm/leads',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({company,stage:'new',nextAction})});await load()}function renderLogs(){fill('opsLogs',(state.ops?.activity||[]).map(a=>`${a.at?.slice(0,16)} · ${a.type} · ${a.text}`))}function renderSync(){const el=$('syncList');if(!el)return;fill('syncList',(state.integrations||[]).map(i=>{const s=state.brain?.sync?.sources?.[i.id]||{};return `${i.name}: ${s.status||i.status} — ${s.summary||i.note||''}`}))}async function refreshSync(){await api('/api/sync/refresh',{method:'POST',headers:{'content-type':'application/json'},body:'{}'});await load()}function quickOpen(text=''){const f=$('fab');f.classList.remove('closed');$('fabText').value=text;$('fabText').focus();renderChats()}function openSideFor(page){quickOpen(`On ${page}: `)}function toggleFab(){$('fab').classList.toggle('closed');renderChats()}async function askFab(){return sendFab()}async function askPage(id,page){quickOpen(`On ${page}: ${$(id)?.value||''}`);await sendFab()}function preview(s,n=48){return String(s||'').replace(/\s+/g,' ').trim().slice(0,n)}function inlineMd(s){return esc(s).replace(/`([^`]+)`/g,'<code>$1</code>').replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>').replace(/\*([^*]+)\*/g,'<em>$1</em>').replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>')}
function structuredMsg(raw){
 const re=/(?:^|\n)(Summary|Options|Recommendation|Next Actions|Map|Flow|Priorities|Next|Research|Sources):?\n/gi;
 const heads=[...raw.matchAll(re)];
 if(heads.length<2)return null;
 let tabs='',panels='';
 heads.forEach((h,i)=>{const name=h[1];const from=h.index+h[0].length;const to=i<heads.length-1?heads[i+1].index:raw.length;const body=raw.slice(from,to).trim();tabs+=`<button>${esc(name)}</button>`;panels+=`<div class="sPanel"><b>${esc(name)}</b>${basicFormat(body)}</div>`});
 return `<div class="structured"><div class="sTabs">${tabs}</div>${panels}</div>`;
}
function visualMsg(raw){ if(!/^\s*VISUALIZE\b/im.test(raw)) return null; 

 if(!/\b(Map|Flow|Priorities|Next|Visual|Architecture|System)\b:?/i.test(raw))return null;
 const lines=raw.split(/\n+/).map(x=>x.replace(/^[-•*\d.)\s]+/,'').trim()).filter(x=>x&&x.length<120).slice(0,8);
 if(lines.length<3)return null;
 const colors=['#111827','#374151','#4b5563','#6b7280','#9ca3af','#d1d5db','#e5e7eb','#f3f4f6'];
 const nodes=lines.map((x,i)=>{const y=34+i*42,c=colors[i%colors.length];return `<g class="vizNode"><rect x="14" y="${y}" width="330" height="30" rx="15" fill="${c}" opacity=".92"/><text x="28" y="${y+20}" fill="white" font-size="12" font-weight="800">${esc(clip(x,58))}</text></g>${i<lines.length-1?`<path d="M179 ${y+30} V ${y+42}" stroke="${c}" stroke-width="3" stroke-linecap="round" opacity=".55"/>`:''}`}).join('');
 return `<div class="vizCanvas" style="overflow:auto; max-height:80vh; padding:10px 0;"><svg viewBox="0 0 360 ${Math.max(180,lines.length*42+28)}" role="img" aria-label="visual map">${nodes}</svg></div><div class="vizBox"><h4>Visual breakdown</h4><div class="vizSteps">${lines.map((x,i)=>`<div class="vizStep" style="border-top:3px solid ${colors[i%colors.length]}">${inlineMd(x)}</div>`).join('')}</div></div>`;
}
function tableMd(block){const rows=block.split(/\n/).filter(x=>/^\s*\|/.test(x));if(rows.length<2||!/[-:|]{3,}/.test(rows[1]))return null;const cells=r=>r.trim().replace(/^\||\|$/g,'').split('|').map(x=>inlineMd(x.trim()));const head=cells(rows[0]),body=rows.slice(2).map(cells);return '<table><thead><tr>'+head.map(x=>`<th>${x}</th>`).join('')+'</tr></thead><tbody>'+body.map(r=>'<tr>'+r.map(x=>`<td>${x}</td>`).join('')+'</tr>').join('')+'</tbody></table>'}
function basicFormat(s){s=String(s||'');s=s.replace(/```([\s\S]*?)```/g,(_,c)=>`\n\n<pre><code>${esc(c)}</code></pre>\n\n`);const parts=s.split(/\n{2,}/).map(p=>p.trim()).filter(Boolean);return parts.map(p=>{if(/^<pre>/.test(p))return p;const tbl=tableMd(p);if(tbl)return tbl;if(/^#{1,3}\s+/m.test(p))return p.split(/\n/).map(x=>{const m=x.match(/^(#{1,3})\s+(.+)/);return m?`<h${m[1].length}>${inlineMd(m[2])}</h${m[1].length}>`:`<p>${inlineMd(x)}</p>`}).join('');if(/^>\s+/m.test(p))return '<blockquote>'+p.split(/\n/).map(x=>inlineMd(x.replace(/^>\s?/,''))).join('<br>')+'</blockquote>';if(/^[-•*]\s+/m.test(p)){
  const items = p.split(/\n/).filter(Boolean);
  const html = items.map(x => {
    const text = x.replace(/^[-•*]\s+/,'');
    const formatted = inlineMd(text);
    // If the bullet point is very long (over 80 chars), make it individually collapsible
    if (text.length > 80) {
      const summaryText = clip(text, 50);
      return `<li style="list-style:none; margin-bottom:4px;"><details style="margin-left: -20px;"><summary style="cursor:pointer; color:var(--text); font-size:14px; outline:none;">• ${esc(summaryText)}</summary><div style="padding: 4px 0 4px 20px; color:var(--muted); font-size:13px; border-left: 2px solid var(--line); margin-top:4px;">${formatted}</div></details></li>`;
    }
    return '<li>'+formatted+'</li>';
  }).join('');
  if(items.length > 3) {
    return `<details style="margin: 8px 0; border: 1px solid var(--line); border-radius: 12px; padding: 8px;"><summary style="cursor:pointer; font-weight:850; color:var(--muted); outline:none;">Expand List (${items.length} items)...</summary><ul style="margin-top:8px;">${html}</ul></details>`;
  }
  return '<ul>'+html+'</ul>';
}if(/^\d+[.)]\s+/m.test(p)){return '<ol>'+p.split(/\n/).filter(Boolean).map(x=>'<li>'+inlineMd(x.replace(/^\d+[.)]\s+/,''))+'</li>').join('')+'</ol>'}return '<p>'+inlineMd(p).replace(/\n/g,'<br>')+'</p>'}).join('')}
function formatMsg(s){const raw=String(s||'');return visualMsg(raw)||structuredMsg(raw)||basicFormat(raw)}
function fill(id,items){const el=$(id);if(!el)return;el.innerHTML='';(items?.length?items:['—']).forEach(x=>{const d=document.createElement('div');d.className='li';d.textContent=x;el.appendChild(d)})}function time(s){const d=new Date(s);return isNaN(d)?'':d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}function esc(s){return String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}function toggleTheme(){document.documentElement.classList.toggle('dark');localStorage.theme=document.documentElement.classList.contains('dark')?'dark':'light'}if(localStorage.theme==='dark')document.documentElement.classList.add('dark');$('todoText').addEventListener('keydown',e=>{if(e.key==='Enter')addTodo()});let replyWatch=null;function hasPending(){return (chat().messages||[]).some(m=>m.pending||m.text==='Thinking…')}function watchReply(){clearInterval(replyWatch);let tries=0;replyWatch=setInterval(async()=>{tries++;await load();if(!hasPending()||tries>160)clearInterval(replyWatch)},500)}function pasteFiles(e){const items=[...(e.clipboardData?.items||[])];const files=items.filter(i=>i.kind==='file').map(i=>i.getAsFile()).filter(Boolean);if(files.length){e.preventDefault();handleFiles(files,{append:true})}}$('chatInput').addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat()}});$('chatInput').addEventListener('input',()=>handleSlashSkills('chatInput','skillPop'));$('chatInput').addEventListener('paste',pasteFiles);$('fabText').addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendFab()}});$('fabText').addEventListener('input',()=>handleSlashSkills('fabText','fabSkillPop'));$('fabText').addEventListener('paste',pasteFiles);if('serviceWorker' in navigator){window.addEventListener('load',()=>navigator.serviceWorker.register('/sw.js').catch(()=>{}))}
function updateModelProfile(){const sel=$('modelSelector');if(sel)localStorage.modelProfile=sel.value}if(localStorage.modelProfile){const sel=$('modelSelector');if(sel)sel.value=localStorage.modelProfile}renderModePops();setAction('auto');nav();load();setInterval(load,4000);

document.addEventListener('DOMContentLoaded', () => {
  ['msgList', 'fabMsgList'].forEach(id => {
    const el = $(id);
    if(!el) return;
    el.addEventListener('scroll', () => {
      const isAtBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 30;
      if (isAtBottom) { delete el.dataset.manualScroll; } else { el.dataset.manualScroll = '1'; }
    });
  });
});
document.addEventListener('click',(e)=>{const pop=$('settingsPop');if(pop&&pop.classList.contains('open')&&!e.target.closest('#settingsPop')&&!e.target.closest('#navGear'))pop.classList.remove('open')});

async function exportChat(){
  const c = chat();
  if(!c || !c.messages) return;
  const projectNames = (c.context?.businessIds||[]).map(id => projects().find(p=>p.id===id)?.name).filter(Boolean);
  const header = [
    `# ${c.title||'Chat'}`,
    c.scope ? `Scope: ${c.scope}` : '',
    projectNames.length ? `Projects: ${projectNames.join(', ')}` : '',
    `Exported: ${new Date().toLocaleString()}`,
  ].filter(Boolean).join('\n');
  const body = c.messages.map(m => `\n## ${m.role.toUpperCase()}\n\n${m.text}`).join('\n');
  try {
    await navigator.clipboard.writeText(header+'\n\n---\n'+body);
    alert('Chat exported to clipboard!');
  } catch (err) {
    const ta=document.createElement('textarea');
    ta.value=header+'\n\n---\n'+body;
    ta.style.cssText='position:fixed;top:0;left:0;width:2em;height:2em;padding:0;border:none;outline:none;boxShadow:none;background:transparent;';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    try { document.execCommand('copy'); alert('Chat exported to clipboard!'); } catch(e) { console.error('Copy fallback failed: ', e); alert('Copy failed. Please try again or check permissions.'); }
    document.body.removeChild(ta);
  }
}
async function generateTimetable(){const tl=$('timeline');if(tl)tl.innerHTML='<div class="softNote" style="padding:20px">Scheduling…</div>';try{const d=selectedDate||today();const res=await api('/api/timetable?date='+d);renderTimetable(res.timetable);}catch(e){const tl=$('timeline');if(tl)tl.innerHTML='<div class="softNote" style="padding:20px;color:var(--red)">Failed: '+esc(e.message)+'</div>';}}
function renderTimetable(t){if(!t)return;const tl=$('timeline');if(!tl)return;const cfg=t.config||{};const workStartM=parseTimeStr(cfg.workStart||'08:00');const workEndM=parseTimeStr(cfg.workEnd||'18:00');const totalMin=workEndM-workStartM;const pxPerMin=Math.max(1,tl.parentElement.clientHeight/Math.max(totalMin,60));tl.style.height=(totalMin*pxPerMin)+'px';let html='';for(let m=workStartM;m<=workEndM;m+=60){const h=Math.floor(m/60);const top=(m-workStartM)*pxPerMin;html+=`<div class="timelineHour" style="top:${top}px">${String(h).padStart(2,'0')}:00</div><div class="timelineLine" style="top:${top}px"></div>`;}(t.meetings||[]).forEach(e=>{const start=parseTimeStr(e.startTime);const end=parseTimeStr(e.endTime);const s=Math.max(start,workStartM),e2=Math.min(end,workEndM);if(e2<=s)return;const top=(s-workStartM)*pxPerMin;const h=Math.max(22,(e2-s)*pxPerMin);html+=`<div class="timetableBlock meeting" style="top:${top}px;height:${h}px" title="${esc(e.title||'Meeting')} (${e.startTime}–${e.endTime})"><div class="tbTitle">📅 ${esc(e.title||'Meeting')}</div><div class="tbTime">${e.startTime} – ${e.endTime}</div></div>`;});(t.scheduled||[]).forEach(s=>{const start=parseTimeStr(s.startTime);const end=parseTimeStr(s.endTime);const s2=Math.max(start,workStartM),e2=Math.min(end,workEndM);if(e2<=s2)return;const top=(s2-workStartM)*pxPerMin;const h=Math.max(20,(e2-s2)*pxPerMin);const proj=esc(s.project||'');html+=`<div class="timetableBlock task ${s.priority||'medium'}" style="top:${top}px;height:${h}px" title="${esc(s.text||'Task')} — ${s.startTime}–${s.endTime} · ${s.minutes}m · ${esc(s.project||'')}"><div class="tbTitle">${esc(s.text||'Task')}</div><div class="tbTime">${s.startTime} – ${s.endTime} · ${s.minutes}m · ${proj}</div></div>`;});tl.innerHTML=html;$('ttScheduled').textContent=t.stats?.scheduled||0;$('ttOverflow').textContent=t.stats?.overflow||0;$('ttHours').textContent=((t.stats?.totalMinutes||0)/60).toFixed(1)+'h';$('ttMeetings').textContent=(t.meetings||[]).length;const ol=$('overflowList');if(ol&&t.overflow){ol.innerHTML=(t.overflow||[]).map(t=>`<div class="overflowTask" title="${esc(t.text)} — ${esc(t.project||'Execution')} · ${t.priority} · ${t.minutes}m"><b>${esc(t.text)}</b><div class="tiny">${esc(t.project||'Execution')} · ${t.priority} · ${t.minutes}m</div></div>`).join('')||'<div class="softNote">All tasks scheduled ✓</div>';}}
function parseTimeStr(s){const p=String(s||'').split(':');return (parseInt(p[0])||0)*60+(parseInt(p[1])||0);}
function openTimetableConfig(){const c=$('ttConfigCard');if(c)c.style.display=c.style.display==='none'?'block':'none';}
async function saveTimetableConfig(){const cfg={workStart:$('ttWorkStart').value||'08:00',workEnd:$('ttWorkEnd').value||'18:00',bufferMinutes:parseInt($('ttBuffer').value)||10,maxBlockMinutes:parseInt($('ttMaxBlock').value)||90,breakAt:$('ttBreakAt').value||'12:30',breakMinutes:parseInt($('ttBreakMin').value)||30,preferMornings:$('ttPreferMorning')?.checked??true};await api('/api/timetable/config',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(cfg)});const c=$('ttConfigCard');if(c)c.style.display='none';generateTimetable();}
// Auto-load timetable config on mount
async function loadTimetableConfig(){try{const r=await api('/api/timetable/config');const cfg=r.config||{};for(const[id,v]of[['ttWorkStart',cfg.workStart||'08:00'],['ttWorkEnd',cfg.workEnd||'18:00'],['ttBuffer',cfg.bufferMinutes||10],['ttMaxBlock',cfg.maxBlockMinutes||90],['ttBreakAt',cfg.breakAt||'12:30'],['ttBreakMin',cfg.breakMinutes||30]]){const el=$(id);if(el)el.value=v;}const cb=$('ttPreferMorning');if(cb)cb.checked=cfg.preferMornings!==false;}catch{}}
</script></body></html>