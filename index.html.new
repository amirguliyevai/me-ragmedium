<!DOCTYPE html>
<html lang="en" class="dark"><head><meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>RAGMEDIUM — Command Center</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#06040e;--sidebar:#0a0818;--surface:#0f0d1e;--surface-hover:#16142e;--border:#1e1a3a;--border2:rgba(130,80,255,0.18);--text:#d4d0ec;--muted:#6b6490;--accent:#8250ff;--accent-hover:#9a6fff;--cyan:#00e5ff;--cyan-dim:rgba(0,229,255,0.15);--green:#00ff88;--green-dim:rgba(0,255,136,0.12);--orange:#ff8c00;--orange-dim:rgba(255,140,0,0.12);--red:#ff3366;--red-dim:rgba(255,51,102,0.12);--pink:#ff44aa;--yellow:#ffd700;--glow-purple:0 0 20px rgba(130,80,255,0.3);--radius:8px;--radius-lg:12px;--radius-xl:16px;--font:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;--font-mono:'JetBrains Mono','SF Mono','Fira Code',monospace;--sidebar-w:260px;--rail-w:52px;--topbar-h:44px;font-family:var(--font);font-size:13px;line-height:1.5;color:var(--text)}
:root.light{--bg:#f8f6ff;--sidebar:#fff;--surface:#fff;--surface-hover:#f3f0ff;--border:#e0dcf0;--border2:rgba(100,60,200,0.15);--text:#1a1630;--muted:#6b6490;--accent:#6a35e0;--accent-hover:#7c4dff;--glow-purple:0 0 20px rgba(106,53,224,0.15)}
html{height:100%}body{background:var(--bg);color:var(--text);height:100vh;height:100dvh;overflow:hidden;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:6px;height:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}::-webkit-scrollbar-thumb:hover{background:var(--muted)}*{scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.topbar{height:var(--topbar-h);flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:0 16px;background:var(--sidebar);border-bottom:1px solid var(--border);position:relative;z-index:50}
.topbar-left,.topbar-right{display:flex;align-items:center;gap:8px}
.topbar-logo{display:flex;align-items:center;gap:10px;font-weight:700;font-size:14px;letter-spacing:.02em}
.topbar-logo-icon{width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,var(--accent),var(--cyan));display:flex;align-items:center;justify-content:center;box-shadow:var(--glow-purple)}
.topbar-logo-icon svg{width:16px;height:16px;fill:#fff}
.topbar-title{color:var(--text)}.topbar-title span{color:var(--accent)}
.topbar-btn{width:32px;height:32px;border-radius:8px;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.topbar-btn:hover{background:var(--surface-hover);color:var(--text)}
.topbar-status{display:flex;align-items:center;gap:6px;padding:4px 10px;border-radius:20px;font-size:11px;background:var(--green-dim);color:var(--green);font-weight:500}
.topbar-status-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse-dot 2s infinite}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.5}}
.layout{display:flex;flex:1;min-height:0;overflow:hidden}
.rail{display:none;width:var(--rail-w);flex-shrink:0;flex-direction:column;align-items:center;gap:4px;padding:8px 0;background:var(--sidebar);border-right:1px solid var(--border)}
.rail-btn{width:38px;height:38px;border-radius:10px;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative;transition:all .2s}
.rail-btn:hover{color:var(--text);background:var(--surface-hover)}
.rail-btn.active{color:var(--accent);background:rgba(130,80,255,0.12)}
.rail-btn.active::before{content:'';position:absolute;left:-8px;top:50%;transform:translateY(-50%);width:3px;height:18px;background:var(--accent);border-radius:0 3px 3px 0;box-shadow:0 0 8px var(--accent)}
.rail-btn svg{width:20px;height:20px}
.rail-spacer{flex:1}
.rail-tooltip{position:absolute;left:calc(100% + 12px);top:50%;transform:translateY(-50%);background:var(--surface);color:var(--text);padding:5px 10px;border-radius:6px;font-size:11px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;border:1px solid var(--border);z-index:100}
.rail-btn:hover .rail-tooltip{opacity:1}
@media(min-width:768px){.rail{display:flex}.sidebar-nav{display:none!important}.sidebar{width:var(--sidebar-w)}}
.sidebar{background:var(--sidebar);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;transition:width .3s cubic-bezier(.22,1,.36,1)}
.sidebar-header{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;min-height:49px}
.sidebar-header h3{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--muted)}
.sidebar-nav{flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:2px}
.sidebar-nav-btn{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius);border:none;background:transparent;color:var(--muted);cursor:pointer;font-size:12.5px;font-weight:500;transition:all .15s;width:100%;text-align:left;font-family:var(--font)}
.sidebar-nav-btn:hover{background:var(--surface-hover);color:var(--text)}
.sidebar-nav-btn.active{background:rgba(130,80,255,.1);color:var(--accent)}
.sidebar-nav-btn svg{width:18px;height:18px;flex-shrink:0}
.sidebar-nav-btn .badge{margin-left:auto;background:var(--accent);color:#fff;font-size:10px;padding:2px 7px;border-radius:10px;font-weight:600}
.sidebar-nav-btn .badge.cyan{background:var(--cyan);color:#000}
.sidebar-nav-btn .badge.orange{background:var(--orange);color:#000}
.sidebar-section{padding:16px 14px 6px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);opacity:.6}
.main{flex:1;min-width:0;display:flex;flex-direction:column;overflow:hidden;position:relative}
.panel{position:absolute;inset:0;display:none;flex-direction:column;overflow:hidden}
.panel.active{display:flex}
.panel-header{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;background:rgba(10,8,24,.6);backdrop-filter:blur(10px)}
.panel-title{font-size:15px;font-weight:600;display:flex;align-items:center;gap:10px}
.panel-title-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:rgba(130,80,255,.12);color:var(--accent)}
.panel-title-icon svg{width:16px;height:16px}
.panel-actions{display:flex;gap:6px}
.panel-body{flex:1;overflow-y:auto;padding:20px}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:20px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;transition:all .2s}
.stat-card:hover{border-color:var(--border2);transform:translateY(-1px)}
.stat-label{font-size:11px;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em}
.stat-value{font-size:22px;font-weight:700;font-family:var(--font-mono)}
.stat-change{font-size:11px;margin-top:4px}.stat-change.up{color:var(--green)}.stat-change.down{color:var(--red)}
.card-cyan{color:var(--cyan)}.card-green{color:var(--green)}.card-orange{color:var(--orange)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;font-family:var(--font)}
.btn:hover{border-color:var(--border2);background:var(--surface-hover)}
.btn-primary{background:linear-gradient(135deg,var(--accent),#6a35e0);border-color:transparent;color:#fff;box-shadow:var(--glow-purple)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 0 30px rgba(130,80,255,.4)}
.btn-sm{padding:5px 10px;font-size:11px}
.btn svg{width:14px;height:14px}
.tag{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500}
.tag-purple{background:rgba(130,80,255,.15);color:var(--accent)}
.tag-cyan{background:var(--cyan-dim);color:var(--cyan)}
.tag-green{background:var(--green-dim);color:var(--green)}
.tag-orange{background:var(--orange-dim);color:var(--orange)}
.tag-red{background:var(--red-dim);color:var(--red)}
.feed{display:flex;flex-direction:column;gap:12px}
.feed-item{display:flex;gap:12px;padding:12px;border-radius:var(--radius);border:1px solid var(--border);transition:all .15s}
.feed-item:hover{border-color:var(--border2)}
.feed-avatar{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;flex-shrink:0}
.feed-content{flex:1;min-width:0}
.feed-header{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.feed-name{font-weight:600;font-size:12.5px}
.feed-time{font-size:11px;color:var(--muted);margin-left:auto}
.feed-text{font-size:12px;color:var(--muted);line-height:1.5}
.kanban{display:flex;gap:14px;overflow-x:auto;padding-bottom:12px}
.kanban-col{min-width:240px;flex:1;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:12px}
.kanban-col-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.kanban-col-title{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.kanban-col-count{font-size:10px;background:var(--border);padding:2px 8px;border-radius:10px}
.kanban-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:10px 12px;margin-bottom:8px;cursor:grab;transition:all .15s}
.kanban-card:hover{border-color:var(--border2);transform:translateY(-1px)}
.kanban-card-title{font-size:12.5px;font-weight:500;margin-bottom:6px}
.kanban-card-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.kanban-card-tag{font-size:10px;padding:2px 6px;border-radius:4px;background:rgba(130,80,255,.12);color:var(--accent)}
.kanban-card-tag.high{background:var(--red-dim);color:var(--red)}
.kanban-card-tag.medium{background:var(--orange-dim);color:var(--orange)}
.memory-search{width:100%;padding:10px 14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:13px;margin-bottom:16px;font-family:var(--font)}
.memory-search:focus{outline:none;border-color:var(--accent)}
.memory-list{display:flex;flex-direction:column;gap:10px}
.memory-item{padding:14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface)}
.memory-item:hover{border-color:var(--border2)}
.memory-item-header{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.memory-item-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;background:rgba(130,80,255,.12);font-size:12px}
.memory-item-title{font-size:12.5px;font-weight:600}
.memory-item-time{font-size:10px;color:var(--muted);margin-left:auto}
.memory-item-text{font-size:12px;color:var(--muted);line-height:1.6}
.gateway-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px}
.gateway-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px}
.gateway-card-header{display:flex;align-items:center;gap:8px;margin-bottom:12px}
.gateway-status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 10px var(--green);animation:pulse-dot 2s infinite}
.gateway-status-dot.warn{background:var(--orange);box-shadow:0 0 10px var(--orange)}
.gateway-card-title{font-size:12.5px;font-weight:600}
.gateway-card-value{font-size:20px;font-weight:700;font-family:var(--font-mono);margin:4px 0}
.gateway-card-sub{font-size:11px;color:var(--muted)}
.progress{height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.progress-bar{height:100%;border-radius:3px;transition:width .5s}
.progress-bar.purple{background:linear-gradient(90deg,var(--accent),var(--cyan))}
.progress-bar.cyan{background:var(--cyan)}
.chat-panel{display:flex;flex-direction:column;height:100%}
.chat-messages{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px}
.chat-msg{display:flex;gap:12px;max-width:800px}
.chat-msg-avatar{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.chat-msg-body{flex:1}
.chat-msg-name{font-size:12px;font-weight:600;margin-bottom:4px}
.chat-msg-text{font-size:13px;line-height:1.6}
.composer{flex-shrink:0;padding:12px 20px;background:var(--sidebar);border-top:1px solid var(--border)}
.composer-box{display:flex;align-items:flex-end;gap:10px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-xl);padding:10px 16px;transition:border-color .15s,box-shadow .15s}
.composer-box:focus-within{border-color:var(--accent);box-shadow:var(--glow-purple)}
.composer-input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-size:13px;font-family:var(--font);resize:none;min-height:24px;max-height:120px;line-height:1.5}
.composer-input::placeholder{color:var(--muted)}
.composer-btn{width:36px;height:36px;border-radius:10px;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.composer-btn:hover{background:var(--surface-hover);color:var(--text)}
.composer-btn.send{background:linear-gradient(135deg,var(--accent),#6a35e0);color:#fff;box-shadow:var(--glow-purple)}
.composer-btn svg{width:18px;height:18px}
.tabs{display:flex;gap:4px;padding:0 20px;border-bottom:1px solid var(--border);flex-shrink:0;background:rgba(10,8,24,.4)}
.tab{padding:10px 16px;border:none;background:transparent;color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;font-family:var(--font)}
.tab:hover{color:var(--text)}.tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px}
.team-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;text-align:center;transition:all .2s}
.team-avatar{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#fff;margin:0 auto 12px}
.team-name{font-size:13px;font-weight:600;margin-bottom:4px}.team-role{font-size:11px;color:var(--muted);margin-bottom:10px}
.team-status{display:inline-flex;align-items:center;gap:5px;font-size:11px;padding:3px 10px;border-radius:20px}
.team-status.online{background:var(--green-dim);color:var(--green)}
.team-status.away{background:var(--orange-dim);color:var(--orange)}
.empire-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px}
.empire-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;transition:all .2s}
.empire-card:hover{border-color:var(--border2)}
.empire-card-cover{height:100px;background:linear-gradient(135deg,rgba(130,80,255,.2),rgba(0,229,255,.1));display:flex;align-items:center;justify-content:center;font-size:28px}
.empire-card-body{padding:14px}.empire-card-title{font-size:13px;font-weight:600;margin-bottom:6px}
.empire-card-meta{font-size:11px;color:var(--muted);display:flex;gap:10px;align-items:center}
.brain-container{position:relative;flex:1;overflow:hidden}
.brain-canvas{width:100%;height:100%;display:block}
#galaxy-container{position:absolute;inset:0;z-index:0}
.boardCols{display:flex;gap:10px;overflow-x:auto;padding-bottom:12px}
.boardCol{min-width:200px;flex:1;background:rgba(15,13,30,0.6);border:1px solid var(--border);border-radius:12px;padding:8px;display:flex;flex-direction:column}
.boardCard{padding:8px 10px;background:rgba(22,20,46,0.8);border:1px solid var(--border);border-radius:8px;margin-bottom:6px;cursor:pointer;border-left:3px solid var(--accent)}
.boardCard:hover{border-color:var(--accent)}
@media(max-width:767px){
  .sidebar{position:fixed;left:0;top:var(--topbar-h);bottom:0;width:85vw;max-width:320px;z-index:100;transform:translateX(-100%);transition:transform .3s cubic-bezier(.22,1,.36,1);display:flex}
  .sidebar.open{transform:translateX(0)}
  .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99}
  .sidebar-overlay.active{display:block}
  .stats-grid{grid-template-columns:1fr 1fr}.team-grid{grid-template-columns:1fr 1fr}.empire-grid{grid-template-columns:1fr}
}
@media(max-width:480px){.stats-grid{grid-template-columns:1fr}.team-grid{grid-template-columns:1fr}}
.text-muted{color:var(--muted)}.text-sm{font-size:11px}.mt-2{margin-top:8px}
</style>
</head>
<body>
<header class="topbar">
  <div class="topbar-left">
    <button class="topbar-btn" id="menuBtn" onclick="toggleMobileSidebar()"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    <div class="topbar-logo"><div class="topbar-logo-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div><div class="topbar-title">RAG<span>MEDIUM</span></div></div>
  </div>
  <div class="topbar-right">
    <div class="topbar-status"><div class="topbar-status-dot"></div>Gateway Online</div>
    <button class="topbar-btn" onclick="toggleTheme()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></button>
    <button class="topbar-btn" onclick="switchPanel('gateway')"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06-.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
  </div>
</header>
<div class="layout">
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleMobileSidebar()"></div>
  <nav class="rail" id="rail">
    <button class="rail-btn active" data-panel="galaxy" onclick="switchPanel('galaxy')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg><span class="rail-tooltip">Galaxy</span></button>
    <button class="rail-btn" data-panel="chat" onclick="switchPanel('chat')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span class="rail-tooltip">Chat</span></button>
    <button class="rail-btn" data-panel="content" onclick="switchPanel('content')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg><span class="rail-tooltip">Content</span></button>
    <button class="rail-btn" data-panel="agents" onclick="switchPanel('agents')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg><span class="rail-tooltip">Agents</span></button>
    <button class="rail-btn" data-panel="brain" onclick="switchPanel('brain')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2z"/></svg><span class="rail-tooltip">Brain</span></button>
    <button class="rail-btn" data-panel="memory" onclick="switchPanel('memory')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg><span class="rail-tooltip">Memory</span></button>
    <button class="rail-btn" data-panel="tasks" onclick="switchPanel('tasks')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg><span class="rail-tooltip">Tasks</span></button>
    <button class="rail-btn" data-panel="gateway" onclick="switchPanel('gateway')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/></svg><span class="rail-tooltip">Gateway</span></button>
    <div class="rail-spacer"></div>
    <button class="rail-btn" data-panel="team" onclick="switchPanel('team')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><span class="rail-tooltip">Team</span></button>
    <button class="rail-btn" data-panel="analytics" onclick="switchPanel('analytics')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg><span class="rail-tooltip">Analytics</span></button>
  </nav>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header"><h3>Navigation</h3><button class="topbar-btn" onclick="toggleMobileSidebar()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="sidebar-nav">
      <button class="sidebar-nav-btn active" data-panel="galaxy" onclick="switchPanel('galaxy')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg>Galaxy</button>
      <button class="sidebar-nav-btn" data-panel="chat" onclick="switchPanel('chat')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Chat</button>
      <button class="sidebar-nav-btn" data-panel="content" onclick="switchPanel('content')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>Content</button>
      <button class="sidebar-nav-btn" data-panel="agents" onclick="switchPanel('agents')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Agents</button>
      <button class="sidebar-nav-btn" data-panel="brain" onclick="switchPanel('brain')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2z"/></svg>Brain</button>
      <div class="sidebar-section">Intelligence</div>
      <button class="sidebar-nav-btn" data-panel="memory" onclick="switchPanel('memory')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>Memory <span class="badge cyan">2.4k</span></button>
      <button class="sidebar-nav-btn" data-panel="tasks" onclick="switchPanel('tasks')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>Tasks <span class="badge orange">7</span></button>
      <button class="sidebar-nav-btn" data-panel="gateway" onclick="switchPanel('gateway')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/></svg>Gateway</button>
      <div class="sidebar-section">Operations</div>
      <button class="sidebar-nav-btn" data-panel="team" onclick="switchPanel('team')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>Team</button>
      <button class="sidebar-nav-btn" data-panel="analytics" onclick="switchPanel('analytics')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>Analytics</button>
      <button class="sidebar-nav-btn" data-panel="slack" onclick="switchPanel('slack')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>Slack</button>
      <button class="sidebar-nav-btn" data-panel="vault" onclick="switchPanel('vault')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Vault</button>
