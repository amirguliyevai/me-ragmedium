// ─── Interaction ───
const raycaster=new THREE.Raycaster();
const pointer=new THREE.Vector2();
let selectedEntity=null;
const hoverLabel=document.getElementById('hover-label');
let hoveredObj=null;

renderer.domElement.addEventListener('pointermove',(e)=>{
  pointer.x=(e.clientX/innerWidth)*2-1;
  pointer.y=-(e.clientY/innerHeight)*2+1;
});

renderer.domElement.addEventListener('click',(e)=>{
  pointer.x=(e.clientX/innerWidth)*2-1;
  pointer.y=-(e.clientY/innerHeight)*2+1;
  raycaster.setFromCamera(pointer,camera);
  const intersects=raycaster.intersectObjects(scene.children,true);
  for(const hit of intersects){
    let obj=hit.object;
    while(obj.parent&&!(obj.userData?.isEntity||obj.userData?.agent)){
      obj=obj.parent;
    }
    if(obj.userData?.isEntity){
      focusEntity(obj.userData.entityId);
      openDashboard(obj.userData.entityId);
      return;
    }
    if(obj.userData?.agent){
      focusAgent(obj.userData.agent);
      return;
    }
  }
});

function focusEntity(id){
  const pos=entityPositions[id];
  if(!pos)return;
  selectedEntity=id;
  controls.target.set(pos.x,pos.y,pos.z);
  // Highlight label
  Object.keys(entityLabels).forEach(k=>{
    entityLabels[k].element.style.opacity=k===id?'1':'0';
  });
}

function focusAgent(agent){
  const ship=ships.find(s=>s.userData.agent?.id===agent.id);
  if(!ship)return;
  controls.target.copy(ship.position);
  openAgentPanel(agent);
}

// ─── Dashboard Modal ───
function openDashboard(id){
  const ent=entities.find(e=>e.id===id);
  if(!ent)return;
  const modal=document.getElementById('dash-modal');
  const inner=document.getElementById('dash-inner');
  const color='#'+new THREE.Color(COLORS[ent.color]).getHexString();
  
  inner.innerHTML=`
    <div class="dash-header">
      <h2 style="color:${color}">${ent.label}</h2>
      <div class="sub">// ${ent.tag} · Radial ${ent.level}</div>
    </div>
    <div class="dash-grid">
      <div class="dash-card"><div class="lbl">Status</div><div class="val small">Active</div></div>
      <div class="dash-card"><div class="lbl">Agents</div><div class="val">${agents.filter(a=>a.target===id).length}</div></div>
      <div class="dash-card"><div class="lbl">Priority</div><div class="val small">${ent.level>=3?'High':ent.level>=2?'Medium':'Normal'}</div></div>
    </div>
    <div class="dash-section">
      <h3>AI Suggestions</h3>
      <ul class="dash-list">
        <li>Prioritise ${ent.label} deliverables for this week</li>
        <li>Review ${ent.label} agent assignments — ${agents.filter(a=>a.target===id).map(a=>a.name).join(', ')||'none assigned'}</li>
        <li>${ent.label} could benefit from a focused sprint</li>
      </ul>
    </div>
    <div class="dash-section">
      <h3>Next Steps</h3>
      <ul class="dash-list">
        <li>Check ${ent.label} current status</li>
        <li>Review backlog and update priorities</li>
        <li>Sync with team on deliverables</li>
      </ul>
    </div>
    <div class="dash-section">
      <h3>Active Agents</h3>
      <ul class="dash-list">
        ${agents.filter(a=>a.target===id).map(a=>`<li>${a.name} — ${a.task} [${a.status}]</li>`).join('')||'<li>No agents assigned</li>'}
      </ul>
    </div>`;
  modal.classList.add('open');
}

function openAgentPanel(agent){
  const modal=document.getElementById('dash-modal');
  const inner=document.getElementById('dash-inner');
  const c='#'+new THREE.Color(agent.color).getHexString();
  inner.innerHTML=`
    <div class="dash-header">
      <h2 style="color:${c}">${agent.name}</h2>
      <div class="sub">// ${agent.task} · Level ${agent.level}</div>
    </div>
    <div class="dash-grid">
      <div class="dash-card"><div class="lbl">Status</div><div class="val small">${agent.status}</div></div>
      <div class="dash-card"><div class="lbl">Current Task</div><div class="val small">${agent.task}</div></div>
      <div class="dash-card"><div class="lbl">Assigned To</div><div class="val small">${agent.target}</div></div>
    </div>
    <div class="dash-section">
      <h3>Action Items</h3>
      <ul class="dash-list">
        <li>Complete current ${agent.task}</li>
        <li>Report results to command</li>
        <li>${agent.status==='stuck'?'⚠️ Needs intervention — reassign or unblock':'Standing by for next directive'}</li>
      </ul>
    </div>`;
  modal.classList.add('open');
}

document.getElementById('dash-close').addEventListener('click',()=>{
  document.getElementById('dash-modal').classList.remove('open');
});

// ─── Sidebar Population ───
function populateSidebars(){
  const pl=document.getElementById('project-list');
  entities.forEach(e=>{
    if(e.id==='amir')return;
    const c='#'+new THREE.Color(COLORS[e.color]).getHexString();
    const item=document.createElement('div');item.className='sb-item';
    item.innerHTML=`<span class="dot" style="background:${c}"></span><span class="lbl">${e.label}</span>`;
    item.addEventListener('click',()=>{focusEntity(e.id);openDashboard(e.id);});
    pl.appendChild(item);
  });
  
  const al=document.getElementById('agent-list');
  agents.forEach(a=>{
    const s=a.status==='active'?'#34d399':a.status==='resting'?'#fbbf24':'#ef4444';
    const item=document.createElement('div');item.className='sb-agent';
    item.innerHTML=`<span class="stat" style="background:${s}"></span><span class="aname">${a.name}</span><span class="atask">${a.task}</span>`;
    item.addEventListener('click',()=>{focusAgent(a);});
    al.appendChild(item);
  });
}
populateSidebars();

// ─── Chat ───
const chatInput=document.getElementById('chat-input');
const chatSend=document.getElementById('chat-send');
const chatThink=document.getElementById('chat-think');
let chatPending=false;

chatSend.addEventListener('click',sendChat);
chatInput.addEventListener('keydown',(e)=>{if(e.key==='Enter')sendChat();});

async function sendChat(){
  const text=chatInput.value.trim();
  if(!text||chatPending)return;
  chatInput.value='';
  chatPending=true;
  chatThink.classList.add('active');
  try{
    const res=await fetch('/api/assistant/chat',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({message:text})
    });
    const data=await res.json();
    if(data.ok&&data.reply){
      // Brief flash feedback
      chatInput.placeholder='✓ Command sent';
      setTimeout(()=>chatInput.placeholder='Command galaxy...',2000);
    }
  }catch(e){
    chatInput.placeholder='✗ Failed to reach gateway';
    setTimeout(()=>chatInput.placeholder='Command galaxy...',3000);
  }
  chatPending=false;
  chatThink.classList.remove('active');
}

// Mic button (placeholder)
document.getElementById('chat-mic').addEventListener('click',()=>{
  alert('🎤 Voice mode coming soon — speak your command');
});

// ─── Animation ───
const clock=new THREE.Clock();

function animate(){
  requestAnimationFrame(animate);
  const dt=Math.min(clock.getDelta(),0.05);
  const t=performance.now()*0.001;
  
  controls.update();
  
  // Rotate core particles
  particles.rotation.y+=0.003;
  particles.rotation.x+=0.001;
  
  // Animate ship orbits
  ships.forEach(ship=>{
    const ud=ship.userData;
    const tPos=entityPositions[ud.targetId];
    if(!tPos)return;
    ud.angle+=ud.speed*dt;
    const x=Math.cos(ud.angle)*ud.orbitRadius;
    const z=Math.sin(ud.angle)*ud.orbitRadius;
    ship.position.x=tPos.x+x;
    ship.position.z=tPos.z+z;
    ship.position.y=tPos.y+ud.yOffset;
    ship.rotation.y+=0.5*dt;
    // Update label
    const lbl=shipLabels[ud.agent.id];
    if(lbl){
      lbl.position.copy(ship.position);
      lbl.position.y+=ud.agent.level===0?5:2.5;
    }
  });
  
  // Hover label
  raycaster.setFromCamera(pointer,camera);
  const hits=raycaster.intersectObjects(scene.children,true);
  let found=null;
  for(const hit of hits){
    let obj=hit.object;
    while(obj.parent&&!(obj.userData?.isEntity||obj.userData?.agent))obj=obj.parent;
    if(obj.userData?.isEntity||obj.userData?.agent){
      found=obj;break;
    }
  }
  if(found){
    const id=found.userData?.entityId||found.userData?.agent?.id;
    const name=found.userData?.entityId?entities.find(e=>e.id===id)?.label:found.userData?.agent?.name;
    if(name){
      hoverLabel.textContent=found.userData?.entityId?'◈ '+name:'▸ '+name;
      hoverLabel.style.display='block';
      hoverLabel.style.left=(pointer.x*0.5+0.5)*innerWidth+15+'px';
      hoverLabel.style.top=(pointer.y*-0.5+0.5)*innerHeight-20+'px';
    }
  }else{
    hoverLabel.style.display='none';
  }
  
  // Render
  renderer.render(scene,camera);
  labelRenderer.render(scene,camera);
}
animate();

// ─── Resize ───
addEventListener('resize',()=>{
  camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
  labelRenderer.setSize(innerWidth,innerHeight);
});
</script>
</body>
</html>
