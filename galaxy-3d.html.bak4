const rPos={x:-100,y:30,z:80};
repairGroup.position.set(rPos.x,rPos.y,rPos.z);
const pad=new THREE.Mesh(new THREE.CircleGeometry(12,24),
  new THREE.MeshBasicMaterial({color:0x00aaff,transparent:true,opacity:0.05,side:THREE.DoubleSide}));
pad.rotation.x=-Math.PI/2;repairGroup.add(pad);
const ringR=new THREE.Mesh(new THREE.TorusGeometry(12,0.08,8,32),
  new THREE.MeshBasicMaterial({color:0x00aaff,transparent:true,opacity:0.15}));
repairGroup.add(ringR);
const rLabel=document.createElement('div');
rLabel.textContent='⚕ REPAIR YARD';
rLabel.style.cssText='color:rgba(0,200,255,0.2);font-size:8px;letter-spacing:3px;font-family:monospace';
