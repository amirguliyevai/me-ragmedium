function buildShip(agent,size,color){
  const g=new THREE.Group();const c=new THREE.Color(color);
  const m=new THREE.MeshPhysicalMaterial({color,emissive:color,emissiveIntensity:0.3,roughness:0.3,metalness:0.7});
  // Hull
  const hull=new THREE.Mesh(new THREE.ConeGeometry(size*0.3,size*1.2,8),m);
  hull.rotation.x=Math.PI/2;g.add(hull);
  // Cockpit
  const cockpit=new THREE.Mesh(new THREE.SphereGeometry(size*0.2,8,8),
    new THREE.MeshBasicMaterial({color:0x88ccff,transparent:true,opacity:0.6}));
  cockpit.position.set(0,0,size*0.4);g.add(cockpit);
  // Wings
  const wing=new THREE.Mesh(new THREE.BoxGeometry(size*1.0,size*0.05,size*0.1),m);
  wing.position.set(0,0,0);g.add(wing);
  // Engine glow
  const glow=new THREE.Mesh(new THREE.SphereGeometry(size*0.15,6,6),
    new THREE.MeshBasicMaterial({color:0x44aaff,transparent:true,opacity:0.5,blending:THREE.AdditiveBlending}));
  glow.position.set(0,0,-size*0.6);g.add(glow);
  return g;
}

function buildMothership(size,color){
  const g=new THREE.Group();const c=new THREE.Color(color);
  const m=new THREE.MeshPhysicalMaterial({color,emissive:color,emissiveIntensity:0.5,roughness:0.2,metalness:0.8});
  // Main body
  const body=new THREE.Mesh(new THREE.CylinderGeometry(size*0.6,size,size*0.4,8),m);
  g.add(body);
  // Ring
  const ring=new THREE.Mesh(new THREE.TorusGeometry(size*0.8,0.08,8,32),
    new THREE.MeshBasicMaterial({color,transparent:true,opacity:0.4}));
  ring.rotation.x=Math.PI/3;g.add(ring);
  const ring2=ring.clone();ring2.rotation.x=-Math.PI/4;g.add(ring2);
  // Core glow
  const core=new THREE.Mesh(new THREE.SphereGeometry(size*0.4,16,16),
    new THREE.MeshBasicMaterial({color:0xffffff,transparent:true,opacity:0.3}));
  g.add(core);
  return g;
}

const ships=[];
const shipLabels={};

agents.forEach((agent,i)=>{
  const targetEnt=entities.find(e=>e.id===agent.target);
  if(!targetEnt)return;
  const tPos=entityPositions[agent.target];
  const size=agent.level===0?3:agent.level===1?1.8:0.9;
  const group=agent.level===0?buildMothership(size,agent.color):buildShip(agent,size,agent.color);
  
  // Start position near target
  const angle=Math.random()*Math.PI*2;
  const yOff=(Math.random()-0.5)*6;
  group.position.set(tPos.x+Math.cos(angle)*4,tPos.y+yOff,tPos.z+Math.sin(angle)*4);
  group.userData={agent,targetId:agent.target,speed:0.3+Math.random()*0.2,angle:Math.random()*Math.PI*2,orbitRadius:3+Math.random()*4,yOffset:yOff};
  scene.add(group);
  ships.push(group);
  clickTargets.push(group);
  
  // Hover label
  const l=document.createElement('div');
  l.textContent=agent.name;
  l.style.cssText='color:rgba(255,255,255,0.5);font-size:7px;letter-spacing:1px;font-family:monospace;'+
    'transition:opacity 0.2s;opacity:0;pointer-events:none;background:rgba(0,0,0,0.5);padding:1px 4px;border-radius:2px;white-space:nowrap';
  const lbl=new CSS2DObject(l);
  lbl.position.copy(group.position);lbl.position.y+=size*1.5;
  scene.add(lbl);
  shipLabels[agent.id]=lbl;
});

// ─── Repair Yard ───
