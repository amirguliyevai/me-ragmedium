<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>JARVIS GALAXY — Command Center</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#000;overflow:hidden;font-family:Inter,system-ui,-apple-system,sans-serif;width:100vw;height:100vh;touch-action:none}
canvas{display:block}
#hud{position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;z-index:10}
#hud>*{pointer-events:auto}
#topbar{position:fixed;top:16px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:20}
.top-btn{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);padding:6px 14px;border-radius:20px;font-size:11px;cursor:pointer;font-family:inherit;transition:all 0.2s;backdrop-filter:blur(10px)}
.top-btn:hover,.top-btn.active{background:rgba(249,115,22,0.15);border-color:rgba(249,115,22,0.3);color:#f97316}
.voice-btn{background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#22c55e;padding:6px 14px;border-radius:20px;font-size:11px;cursor:pointer;font-family:inherit;transition:all 0.2s;backdrop-filter:blur(10px)}
.voice-btn:hover{background:rgba(34,197,94,0.25)}
.voice-btn.listening{background:rgba(239,68,68,0.3);border-color:rgba(239,68,68,0.5);color:#ef4444;animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.6}}
#hand-toggle{position:fixed;top:16px;right:16px;z-index:20;background:rgba(15,15,25,0.9);border:1px solid rgba(255,255,255,0.12);color:#aaa;padding:8px 14px;border-radius:20px;cursor:pointer;font-size:11px;font-family:system-ui,sans-serif;transition:all 0.2s;backdrop-filter:blur(10px)}
#hand-toggle:hover{color:#fff;border-color:rgba(255,255,255,0.3)}
#hand-toggle.on{color:#34d399;border-color:#34d399;box-shadow:0 0 12px rgba(52,211,153,0.2)}
#hand-debug{position:fixed;bottom:100px;left:50%;transform:translateX(-50%);z-index:10;display:none;gap:12px;font-size:10px;color:#555;font-family:monospace}
#hand-debug.show{display:flex}
#cam-preview{position:fixed;bottom:16px;right:16px;z-index:15;width:120px;height:90px;border-radius:8px;border:1px solid rgba(255,255,255,0.08);overflow:hidden;opacity:0;transition:opacity 0.3s}
#cam-preview.on{opacity:0.5}
#cam-preview video{width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
#voice-status{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.8);border:1px solid rgba(34,197,94,0.3);border-radius:12px;padding:12px 20px;font-size:12px;color:#22c55e;z-index:40;display:none;backdrop-filter:blur(10px)}
#agent-panel{position:fixed;right:16px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:4px;z-index:20;max-height:70vh;overflow-y:auto}
.ap-agent{display:flex;align-items:center;gap:6px;padding:6px 10px;border-radius:8px;cursor:pointer;background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.04);transition:all 0.2s;backdrop-filter:blur(8px);min-width:140px}
.ap-agent:hover{background:rgba(249,115,22,0.12);border-color:rgba(249,115,22,0.2)}
.ap-agent.selected{border-color:#f97316;background:rgba(249,115,22,0.15)}
.ap-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.ap-name{font-size:10px;color:rgba(255,255,255,0.8);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.ap-task{font-size:8px;color:rgba(255,255,255,0.3)}
#info-modal{position:fixed;top:0;right:-520px;width:480px;height:100vh;background:linear-gradient(160deg,rgba(13,17,23,0.97),rgba(15,25,35,0.97));border-left:1px solid rgba(255,255,255,0.06);transition:right 0.4s cubic-bezier(0.16,1,0.3,1);z-index:30;overflow-y:auto;backdrop-filter:blur(20px)}
#info-modal.open{right:0;box-shadow:-30px 0 80px rgba(0,0,0,0.6)}
#modal-close{position:sticky;top:12px;float:right;margin-right:12px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:#fff;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:14px}
#modal-content{padding:24px;clear:both}
.modal-title{font-size:22px;font-weight:700;margin-bottom:4px}
.modal-sub{font-size:11px;color:#6b7280;margin-bottom:16px}
.modal-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:14px;margin-bottom:10px}
.modal-card h4{font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.agent-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;font-size:10px;margin:2px;cursor:pointer}
#help-hint{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);font-size:10px;color:rgba(255,255,255,0.2);z-index:15;transition:opacity 0.5s}
#loading{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);color:rgba(255,255,255,0.3);font-size:12px;z-index:5}
</style>
</head>
<body>
<div id="voice-status">🎤 Listening... speak now</div>
<div id="loading">⚡ INITIALIZING GALAXY...</div>
<div id="topbar">
  <button class="top-btn active" onclick="viewAll()">🌌 ALL</button>
  <button class="top-btn" onclick="viewTier('startups')">🚀 STARTUPS</button>
  <button class="top-btn" onclick="viewTier('clients')">👥 CLIENTS</button>
  <button class="top-btn" onclick="viewTier('platforms')">🖥️ PLATFORMS</button>
  <button class="top-btn" onclick="window.open('/slack','_blank')">💬 SLACK</button>
  <button class="voice-btn" id="voice-btn" onclick="toggleVoice()">🎤 VOICE</button>
</div>
<div id="agent-panel"></div>
<div id="info-modal"><button id="modal-close" onclick="closeModal()">✕</button><div id="modal-content"></div></div>
<div id="help-hint">🖱 Drag to rotate · Scroll to zoom · Click planets & ships</div>
<button id="hand-toggle" onclick="toggleHandTracking()">🖐️ Hand Control</button>
<div id="hand-debug"><span id="hd-gesture">idle</span><span id="hd-pos">0,0</span></div>
<div id="cam-preview"><video id="cam-video" autoplay playsinline></video></div>

<script type="importmap">
{"imports":{"three":"https://unpkg.com/three@0.160.0/build/three.module.js","three/addons/":"https://unpkg.com/three@0.160.0/examples/jsm/"}}
</script>

<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

// ─── Scene Setup ───
const W=window.innerWidth,H=window.innerHeight;
const scene=new THREE.Scene();
scene.fog=new THREE.FogExp2(0x000011,0.000015);

const camera=new THREE.PerspectiveCamera(55,W/H,1,600);
camera.position.set(0,30,120);

const renderer=new THREE.WebGLRenderer({antialias:true,alpha:true});
renderer.setSize(W,H);renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=1.2;
document.body.appendChild(renderer.domElement);

const labelRenderer=new CSS2DRenderer();
labelRenderer.setSize(W,H);labelRenderer.domElement.style.position='fixed';
labelRenderer.domElement.style.top='0';labelRenderer.domElement.style.pointerEvents='none';
document.body.appendChild(labelRenderer.domElement);

// Orbit Controls
const controls=new OrbitControls(camera,renderer.domElement);
controls.enableDamping=true;controls.dampingFactor=0.08;
controls.minDistance=15;controls.maxDistance=250;
controls.zoomSpeed=1.2;controls.rotateSpeed=0.5;
controls.target.set(0,0,0);controls.update();

// ─── Lighting ───
scene.add(new THREE.AmbientLight(0x111133,0.6));
const sun=new THREE.PointLight(0xff9944,80,200);sun.position.set(0,0,0);scene.add(sun);
const blueLight=new THREE.PointLight(0x4488ff,30,150);blueLight.position.set(40,20,-30);scene.add(blueLight);

// ─── Background Stars ───
const stars=new THREE.BufferGeometry();
const starPositions=new Float32Array(2000*3);
for(let i=0;i<2000*3;i+=3){
  const r=120+Math.random()*80;
  const theta=Math.random()*Math.PI*2,phi=Math.acos(2*Math.random()-1);
  starPositions[i]=r*Math.sin(phi)*Math.cos(theta);
  starPositions[i+1]=r*Math.sin(phi)*Math.sin(theta);
  starPositions[i+2]=r*Math.cos(phi);
}
stars.setAttribute('position',new THREE.BufferAttribute(starPositions,3));
scene.add(new THREE.Points(stars,new THREE.PointsMaterial({color:0xffffff,size:0.15,transparent:true,opacity:0.5})));

// Grid
const grid=new THREE.PolarGridHelper(100,64,48,64,0x111133,0x111133);
grid.position.y=-50;scene.add(grid);

// ─── DATA ───
const PROJECTS=[
  {id:'amir',name:'AMIR',tier:'core',color:0xf59e0b,size:5,desc:'Command Center',agents:['kaneki','cmo','cto','cfo']},
  // Startups
  {id:'lamatrader',name:'LamaTrader',tier:'startups',color:0xf59e0b,size:3.5,desc:'Integrated Trader Environment',agents:['lamatrader-lead']},
  {id:'grademy',name:'Grademy',tier:'startups',color:0xa855f7,size:3,desc:'AI Learning Ecosystem',agents:['grademy-lead']},
  {id:'pripitch',name:'Pripitch',tier:'startups',color:0xec4899,size:3,desc:'Pitch Platform — Revival Sprint',agents:['pripitch-lead']},
  {id:'rema',name:'Remit Exteriors',tier:'startups',color:0x06b6d4,size:2.5,desc:'Construction Projects',agents:['rema-lead']},
  {id:'content-empire',name:'Content Empire',tier:'startups',color:0xf97316,size:3,desc:'Content + Brogen',agents:['content-director']},
  // Clients
  {id:'halal-booking',name:'Halal Booking',tier:'clients',color:0x84cc16,size:2,desc:'Booking Platform',agents:['ventures-pm']},
  {id:'cinematicx',name:'CinematicX',tier:'clients',color:0x64748b,size:2,desc:'NDA Client',agents:['ventures-pm']},
  {id:'unitas',name:'Unitas',tier:'clients',color:0x64748b,size:2,desc:'Client Project',agents:['ventures-pm']},
  {id:'waterspring',name:'Waterspring',tier:'clients',color:0x38bdf8,size:2,desc:'Client Project',agents:['ventures-pm']},
  // Platforms
  {id:'ai-ragmedium',name:'ai.ragmedium',tier:'platforms',color:0x14b8a6,size:2.5,desc:'B2C Marketing Platform',agents:['outreach-head']},
  {id:'reach-inbox',name:'Reach Inbox',tier:'platforms',color:0x0ea5e9,size:2.5,desc:'300 Verified Inboxes',agents:['outreach-head','cold-email']},
  {id:'content-studio',name:'Content Studio',tier:'platforms',color:0xf97316,size:2.5,desc:'11-Module Suite',agents:['content-director']},
  {id:'dashboard',name:'Dashboard',tier:'platforms',color:0x3b82f6,size:2,desc:'Command Center :1702',agents:['kaneki']},
];

const AGENTS=[
  {id:'kaneki',name:'KANEKI',level:0,color:0xf59e0b,target:'amir',task:'Chief AI — Command & Control'},
  {id:'cmo',name:'CMO',level:1,color:0x8b5cf6,target:'amir',task:'Marketing & Outreach'},
  {id:'cto',name:'CTO',level:1,color:0x3b82f6,target:'amir',task:'Tech & Infrastructure'},
  {id:'cfo',name:'CFO',level:1,color:0x22c55e,target:'amir',task:'Revenue & Billing'},
  {id:'lamatrader-lead',name:'LamaTrader Lead',level:2,color:0xf59e0b,target:'lamatrader',task:'Trading Platform'},
  {id:'grademy-lead',name:'Grademy Lead',level:2,color:0xa855f7,target:'grademy',task:'EdTech Launch'},
  {id:'pripitch-lead',name:'Pripitch Lead',level:2,color:0xec4899,target:'pripitch',task:'Revival Sprint'},
  {id:'outreach-head',name:'Outreach Head',level:2,color:0x14b8a6,target:'ai-ragmedium',task:'Email+LinkedIn+SMS'},
  {id:'content-director',name:'Content Director',level:2,color:0xf97316,target:'content-empire',task:'Content Ops+Distribution'},
  {id:'rema-lead',name:'Remit Lead',level:2,color:0x06b6d4,target:'rema',task:'Construction Ops'},
  {id:'ventures-pm',name:'Ventures PM',level:2,color:0x64748b,target:'halal-booking',task:'Client Projects'},
];

// ─── Fibonacci sphere positions ───
function fibSphere(n,radius){
  const pts=[];
  const phi=Math.PI*(3-Math.sqrt(5));
  for(let i=0;i<n;i++){
    const y=1-(i/(n-1))*2;
    const rAtY=Math.sqrt(1-y*y);
    const theta=phi*i;
    pts.push({x:Math.cos(theta)*rAtY*radius,y:y*radius,z:Math.sin(theta)*rAtY*radius});
  }
  return pts;
}

// ─── Build Scene ───
const projectMeshes={},shipGroups=[],shipLabels={},connectors=[];
const positions=fibSphere(PROJECTS.length,55); // Spread across sphere radius 55

PROJECTS.forEach((p,i)=>{
  const pos=positions[i];
  
  // Planet — translucent glass
  const geo=new THREE.SphereGeometry(p.size,32,32);
  const mat=new THREE.MeshPhysicalMaterial({
    color:p.color,emissive:p.color,emissiveIntensity:0.3,
    roughness:0.2,metalness:0.1,transparent:true,opacity:0.35,
    clearcoat:0.1,clearcoatRoughness:0.2
  });
  const planet=new THREE.Mesh(geo,mat);
  planet.position.set(pos.x,pos.y,pos.z);
  planet.userData={isProject:true,projectId:p.id,project:p};
  scene.add(planet);
  projectMeshes[p.id]=planet;
  
  // Ring
  const ring=new THREE.Mesh(
    new THREE.TorusGeometry(p.size*1.4,0.06,16,48),
    new THREE.MeshBasicMaterial({color:p.color,transparent:true,opacity:0.2})
  );
  ring.position.copy(planet.position);
  ring.rotation.x=Math.random()*Math.PI;
  ring.userData={spin:0.1+Math.random()*0.2};
  scene.add(ring);
  planet.userData.ring=ring;
  
  // Wireframe shell
  const wire=new THREE.Mesh(
    new THREE.SphereGeometry(p.size*1.15,16,16),
    new THREE.MeshBasicMaterial({color:p.color,wireframe:true,transparent:true,opacity:0.08})
  );
  wire.position.copy(planet.position);
  scene.add(wire);
  planet.userData.wire=wire;
  
  // CSS2D Label
  const lbl=document.createElement('div');
  lbl.textContent=p.name;
  lbl.style.cssText=`color:rgba(255,255,255,0.6);font-size:${p.tier==='core'?'14px':'9px'};font-weight:600;letter-spacing:0.5px;text-shadow:0 0 10px rgba(0,0,0,0.8);white-space:nowrap;transition:opacity 0.3s`;
  const labelObj=new CSS2DObject(lbl);
  labelObj.position.copy(planet.position);
  labelObj.position.y+=p.size+1.5;
  labelObj.userData={baseOpacity:0.6};
  scene.add(labelObj);
  planet.userData.label=labelObj;
});

// ─── Agent Ships ───
function buildShip(agent,size,color){
  const g=new THREE.Group();
  const c=new THREE.Color(color);
  const m=new THREE.MeshPhysicalMaterial({color,emissive:color,emissiveIntensity:0.5,roughness:0.2,metalness:0.8});
  // Hull
  const hull=new THREE.Mesh(new THREE.CylinderGeometry(size*0.12,size*0.28,size*0.9,10),m);g.add(hull);
  // Nose
  const nose=new THREE.Mesh(new THREE.ConeGeometry(size*0.12,size*0.35,10),m);nose.position.y=size*0.62;g.add(nose);
  // Cockpit
  const cockpit=new THREE.Mesh(new THREE.SphereGeometry(size*0.14,8,8),
    new THREE.MeshPhysicalMaterial({color:0x88ccff,emissive:0x88ccff,emissiveIntensity:0.5,roughness:0.1,transparent:true,opacity:0.5}));
  cockpit.position.set(0,size*0.04,size*0.12);g.add(cockpit);
  // Wings
  for(let i=0;i<2;i++){
    const wing=new THREE.Mesh(new THREE.BoxGeometry(size*0.6,size*0.03,size*0.12),m);
    wing.position.set(i===0?-size*0.25:size*0.25,0,0);wing.rotation.z=i===0?0.15:-0.15;g.add(wing);
  }
  // Engine glow
  for(let i=0;i<2;i++){
    const glow=new THREE.Mesh(new THREE.SphereGeometry(size*0.08,6,6),
      new THREE.MeshBasicMaterial({color:0x44aaff,transparent:true,opacity:0.6,blending:THREE.AdditiveBlending,depthWrite:false}));
    glow.position.set(i===0?size*0.3:-size*0.3,0,-size*0.06);g.add(glow);
  }
  return g;
}

function buildMothership(size,color){
  const g=new THREE.Group();
  const c=new THREE.Color(color);
  const m=new THREE.MeshPhysicalMaterial({color,emissive:color,emissiveIntensity:0.7,roughness:0.1,metalness:0.9,clearcoat:0.3});
  const body=new THREE.Mesh(new THREE.CylinderGeometry(size*0.25,size*0.4,size*0.6,14),m);g.add(body);
  const bridge=new THREE.Mesh(new THREE.CylinderGeometry(size*0.2,size*0.25,size*0.25,14),
    new THREE.MeshPhysicalMaterial({color:0xffdd88,emissive:0xffdd88,emissiveIntensity:0.6,roughness:0.1,transparent:true,opacity:0.6}));
  bridge.position.y=size*0.45;g.add(bridge);
  for(let i=0;i<3;i++){
    const r=new THREE.Mesh(new THREE.TorusGeometry(size*(0.5+i*0.15),0.03,8,24),
      new THREE.MeshBasicMaterial({color:c,transparent:true,opacity:0.25,blending:THREE.AdditiveBlending,depthWrite:false}));
    r.rotation.x=Math.random()*Math.PI;r.userData={spin:0.1+Math.random()*0.2};g.add(r);
  }
  const core=new THREE.Mesh(new THREE.SphereGeometry(size*0.2,16,16),
    new THREE.MeshBasicMaterial({color:0xffffff,transparent:true,opacity:0.2,blending:THREE.AdditiveBlending,depthWrite:false}));
  core.position.y=size*0.08;g.add(core);
  return g;
}

AGENTS.forEach(a=>{
  const targetMesh=projectMeshes[a.target];
  if(!targetMesh)return;
  const tPos=targetMesh.position;
  const size=a.level===0?8:4.5;
  const group=a.level===0?buildMothership(size,a.color):buildShip(a,size,a.color);
  
  const angle=Math.random()*Math.PI*2;
  const orbitR=(PROJECTS.find(p=>p.id===a.target)?.size||3)*2.8+2;
  group.position.set(tPos.x+Math.cos(angle)*orbitR,tPos.y+(Math.random()-0.5)*2,tPos.z+Math.sin(angle)*orbitR);
  group.userData={agent:a,targetId:a.target,orbitRadius:orbitR,speed:0.15+Math.random()*0.2,angle,yOff:(Math.random()-0.5)*3,baseEmissive:0.5};
  scene.add(group);
  shipGroups.push(group);
  
  // Hover label — hidden by default
  const lb=document.createElement('div');
  lb.textContent=`${a.name} · ${a.task}`;
  lb.style.cssText='color:rgba(255,255,255,0.7);font-size:8px;letter-spacing:0.5px;font-family:monospace;opacity:0;transition:opacity 0.2s;background:rgba(0,0,0,0.7);padding:2px 6px;border-radius:3px;white-space:nowrap;pointer-events:none';
  const lblObj=new CSS2DObject(lb);
  lblObj.position.copy(group.position);lblObj.position.y+=size*0.7;
  scene.add(lblObj);
  shipLabels[a.id]={obj:lblObj,el:lb,ship:group};
});

// ─── Connector Lines (between agents that share a project) ───
function updateConnectors(){
  connectors.forEach(c=>scene.remove(c));
  connectors.length=0;
  
  const projectAgents={};
  AGENTS.forEach(a=>{if(!projectAgents[a.target])projectAgents[a.target]=[];projectAgents[a.target].push(a);});
  
  Object.values(projectAgents).forEach(agentList=>{
    for(let i=0;i<agentList.length;i++){
      for(let j=i+1;j<agentList.length;j++){
        const s1=shipGroups.find(s=>s.userData.agent?.id===agentList[i].id);
        const s2=shipGroups.find(s=>s.userData.agent?.id===agentList[j].id);
        if(!s1||!s2)continue;
        const geo=new THREE.BufferGeometry().setFromPoints([s1.position,s2.position]);
        const line=new THREE.Line(geo,new THREE.LineBasicMaterial({color:0x4488ff,transparent:true,opacity:0.08,depthWrite:false}));
        line.userData={a:s1,b:s2};
        connectors.push(line);
        scene.add(line);
      }
    }
  });
}
updateConnectors();

// ─── Agent Panel (right sidebar) ───
function updateAgentPanel(){
  const panel=document.getElementById('agent-panel');
  let html='';
  const tiers={0:'EXECUTIVE',1:'C-SUITE',2:'TEAM LEADS'};
  let lastTier='';
  AGENTS.forEach(a=>{
    if(tiers[a.level]!==lastTier){
      html+=`<div style="font-size:8px;color:rgba(255,255,255,0.2);padding:8px 10px 2px;text-transform:uppercase;letter-spacing:1px">${tiers[a.level]}</div>`;
      lastTier=tiers[a.level];
    }
    const sc=a.status==='active'?'#22c55e':a.status==='resting'?'#eab308':'#6b7280';
    html+=`<div class="ap-agent" onclick="focusShip('${a.id}')" data-agent="${a.id}">
      <span class="ap-dot" style="background:${sc};box-shadow:0 0 6px ${sc}"></span>
      <span class="ap-name">${a.name}</span>
      <span class="ap-task">${a.task}</span>
    </div>`;
  });
  panel.innerHTML=html;
}
updateAgentPanel();

// Make focusShip + focusProject global
window.focusShip=function(id){
  const ship=shipGroups.find(s=>s.userData.agent?.id===id);
  if(!ship)return;
  // Animate camera
  const target=ship.position.clone();
  controls.target.lerp(target,0.5);
  camera.position.lerp(target.clone().add(new THREE.Vector3(0,8,15)),0.5);
  // Highlight panel
  document.querySelectorAll('.ap-agent').forEach(el=>el.classList.remove('selected'));
  const panelEl=document.querySelector(`[data-agent="${id}"]`);
  if(panelEl)panelEl.classList.add('selected');
  // Open agent info
  openAgentModal(id);
};

window.focusProject=function(id){
  const mesh=projectMeshes[id];
  if(!mesh)return;
  controls.target.lerp(mesh.position,1);
  document.querySelectorAll('.ap-agent').forEach(el=>el.classList.remove('selected'));
  openProjectModal(id);
};

function openAgentModal(id){
  const a=AGENTS.find(x=>x.id===id);
  if(!a)return;
  const project=PROJECTS.find(p=>p.id===a.target);
  const modal=document.getElementById('info-modal');
  document.getElementById('modal-content').innerHTML=`
    <div class="modal-title" style="color:#${new THREE.Color(a.color).getHexString()}">${a.name}</div>
    <div class="modal-sub">${a.task} · ${a.level===0?'Executive':a.level===1?'C-Suite':'Team Lead'} · Assigned to: ${project?.name||a.target}</div>
    <div class="modal-card">
      <h4>Recent Activity</h4>
      <p style="font-size:12px;color:rgba(255,255,255,0.4)">Loading outputs from AI Slack...</p>
    </div>
    <div class="modal-card">
      <h4>Quick Actions</h4>
      <button class="top-btn" onclick="window.open('/slack','_blank')" style="margin:2px">💬 Open in Slack</button>
      <button class="top-btn" onclick="focusProject('${a.target}')" style="margin:2px">🪐 View Project</button>
    </div>
  `;
  modal.classList.add('open');
  
  // Fetch recent outputs
  fetch('/api/agents/status').then(r=>r.json()).then(d=>{
    const outputs=d.outputs?.[id]||[];
    if(outputs.length){
      document.querySelector('#modal-content .modal-card:first-of-type').innerHTML=`
        <h4>Recent Activity</h4>
        ${outputs.slice(-3).map(o=>`<div style="font-size:11px;color:rgba(255,255,255,0.6);padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.04)">${o.text||'(empty)'}</div>`).join('')}
      `;
    }
  });
}

function openProjectModal(id){
  const p=PROJECTS.find(x=>x.id===id);
  if(!p)return;
  const myAgents=AGENTS.filter(a=>a.target===id);
  const modal=document.getElementById('info-modal');
  document.getElementById('modal-content').innerHTML=`
    <div class="modal-title" style="color:#${new THREE.Color(p.color).getHexString()}">${p.name}</div>
    <div class="modal-sub">${p.tier.toUpperCase()} · ${p.desc} · ${myAgents.length} agents assigned</div>
    <div class="modal-card">
      <h4>Assigned Agents</h4>
      ${myAgents.map(a=>`<span class="agent-chip" style="background:#${new THREE.Color(a.color).getHexString()}22;color:#${new THREE.Color(a.color).getHexString()};border:1px solid #${new THREE.Color(a.color).getHexString()}44;cursor:pointer" onclick="focusShip('${a.id}')">${a.name}</span>`).join('')||'<span style="font-size:11px;color:rgba(255,255,255,0.3)">No agents assigned</span>'}
    </div>
    <div class="modal-card">
      <h4>Quick Actions</h4>
      <button class="top-btn" onclick="window.open('/slack','_blank')" style="margin:2px">💬 AI Slack</button>
    </div>
  `;
  modal.classList.add('open');
}

window.closeModal=function(){
  document.getElementById('info-modal').classList.remove('open');
};

// Tier filters
window.viewAll=function(){
  document.querySelectorAll('.top-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector('.top-btn').classList.add('active');
  PROJECTS.forEach(p=>{if(projectMeshes[p.id])projectMeshes[p.id].visible=true;});
  shipGroups.forEach(s=>{s.visible=true;});
};
window.viewTier=function(tier){
  document.querySelectorAll('.top-btn').forEach(b=>b.classList.remove('active'));
  event.target.classList.add('active');
  PROJECTS.forEach(p=>{
    const visible=p.tier===tier||p.tier==='core';
    if(projectMeshes[p.id]){
      projectMeshes[p.id].visible=visible;
      if(projectMeshes[p.id].userData.ring)projectMeshes[p.id].userData.ring.visible=visible;
      if(projectMeshes[p.id].userData.wire)projectMeshes[p.id].userData.wire.visible=visible;
      if(projectMeshes[p.id].userData.label)projectMeshes[p.id].userData.label.visible=visible;
    }
  });
  shipGroups.forEach(s=>{
    const target=s.userData?.targetId;
    const proj=PROJECTS.find(p=>p.id===target);
    s.visible=proj&&(proj.tier===tier||proj.tier==='core');
  });
};

// ─── Raycaster for clicks/hover ───
const raycaster=new THREE.Raycaster();
const mouse=new THREE.Vector2();
let hovered=null;

renderer.domElement.addEventListener('click',(e)=>{
  mouse.x=(e.clientX/W)*2-1;mouse.y=-(e.clientY/H)*2+1;
  raycaster.setFromCamera(mouse,camera);
  
  // Check ships first (they're interactive)
  const shipHits=raycaster.intersectObjects(shipGroups,true);
  if(shipHits.length){
    let obj=shipHits[0].object;
    while(obj&&!obj.userData?.agent)obj=obj.parent;
    if(obj?.userData?.agent){focusShip(obj.userData.agent.id);return;}
  }
  
  // Then check planets
  const planetHits=raycaster.intersectObjects(Object.values(projectMeshes));
  if(planetHits.length){
    const p=planetHits[0].object.userData?.projectId;
    if(p){focusProject(p);return;}
  }
  
  closeModal();
});

renderer.domElement.addEventListener('pointermove',(e)=>{
  mouse.x=(e.clientX/W)*2-1;mouse.y=-(e.clientY/H)*2+1;
  raycaster.setFromCamera(mouse,camera);
  
  const hits=raycaster.intersectObjects(shipGroups,true);
  let found=null;
  if(hits.length){
    let obj=hits[0].object;
    while(obj&&!obj.userData?.agent)obj=obj.parent;
    if(obj?.userData?.agent)found=obj.userData.agent.id;
  }
  
  if(hovered!==found){
    // Hide old
    if(hovered&&shipLabels[hovered])shipLabels[hovered].el.style.opacity='0';
    // Show new
    if(found&&shipLabels[found])shipLabels[found].el.style.opacity='1';
    hovered=found;
    renderer.domElement.style.cursor=found?'pointer':'grab';
  }
});

// ─── Status polling ───
let agentStatus={};
async function pollStatus(){
  try{
    const r=await fetch('/api/agents/status');
    const d=await r.json();
    // Update agent statuses
    if(d._cronJobs){
      d._cronJobs.forEach(j=>{
        const n=j.name?.toLowerCase()||'';
        if(n.includes('cmo'))agentStatus.cmo=j.lastStatus==='ok'?'active':'resting';
        if(n.includes('cto'))agentStatus.cto=j.lastStatus==='ok'?'active':'resting';
        if(n.includes('cfo'))agentStatus.cfo=j.lastStatus==='ok'?'active':'resting';
      });
    }
    // Update ship emissive based on status
    shipGroups.forEach(s=>{
      const a=s.userData?.agent;
      if(!a)return;
      const st=agentStatus[a.id]||'active';
      s.traverse(c=>{
        if(c.material?.emissiveIntensity!==undefined){
          c.material.emissiveIntensity=st==='active'?0.8:st==='resting'?0.3:0.15;
        }
      });
    });
    // Update panel dots
    document.querySelectorAll('.ap-agent').forEach(el=>{
      const id=el.dataset.agent;
      const st=agentStatus[id]||'active';
      const dot=el.querySelector('.ap-dot');
      if(dot){
        dot.style.background=st==='active'?'#22c55e':st==='resting'?'#eab308':'#6b7280';
        dot.style.boxShadow=`0 0 6px ${st==='active'?'#22c55e':st==='resting'?'#eab308':'#6b7280'}`;
      }
    });
  }catch(e){}
}
setInterval(pollStatus,15000);
setTimeout(pollStatus,3000);

// ─── Animate ───
function animate(){
  requestAnimationFrame(animate);
  
  const t=performance.now()*0.001;
  
  // Orbit ships
  shipGroups.forEach(s=>{
    const ud=s.userData;
    if(!ud?.targetId)return;
    const targetMesh=projectMeshes[ud.targetId];
    if(!targetMesh||!targetMesh.visible){s.visible=false;return;}
    s.visible=true;
    ud.angle+=ud.speed*0.01;
    const tp=targetMesh.position;
    s.position.x=tp.x+Math.cos(ud.angle)*ud.orbitRadius;
    s.position.z=tp.z+Math.sin(ud.angle)*ud.orbitRadius;
    s.position.y=tp.y+Math.sin(ud.angle*1.3)*ud.yOff;
    s.rotation.y=ud.angle+Math.PI/2;
    s.rotation.z=Math.sin(t*0.5+ud.angle)*0.15;
    
    // Update label position
    const lbl=shipLabels[ud.agent?.id];
    if(lbl)lbl.obj.position.copy(s.position).add(new THREE.Vector3(0,ud.agent?.level===0?8:4,0));
  });
  
  // Spin rings
  projectMeshes && Object.values(projectMeshes).forEach(p=>{
    if(p.userData?.ring)p.userData.ring.rotation.z+=0.003;
  });
  
  // Update connector lines
  connectors.forEach(c=>{
    if(c.userData?.a&&c.userData?.b){
      const pos=[c.userData.a.position,c.userData.b.position];
      c.geometry.dispose();
      c.geometry=new THREE.BufferGeometry().setFromPoints(pos);
    }
  });
  
  updateHandControl(0.016); // Hand gesture control (~60fps dt)
  controls.update();
  renderer.render(scene,camera);
  labelRenderer.render(scene,camera);
  
  // Hide loading
  const loader=document.getElementById('loading');
  if(loader&&t>2)loader.style.display='none';
  
  // Fade help hint
  const hint=document.getElementById('help-hint');
  if(hint&&t>8)hint.style.opacity=Math.max(0,parseFloat(hint.style.opacity||1)-0.003);
}

animate();

// ─── HAND TRACKING (MediaPipe) ───
let handTracking=false,handLandmarks=null,prevPinchDist=null,prevHandX=null,prevHandY=null;
window.toggleHandTracking=function(){
  handTracking=!handTracking;
  const btn=document.getElementById('hand-toggle');
  const hint=document.getElementById('help-hint');
  const cam=document.getElementById('cam-preview');
  if(handTracking){
    btn.textContent='🖐️ Hand Control ON';btn.classList.add('on');
    hint.textContent='✊ pinch to zoom · ✋ drag to rotate';cam.classList.add('on');
    startHandTracking();
  }else{
    btn.textContent='🖐️ Hand Control';btn.classList.remove('on');
    hint.textContent='🖱 Drag to rotate · Scroll to zoom · Click planets & ships';cam.classList.remove('on');
    stopHandTracking();controls.enabled=true;
  }
};
async function startHandTracking(){
  try{
    const[{HandLandmarker,FilesetResolver}]=await Promise.all([import('https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/+esm')]);
    const vision=await FilesetResolver.forVisionTasks('https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/wasm');
    const handLandmarker=await HandLandmarker.createFromOptions(vision,{
      baseOptions:{modelAssetPath:'https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/latest/hand_landmarker.task',delegate:'GPU'},
      runningMode:'VIDEO',numHands:1
    });
    const video=document.getElementById('cam-video');
    const stream=await navigator.mediaDevices.getUserMedia({video:{width:640,height:480,facingMode:'user'}});
    video.srcObject=stream;await video.play();
    controls.enabled=false;
    let lastTime=performance.now();
    async function detectFrame(){
      if(!handTracking)return;
      const now=performance.now();
      if(now-lastTime<50){requestAnimationFrame(detectFrame);return;}lastTime=now;
      try{const results=handLandmarker.detectForVideo(video,performance.now());handLandmarks=results.landmarks?.[0]||null;}catch(e){handLandmarks=null;}
      requestAnimationFrame(detectFrame);
    }
    detectFrame();
  }catch(e){console.warn('Hand tracking:',e.message);document.getElementById('hand-toggle').textContent='🖐️ Camera denied';handTracking=false;}
}
function stopHandTracking(){
  const video=document.getElementById('cam-video');
  if(video.srcObject){video.srcObject.getTracks().forEach(t=>t.stop());video.srcObject=null;}
  handLandmarks=null;prevPinchDist=null;prevHandX=null;prevHandY=null;
}
function updateHandControl(dt){
  if(!handTracking||!handLandmarks)return;
  const lm=handLandmarks;
  const thumb=lm[4],index=lm[8],middle=lm[12],wrist=lm[0];
  const wx=1-wrist.x,wy=wrist.y;
  const pinchDist=Math.hypot(thumb.x-index.x,thumb.y-index.y,(thumb.z||0)-(index.z||0));
  const fingersOpen=Math.hypot(middle.x-wrist.x,middle.y-wrist.y);
  const gesEl=document.getElementById('hd-gesture'),posEl=document.getElementById('hd-pos');
  if(pinchDist<0.08){
    gesEl.textContent='PINCH';posEl.textContent=pinchDist.toFixed(3);
    if(prevPinchDist!==null){
      const delta=prevPinchDist-pinchDist;
      const zoomSpeed=300*dt;
      camera.position.multiplyScalar(1+delta*zoomSpeed);
      camera.position.clampLength(30,500);
    }
    prevPinchDist=pinchDist;prevHandX=null;prevHandY=null;
  }else if(fingersOpen>0.15&&pinchDist>0.15){
    gesEl.textContent='DRAG';posEl.textContent=`${wx.toFixed(2)},${wy.toFixed(2)}`;
    if(prevHandX!==null&&prevHandY!==null){
      const dx=wx-prevHandX,dy=wy-prevHandY,rotSpeed=3.0;
      const camPos=camera.position.clone().sub(controls.target);
      const spherical=new THREE.Spherical().setFromVector3(camPos);
      spherical.theta-=dx*rotSpeed;spherical.phi-=dy*rotSpeed;
      spherical.phi=Math.max(0.1,Math.min(Math.PI-0.1,spherical.phi));spherical.makeSafe();
      camera.position.copy(controls.target).add(new THREE.Vector3().setFromSpherical(spherical));
      camera.lookAt(controls.target);
    }
    prevHandX=wx;prevHandY=wy;prevPinchDist=null;
  }else{gesEl.textContent='idle';prevPinchDist=null;prevHandX=null;prevHandY=null;}
}

// ─── Resize ───
window.addEventListener('resize',()=>{
  const w=window.innerWidth,h=window.innerHeight;
  camera.aspect=w/h;camera.updateProjectionMatrix();
  renderer.setSize(w,h);labelRenderer.setSize(w,h);
});

// ─── Voice Calling (Web Speech API) ───
let voiceListening=false,recognition=null;
window.toggleVoice=function(){
  const btn=document.getElementById('voice-btn');
  const status=document.getElementById('voice-status');
  if(voiceListening){stopVoice();return;}
  const SpeechRecognition=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SpeechRecognition){alert('Voice not supported in this browser');return;}
  recognition=new SpeechRecognition();
  recognition.continuous=false;recognition.interimResults=false;recognition.lang='en-US';
  recognition.onstart=()=>{voiceListening=true;btn.classList.add('listening');btn.textContent='🔴 STOP';status.style.display='block';};
  recognition.onresult=(e)=>{
    const text=e.results[0][0].transcript;
    status.textContent='📝 "'+text+'" — processing...';
    status.style.color='#f59e0b';
    // Send voice command through dashboard chat
    fetch('/api/commands',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text:text,threadId:'general',target:'assistant'})})
      .then(r=>r.json()).then(d=>{
        status.textContent='✅ Sent: "'+text+'"';
        status.style.color='#22c55e';
        setTimeout(()=>{status.style.display='none';},2000);
      }).catch(()=>{
        status.textContent='❌ Failed to send';
        status.style.color='#ef4444';
      });
    stopVoice();
  };
  recognition.onerror=(e)=>{status.textContent='❌ Voice error: '+e.error;status.style.color='#ef4444';stopVoice();};
  recognition.onend=()=>{stopVoice();};
  recognition.start();
};
function stopVoice(){
  voiceListening=false;
  const btn=document.getElementById('voice-btn');
  btn.classList.remove('listening');btn.textContent='🎤 VOICE';
  if(recognition){try{recognition.stop();}catch(e){}}
}
</script>
</body>
</html>
