  const type=status==='paid'?(confirm('Recurring (OK) or one-time (Cancel)?')?'recurring':'nonrecurring'):'nonrecurring';
  const desc=prompt('Description?')||'';
  const pid=projectDetailId||prompt('Project ID?')||'';
  const date=status==='paid'?todayKey():(prompt('Expected date (YYYY-MM-DD)?')||todayKey());
  await api('/api/payments',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({projectId:pid,amount:parseFloat(amount),type,status,description:desc,date})});
  await load();
}

