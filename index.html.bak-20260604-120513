// ─── AI CHAT BAR ──────────────────────────────────────
function autoResizeChatInput(){
  const el=$('chatInput');
  if(!el)return;
  el.style.height='auto';
  el.style.height=Math.min(el.scrollHeight,200)+'px';
}
function sendChatMessage(msg){
  const input=$('chatInput');
  const text=msg||(input?input.value:'').trim();
  if(!text)return;
  if(input){input.value='';input.style.height='auto';}
  
  // Parse commands locally — execute directly + ALSO send to AI
  const lower=text.toLowerCase();
  
  // Auto-detect payment data in ANY message
  // Match patterns like: "ProjectName £X paid", "ProjectName: £X upcoming", "£X for Project"
  const paymentPatterns=[];
  const lines=text.split(/[,;\n]+/);
  for(const line of lines){
    const ll=line.toLowerCase().trim();
    if(!ll)continue;
    // Try: "Project £X [status]" or "Project: £X [status]"
    let m=ll.match(/([a-z][a-z0-9\s]+?)\s*[:\-]?\s*[£$€]?\s*(\d+[.,]?\d*)\s*(k|k)?\s*(paid|upcoming|pipeline|monthly|mrr)?/i);
    if(!m) m=ll.match(/[£$€]\s*(\d+[.,]?\d*)\s*(k)?\s*(?:paid|upcoming|pipeline|monthly|mrr)?\s*(?:for|from|to|:)?\s*(.+)/i);
    if(m){
      let projectName='', amount=0, status='paid', desc='', type='nonrecurring';
      if(m[1]&&!/^\d+$/.test(m[1])&&parseFloat((m[2]||'0').replace(',','.'))>0){ // "Project £X [status]"
        projectName=m[1].trim().replace(/^[\s:,.-]+/,'').replace(/[\s:,.-]+$/,'');
        amount=parseFloat((m[2]||'0').replace(',','.'))*((m[3]||'').toLowerCase()==='k'?1000:1);
        if(m[4]){status=m[4].toLowerCase();if(status==='monthly'||status==='mrr'){status='paid';type='recurring'}}
        desc=projectName+' payment';
      } else if(m[3]&&m[4]){ // "£X [status] for Project"
        amount=parseFloat((m[1]||'0').replace(',','.'))*((m[2]||'').toLowerCase()==='k'?1000:1);
        status=m[3].toLowerCase();if(status==='monthly'||status==='mrr'){status='paid';type='recurring'}
        projectName=m[4].trim();
        desc=projectName+' payment';
      }
      if(projectName&&amount>10){
        const biz=(state.businesses||[]).find(b=>projectName.toLowerCase().includes(b.name.toLowerCase())||b.name.toLowerCase().includes(projectName.toLowerCase()));
        paymentPatterns.push({projectId:biz?biz.id:'',amount,type:type||'nonrecurring',status:status||'paid',description:desc,date:todayKey()});
      }
    }
  }
  
  // Execute detected payments
  for(const pp of paymentPatterns){
    api('/api/payments',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(pp)});
  }
  
  // Also handle explicit commands
  // "add task: X" or "add todo: X"
  if(lower.startsWith('add task')||lower.startsWith('add todo')||lower.startsWith('task:')){
    const taskText=text.replace(/^(add\s+task\s*:?|add\s+todo\s*:?|task\s*:?)\s*/i,'');
    if(taskText){
      api('/api/todos',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),text:taskText,priority:'medium'})});
    }
  }
  
  // "mark X as done" / "complete X"
  if(lower.includes('mark')&&(lower.includes('done')||lower.includes('complete'))){
    const kw=text.replace(/mark\s+|as\s+|done|complete/gi,'').trim().toLowerCase();
    const arr=(state.todos||{})[todayKey()]||[];
    const match=arr.find(t=>t.text.toLowerCase().includes(kw));
    if(match) api('/api/todos/'+match.id,{method:'PATCH',headers:{'content-type':'application/json'},body:JSON.stringify({done:true})});
  }
  
  // Navigation commands
  if(lower.includes('show projects')||lower.includes('go to projects')){navTo('projects');load();return}
  if(lower.includes('show stats')||lower.includes('show revenue')||lower.includes('show mrr')){projView='stats';navTo('projects');load();return}
  if(lower.includes('show list')||lower.includes('show calendar')){projView='list';navTo('projects');load();return}
  if(lower.includes('show schedule')||lower.includes('show timetable')){navTo('schedule');load();return}
  if(lower.includes('show chat')||lower.includes('go to chat')){navTo('chat');load();return}
  if(lower.includes('show todo')||lower.includes('show tasks')){navTo('todo');load();return}
  if(lower.includes('show home')){navTo('home');load();return}
  
  // ─── Daily check-in commands ───
  // "mood 4", "feeling great" (maps to mood 5), "productivity 7", "worked 6 hours"
  const moodMatch=text.match(/(?:mood|feeling)\s*(\d|awful|meh|okay|good|great)/i);
  if(moodMatch){
    let v=moodMatch[1].toLowerCase();
    if(v==='awful')v=1;else if(v==='meh')v=2;else if(v==='okay'||v==='ok')v=3;else if(v==='good')v=4;else if(v==='great')v=5;else v=parseInt(v)||3;
    fetch('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field:'mood',value:Math.min(5,Math.max(1,v))})}).catch(()=>{});
  }
  const prodMatch=text.match(/productivity\s*(\d+)/i);
  if(prodMatch){const v=Math.min(10,Math.max(1,parseInt(prodMatch[1])||5));fetch('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field:'productivity',value:v})}).catch(()=>{});}
  const hoursMatch=text.match(/(?:worked|did)\s*(\d+(?:\.\d+)?)\s*(?:hours?|hrs?|h)/i);
  if(hoursMatch){const v=Math.min(24,Math.max(0,parseFloat(hoursMatch[1])||0));fetch('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field:'hours',value:v})}).catch(()=>{});}
  
  // ─── Thread management: page-aware ───
  let thread;
  if(activePage==="chat"){
    thread=currentThread();
    pageThreads[activePage]=thread.id;
  } else {
    thread=ensureFreshThread();
  }
  // Tag thread with current page context if not already set
  if(thread.context) thread.context.page=activePage;
  // On project detail page, inject the project ID so AI knows which project you're on
  if(activePage==='project-detail' && projectDetailId){
    thread.context.businessIds = [projectDetailId];
    const proj = (state.businesses||[]).find(b=>b.id===projectDetailId);
    if(proj) thread.context.projectName = proj.name;
  }
  
  const userMsg={id:'usr_'+Date.now(),role:'user',text:text,at:new Date().toISOString(),surface:'dashboard',threadId:thread.id};
  thread.messages=thread.messages||[];
  thread.messages.push(userMsg);
  // Add client-side Thinking placeholder immediately
  const thinkMsg={id:'think_'+Date.now(),role:'assistant',text:'Thinking…',pending:true,at:new Date().toISOString()};
  thread.messages.push(thinkMsg);
  // Open chat overlay immediately on non-chat pages
  if(activePage!=='chat') openChatOverlay();
  
  api('/api/threads/'+thread.id+'/messages',{
    method:'POST',headers:{'content-type':'application/json'},
    body:JSON.stringify({message:text,projectId:(thread.context?.businessIds||[])[0]||'',async:true,model:activeModel})
  }).then(res=>{
    if(res.queued){
      let attempts=0;
      const poll=()=>{
        attempts++;
        if(attempts>40)return;
        api('/api/state').then(s=>{
          state=s;
          const t2=(s.brain?.threads||[]).find(x=>x.id===thread.id);
          if(t2){
            const serverMsgs=t2.messages||[];
            const localMsgs=thread.messages||[];
            const hasNew=serverMsgs.length!==localMsgs.length || JSON.stringify(serverMsgs.slice(-1))!==JSON.stringify(localMsgs.slice(-1));
            if(hasNew){
              thread.messages=serverMsgs;
              if(activePage==='chat')renderChat();
              else if($('chatOverlay').classList.contains('open')) renderChatOverlayMsgs();
              else openChatOverlay();
            }
            // Check for final response (non-pending assistant message) to stop polling
            const lastMsg=serverMsgs[serverMsgs.length-1];
            if(lastMsg && lastMsg.role==='assistant' && !lastMsg.pending){
              // Real-time refresh: update todos and project page if relevant
              if(activePage==='todo') renderTodos();
              else if(activePage==='project-detail') renderProjectDetail();
              else if(activePage==='home') renderHomeStats();
              return;
            }
            setTimeout(poll,500);
          } else setTimeout(poll,500);
        }).catch(()=>setTimeout(poll,500));
      };
      setTimeout(poll,500);
    }
    setTimeout(()=>load(),2000);
  }).catch(()=>{});
  // Also reload for local payment creations
  setTimeout(()=>load(),500);
}
