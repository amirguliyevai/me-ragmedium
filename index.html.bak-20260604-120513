async function sendCodeCommand(){
  const input=$('codeInput');
  const text=input.value.trim();
  if(!text)return;
  input.value='';
  
  const project=$('codeProject').value;
  // Create a new thread or reuse existing
  const r=await fetch('/api/threads',{
    method:'POST',
    headers:{'content-type':'application/json'},
    body:JSON.stringify({
      title:'⌘ Code: '+clip(text,40),
      businessIds:project==='__all'?[]:[project],
      scope:'Coding workspace chat'
    })
  });
  const d=await r.json();
  if(d.thread){
    // Send the message
    const r2=await fetch('/api/threads/'+d.thread.id+'/messages',{
      method:'POST',
      headers:{'content-type':'application/json'},
      body:JSON.stringify({message:text, async:true})
    });
    await r2.json();
    // Switch to chat page with this thread
    activeThread=d.thread.id;
    navTo('chat');
  }
}

