function getLast7Days(){
  const days=[];const d=new Date();
  for(let i=6;i>=0;i--){const n=new Date(d);n.setDate(d.getDate()-i);if(n.getHours()<6)n.setDate(n.getDate()-1);days.push(n.getFullYear()+'-'+String(n.getMonth()+1).padStart(2,'0')+'-'+String(n.getDate()).padStart(2,'0'));}
  return days;
}
async function setCheckin(field,value){
  const s=state;const sm=s.metrics||{};sm.dailyCheckin||={};sm.dailyCheckin[todayKey()]||={};
  sm.dailyCheckin[todayKey()][field]=field==='mood'?Number(value):field==='hours'?parseFloat(value)||0:Number(value);
  await api('/api/checkin',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({date:todayKey(),field,value:sm.dailyCheckin[todayKey()][field]})});
  await load();
}

