function renderCalendar(){
  const grid=$('calGrid'),ml=$('calMonth'),ev=$('dayEvents');
  if(!grid)return;
  const y=calCursor.getFullYear(),m=calCursor.getMonth();
  const first=new Date(y,m,1).getDay()||7;const days=new Date(y,m+1,0).getDate();
  const today=todayKey();const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  if(ml)ml.textContent=months[m]+' '+y;
  const events=state.brain?.calendar||[];
  let html='';['M','T','W','T','F','S','S'].forEach(d=>{html+=`<div style="font-size:10px;color:var(--dim);text-align:center;font-weight:700;padding:4px 0">${d}</div>`});
  for(let i=1-first+1;i<=days;i++){
